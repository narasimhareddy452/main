    <validationRules>
        <fullName>city_is_required</fullName>
        <active>true</active>
        <description>city_is_required</description>
        <errorConditionFormula>ISNULL( City__c )</errorConditionFormula>
        <errorDisplayField>City__c</errorDisplayField>
        <errorMessage>city_is_required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>mobile_no_is_required</fullName>
        <active>true</active>
        <description>mobile no is required</description>
        <errorConditionFormula>ISNULL( Mobile__c )</errorConditionFormula>
        <errorDisplayField>Mobile__c</errorDisplayField>
        <errorMessage>mobile no is required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>name_is_required</fullName>
        <active>true</active>
        <description>please enter first name</description>
        <errorConditionFormula>ISNULL( FirstName__c )</errorConditionFormula>
        <errorDisplayField>FirstName__c</errorDisplayField>
        <errorMessage>please enter first name</errorMessage>
    </validationRules>
