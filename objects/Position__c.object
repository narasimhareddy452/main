    <validationRules>
        <fullName>CloseDateRule</fullName>
        <active>true</active>
        <description>Close Date must be specified when Status is
set to &apos;Closed - Filled&apos; or &apos;Closed - Not Approved</description>
        <errorConditionFormula>AND( ISNULL( CloseDate__c ) , OR( ISPICKVAL( Status__c , &quot;Closed - Filled&quot;), ISPICKVAL( Status__c , &quot;Closed - Not Approved&quot;)))</errorConditionFormula>
        <errorDisplayField>CloseDate__c</errorDisplayField>
        <errorMessage>Close Date must be specified when Status
is set to &apos;Closed</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>MinPayRule</fullName>
        <active>true</active>
        <description>Min Pay should never exceed Max Pay</description>
        <errorConditionFormula>MinPay__c  &gt;  MaxPay__c</errorConditionFormula>
        <errorDisplayField>MinPay__c</errorDisplayField>
        <errorMessage>Min Pay cannot exceed Max Pay</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
