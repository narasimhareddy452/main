                    "copado__Parameters__c": "[ {\n  \"required\" : true,\n  \"name\" : \"userStoryBranches\",\n  \"defaultValue\" : \"{$Context.apex.cmcSf.GetUserStoryBranchesInOrder}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"promotionBranch\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.promotionBranchName}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"targetBranch\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.destinationBranchName}\"\n}, {\n  \"required\" : false,\n  \"name\" : \"tag\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.Promotion__r.Release__r.Version__c}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"git_json\",\n  \"defaultValue\" : \"{$Context.Repository.Credential}\"\n}, {\n  \"required\" : false,\n  \"name\" : \"recreatePromotionBranch\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.Promotion__r.cmcSf__Recreate_Promotion_Branch__c}\"\n}, {\n  \"name\" : \"promotionId\",\n  \"defaultValue\" : \"{$Job.ExecutionParent.Id}\"\n}, {\n  \"name\" : \"fileChangesId\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.fileWithSelectedChanges}\"\n}, {\n  \"name\" : \"conflictResolutionAttachments\",\n  \"defaultValue\" : \"{$Context.apex.GetConflictResolutionAttachments}\"\n}, {\n  \"name\" : \"gitName\",\n  \"defaultValue\" : \"{$User.Name}\"\n}, {\n  \"name\" : \"gitEmail\",\n  \"defaultValue\" : \"{$User.Email}\"\n}, {\n  \"name\" : \"repositoryId\",\n  \"defaultValue\" : \"{$Pipeline.Git_Repository__r.Id}\"\n}, {\n  \"required\" : false,\n  \"name\" : \"gitDepth\",\n  \"defaultValue\" : \"{$Pipeline.Property.gitDepth_promote}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"fileName\",\n  \"defaultValue\" : \"Copado Promotion changes\"\n}, {\n  \"name\" : \"overriddenApiVersion\",\n  \"defaultValue\" : \"\"\n}, {\n  \"name\" : \"disableXMLDeDuplication\",\n  \"defaultValue\" : \"{$Pipeline.Property.DisableXMLDeDuplication}\"\n}, {\n  \"name\" : \"disableSmartConflictResolution\",\n  \"defaultValue\" : \"{$Property.sfdx_disable_smart_conflict_resolution}\"\n}, {\n  \"name\" : \"sourceBranch\",\n  \"defaultValue\" : \"{$Context.apex.SourceEnvironmentBranch}\"\n}, {\n  \"name\" : \"promotionMethod\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.Promotion__r.Promotion_Method__c}\"\n}, {\n  \"name\" : \"destinationSessionid\",\n  \"defaultValue\" : \"{$Destination.Credential.SessionId}\"\n}, {\n  \"name\" : \"destinationInstanceUrl\",\n  \"defaultValue\" : \"{$Destination.Credential.Endpoint}\"\n}, {\n  \"name\" : \"overrideDestinationChanges\",\n  \"defaultValue\" : \"{$Destination.Property.Env_Sync_Back_Promote_Override_Destination_Changes}\"\n}, {\n  \"name\" : \"otherInformationJson\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.otherInformation}\"\n} ]",
                    "copado__Result_Viewer_Component__c": "cmcSf:resultViewer",
                    "copado__Script__c": "#!/usr/bin/env node\n'use strict';\n\n/**\n * Performs promotion of selected user story metadata changes.\n * Returns (If ACTION success) new promotion branch in user repo with all the changes\n * (If ACTION failed) Returns details with conflict or error status on promotion record\n * @param userStoryBranches\n * @param promotionBranch\n * @param targetBranch\n * @param tag\n * @param recreatePromotionBranch\n * @param promotionId\n * @param fileChangesId\n * @param conflictResolutionAttachments\n * @param gitName\n * @param gitEmail\n * @param repositoryId\n * @param gitDepth\n * @param maxBuffer\n *\n * Environment Sync variables\n * @param sourceBranch\n * @param destinationInstanceUrl\n * @param destinationSessionid\n * @param promotionMethod\n * @param overrideDestinationChanges\n * @param otherInformationJson\n */\n\nconst child_process = require('child_process'),\n\t{ existsSync, readFileSync, writeFileSync } = require('fs'),\n\tprocess = require('process');\nconst {\n\t\tfileChangesId,\n\t\ttargetBranch,\n\t\tpromotionBranch,\n\t\tgitDepth,\n\t\tgitEmail,\n\t\tgitName,\n\t\tpromotionId,\n\t\trepositoryId,\n\t\tconflictResolutionAttachments,\n\t\tuserStoryBranches,\n\t\ttag,\n\t\trecreatePromotionBranch,\n\t\tfileName,\n\t\toverriddenApiVersion,\n\t\tAPI_VERSION,\n\t\tisTest,\n\t\tGIT_BATCH_SIZE,\n\t\tdisableXMLDeDuplication,\n\t\tdisableSmartConflictResolution,\n\t\tsourceBranch,\n\t\tdestinationInstanceUrl,\n\t\tdestinationSessionid,\n\t\tpromotionMethod,\n\t\toverrideDestinationChanges,\n\t\totherInformationJson\n\t} = process.env,\n\t{ Ux } = isTest ? require('@salesforce/sf-plugins-core') : require('/usr/local/lib/node_modules/@salesforce/sf-plugins-core'),\n\tAPP_DIRECTORY = getPath('/app'),\n\tTEMP_DIRECTORY = getPath('/tmp'),\n\tTARGET_DIRECTORY = `${APP_DIRECTORY}/repository`,\n\tOUTPUT_JSON_PATH = `${TEMP_DIRECTORY}/output.json`,\n\tGIT_STATUS_FILE_PATH = `${TEMP_DIRECTORY}/git_status.txt`,\n\tENRICHED_CHANGE_FILE_PATH = `${TEMP_DIRECTORY}/enrichedPromotionChanges.json`,\n\tVLOCITY_CATEGORY = 'Vlocity',\n\tGIT_DEPTH = getGitDepth(gitDepth),\n\tPORCELAIN_STATUS = {\n\t\tADDED: 'A',\n\t\tDELETED: 'D',\n\t\tUNMERGED: 'U'\n\t},\n\tMETADATA_TYPE = {\n\t\tLAYOUT: 'layout'\n\t},\n\tACTIONS = {\n\t\tADD: 'add',\n\t\tFULL: 'full',\n\t\tSELECTIVE_COMMIT: 'selectivecommit'\n\t},\n\tCOPADO_INFO_PREFIX = 'CopadoFunction INFO',\n\tLOG_LEVEL = {\n\t\tERROR: 'error',\n\t\tWARN: 'warn',\n\t\tSUCCESS: 'success'\n\t},\n\tRESULT_INFO = {\n\t\tLEVEL: {\n\t\t\tINFO: 'INFO',\n\t\t\tERROR: 'ERROR',\n\t\t\tWARN: 'WARN'\n\t\t},\n\t\tCATEGORY: {\n\t\t\tUNKNOWN_EXCEPTION: 'Unknown Exception',\n\t\t\tCOPADO_INFO: 'Copado Info',\n\t\t\tCOPADO_METADATA_INTELLIGENCE: 'Copado Metadata Intelligence',\n\t\t\tGIT: 'Git',\n\t\t\tCOPADO_SERVICE: 'Copado Service',\n\t\t\tFILE_SYSTEM: 'File System',\n\t\t\tGIT_SERVICE: 'Git Service'\n\t\t},\n\t\tADDITIONAL_INFORMATION: {\n\t\t\tGIT_STATUS: 'Git Status',\n\t\t\tGIT_CONFIG: 'Git Configuration',\n\t\t\tPROMOTION_BRANCH_CHECKOUT: 'Promotion Branch Checkout',\n\t\t\tENRICHER_SERVICE: 'Enricher Service',\n\t\t\tCOPADO_MERGE: 'Copado Merge',\n\t\t\tUPLOAD_FILES: 'Upload Files',\n\t\t\tDOWNLOAD_FILES: 'Download Files',\n\t\t\tGIT_MERGE: 'Git Merge',\n\t\t\tGIT_PUSH: 'Git Push',\n\t\t\tGIT_ADD: 'Git Add',\n\t\t\tGIT_CHECKOUT: 'Git Checkout',\n\t\t\tGIT_FETCH: 'Git Fetch',\n\t\t\tGIT_FETCH_BRANCHES: 'Git Fetch Feature Branches',\n\t\t\tGIT_RESET: 'Git Reset',\n\t\t\tGIT_FIND_COMMIT_ID: 'Git Find Commit Id',\n\t\t\tSETUP_DIRECTORY: 'Setup Directory',\n\t\t\tLIST_REMOTE_REFERENCES: 'List Remote References',\n\t\t\tFILE_CREATE: 'File Create'\n\t\t}\n\t},\n\tCUSTOM_ERROR = {\n\t\tCOMMAND_EXECUTION_ERROR: 'CommandExecutionError'\n\t},\n\tRESULT_TABLE_HEADER = {\n\t\tlabel: 'Promote Result',\n\t\tcustomLabel: 'Promote_Result'\n\t},\n\tHEADER_ICON = 'standard:note',\n\tRESULT_TABLE_COLUMNS = [\n\t\t{\n\t\t\tlabel: 'Level',\n\t\t\tfieldName: 'Level',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Level',\n\t\t\tinitialWidth: 80\n\t\t},\n\t\t{\n\t\t\tlabel: 'Category',\n\t\t\tfieldName: 'Category',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Category',\n\t\t\tinitialWidth: 120\n\t\t},\n\t\t{\n\t\t\tlabel: 'Additional Information',\n\t\t\tfieldName: 'AdditionalInformation',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Additional_Information',\n\t\t\tinitialWidth: 200\n\t\t},\n\t\t{\n\t\t\tlabel: 'Message',\n\t\t\tfieldName: 'Message',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Message'\n\t\t}\n\t];\n\n// Environment Sync constants\nconst ENVIRONMENT_SYNC_CONFIG = {\n\tPRE_CHANGE_BRANCH: 'promotion/envsync_prechanges',\n\tPOST_CHANGE_BRANCH: 'promotion/envsync_postchanges',\n\tPROMOTION_METHOD: 'Environment Sync'\n};\n\nconst LOG_MESSAGES = {\n\tENV_SYNC_START: 'Starting Environment Sync Flow',\n\tENV_SYNC_COMPLETE: 'Environment Sync Flow Completed Successfully',\n\tCONFLICT_RESOLUTION: 'Resolving conflicts in environment sync',\n\tENVIRONMENT_SYNC: 'US-EnvironmentSync'\n};\n\n// Global state variables\nlet executionError,\n\ttotalTimeByType = {},\n\tprocesses = [],\n\tresultViewerJson = [],\n\thasPrefetchedVolume = false,\n\tshallowSinceSupportedForEnvSync = true,\n\t// Tracks whether git fetch --deepen is supported for this Environment Sync run.\n\tgitDeepenSupportedForEnvSync = true,\n\tenvSyncSourceBranch = sourceBranch;\n\n/**\n * =====================\n * Business Logic Functions\n * =====================\n */\n\nasync function execute() {\n\ttry {\n\t\tconst { userStoryBranchesList, errorInOrderingUS, promotionChangesFilePath, promotionChanges, shallowSinceDate } =\n\t\t\tawait this.initializeExecution();\n\t\tif (this.isEnvironmentSync()) {\n\t\t\tawait this.executeEnvironmentSyncFlow(userStoryBranchesList, promotionChanges, shallowSinceDate);\n\t\t} else {\n\t\t\tawait this.executeRegularPromotionFlow(userStoryBranchesList, errorInOrderingUS, promotionChangesFilePath, promotionChanges);\n\t\t}\n\t} catch (err) {\n\t\tthis.handleExecutionError(err);\n\t} finally {\n\t\tthis.finalizeExecution();\n\t}\n}\n\nasync function initializeExecution() {\n\tthis.checkPrefetchedVolume();\n\tconst { userStoryBranchesList, errorInOrderingUS, shallowSinceDate } = this.validateUserStoriesBranches(userStoryBranches);\n\tconst { promotionChangesFilePath, promotionChanges } = await this.getPromotionChanges(fileChangesId, fileName);\n\treturn { userStoryBranchesList, errorInOrderingUS, promotionChangesFilePath, promotionChanges, shallowSinceDate };\n}\n\nasync function executeRegularPromotionFlow(userStoryBranchesList, errorInOrderingUS, promotionChangesFilePath, promotionChanges) {\n\tthis.logUserStoryBranchesInfo(userStoryBranchesList, errorInOrderingUS);\n\n\tawait this.setUpDirectory(TARGET_DIRECTORY);\n\tawait this.fetchTargetBranch(targetBranch);\n\tawait this.configureGit(gitEmail, gitName);\n\tawait this.fetchCreatePromotionBranch(promotionBranch, recreatePromotionBranch);\n\tawait this.checkSFDXProjectJson(overriddenApiVersion, API_VERSION);\n\tawait this.promote(userStoryBranchesList, promotionChangesFilePath, promotionBranch, promotionId, repositoryId);\n\tawait this.deduplicateXMLTags(disableXMLDeDuplication, userStoryBranchesList, promotionChanges);\n\n\tawait this.gitPush(tag, promotionBranch);\n}\n\nfunction handleExecutionError(err) {\n\tthis.logger(`Error stack: ${err.stack}`, LOG_LEVEL.ERROR);\n\tif (!(err instanceof CommandExecutionError)) {\n\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, RESULT_INFO.CATEGORY.UNKNOWN_EXCEPTION, 'See logs for more info', err.message);\n\t}\n\texecutionError = err.message || err?.toString() || 'Unknown Error occurred';\n}\n\nasync function finalizeExecution() {\n\tif (resultViewerJson?.length) {\n\t\tawait this.uploadResultViewerJson(resultViewerJson, RESULT_TABLE_COLUMNS, RESULT_TABLE_HEADER, HEADER_ICON);\n\t}\n\tif (executionError) {\n\t\tawait this.executeCommand(this.getErrorCommand(executionError));\n\t}\n\tthis.printMetrics();\n\tif (executionError && !isTest) {\n\t\tprocess.exit(1);\n\t}\n}\n\nasync function getPromotionChanges(fileChangesId, fileName) {\n\tthis.logger('START getting promotion changes');\n\tlet promotionChangesFilePath;\n\tawait this.executeCommand(\n\t\t`copado --downloadfiles ${fileChangesId} --downloaddir ${TEMP_DIRECTORY}/`,\n\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.DOWNLOAD_FILES\n\t);\n\tthis.logger('END getting promotion changes');\n\tif (existsSync(`${TEMP_DIRECTORY}/${fileName}`)) {\n\t\tpromotionChangesFilePath = `${TEMP_DIRECTORY}/${fileName}`;\n\t} else if (existsSync(`${TEMP_DIRECTORY}/${fileName}.json`)) {\n\t\tpromotionChangesFilePath = `${TEMP_DIRECTORY}/${fileName}.json`;\n\t} else {\n\t\tthrow new Error('Error fetching Promotion Changes');\n\t}\n\tconst promotionChanges = this.readFromPath(promotionChangesFilePath);\n\tthis.logger(`promotionChanges: ${JSON.stringify(promotionChanges)}`);\n\treturn { promotionChangesFilePath, promotionChanges };\n}\n\nasync function setUpDirectory(dir) {\n\tthis.logger('Creating repository directory...');\n\n\tconst cmd = `mkdir -p ${dir}`;\n\tawait this.executeCommand(cmd, RESULT_INFO.CATEGORY.FILE_SYSTEM, RESULT_INFO.ADDITIONAL_INFORMATION.SETUP_DIRECTORY);\n\tprocess.chdir(dir);\n\tthis.logger('Repository directory created successfully', LOG_LEVEL.SUCCESS);\n}\n\nasync function fetchTargetBranch(targetBranch) {\n\tthis.logger(`Fetching remote target branch '${targetBranch}' with depth: ${GIT_DEPTH}`);\n\tawait this.executeCommand(\n\t\tthis.getRemoteBranchFetchCommand(targetBranch),\n\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_CHECKOUT\n\t);\n\tthis.logger('Remote target branch fetched successfully', LOG_LEVEL.SUCCESS);\n}\n\nasync function addTargetBranchRefspecAndCheckout(targetBranch, shallowSinceDate) {\n\tthis.logger(`Fetching remote target branch '${targetBranch}' with shallow-since=${shallowSinceDate}`);\n\tconst fetchTargetCmd = `copado-git-get -g \"git remote set-branches --add origin ${targetBranch} && git fetch origin ${targetBranch} --shallow-since=${shallowSinceDate} && git checkout -b ${targetBranch} origin/${targetBranch}\"`;\n\tawait this.executeCommand(fetchTargetCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CHECKOUT);\n\tthis.logger('Remote target branch fetched successfully', LOG_LEVEL.SUCCESS);\n}\n\nasync function fetchCreatePromotionBranch(promotionBranch, recreatePromotionBranch) {\n\tthis.logger('START fetching / creating promotion branch');\n\tlet cmd = '';\n\tif (!promotionBranch) {\n\t\tthrow new Error('Kindly provide a valid promotion branch');\n\t}\n\tif (recreatePromotionBranch === 'true' && (await this.remotePromotionBranchExists(promotionBranch))) {\n\t\tawait this.asyncCopadoLogMessage(`Removing branch ${promotionBranch}`);\n\t\tcmd = `copado-git-get -g \"git push origin --delete ${promotionBranch}\" || exit 1`;\n\t}\n\tawait this.asyncCopadoLogMessage(`Fetching/creating branch ${promotionBranch}`);\n\tcmd += `\n        ${this.fetchCheckoutBranch(promotionBranch, true)}\n    `;\n\n\tawait this.executeCommand(cmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.PROMOTION_BRANCH_CHECKOUT);\n\tthis.logger('END fetching / creating promotion branch');\n}\n\nasync function remotePromotionBranchExists(promotionBranch) {\n\tconst cmd = `git ls-remote --heads origin ${promotionBranch}`;\n\treturn await this.executeCommand(cmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.LIST_REMOTE_REFERENCES);\n}\n\nasync function configureGit(gitEmail, gitName) {\n\tawait this.executeCommand(\n\t\t`\n        git config --local user.email \"${gitEmail}\" || exit 1\n        git config --local user.name \"${gitName}\" || exit 1\n        git config --global diff.renames false || exit 1\n        git config --global merge.renames false || exit 1\n        git config --global status.renames false || exit 1\n        git config --global core.quotePath false\n    `,\n\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_CONFIG\n\t);\n}\n\nasync function promote(userStoryBranches, promotionChangesFilePath, promotionBranch, promotionId, repositoryId) {\n\tthis.logger('START promote operation');\n\tconst featureBranches = userStoryBranches;\n\tawait this.fetchFeatureBranches(featureBranches);\n\tlet gitConflictsResolution = [];\n\tthis.logger('START Merging branches into Promotion branch');\n\tfor (let story of featureBranches) {\n\t\tawait this.checkoutFeatureAndPromotionBranch(story, promotionBranch);\n\t\ttry {\n\t\t\tawait this.mergeFeatureBranchInPromotionBranch(story, promotionBranch);\n\t\t} catch (error) {\n\t\t\twriteFileSync(\n\t\t\t\tGIT_STATUS_FILE_PATH,\n\t\t\t\tawait this.executeCommand(\n\t\t\t\t\t'git status --porcelain=v1',\n\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_STATUS\n\t\t\t\t)\n\t\t\t);\n\t\t\tif (this.hasConflict()) {\n\t\t\t\tawait this.asyncCopadoLogMessage('Resolving conflicts');\n\t\t\t\tgitConflictsResolution.push(\n\t\t\t\t\t...(await this.handleConflicts(promotionChangesFilePath, promotionId, repositoryId, story, promotionBranch))\n\t\t\t\t);\n\t\t\t} else {\n\t\t\t\tthrow new Error(error);\n\t\t\t}\n\t\t}\n\t}\n\tthis.logger('END Merging branches into Promotion branch');\n\tthis.logger('END promote operation');\n\tawait this.uploadGitConflictsResolution(gitConflictsResolution);\n}\n\nasync function fetchFeatureBranches(userStoryBranches) {\n\tthis.logger('START fetch feature branches');\n\tthis.startWatch(RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_FETCH_BRANCHES, processes);\n\tconst chunkSize = GIT_BATCH_SIZE ? parseInt(GIT_BATCH_SIZE) : 10;\n\tif (userStoryBranches.length > 0) {\n\t\tlet index = 0;\n\t\tdo {\n\t\t\tconst endIndex = index + chunkSize > userStoryBranches.length ? userStoryBranches.length : index + chunkSize;\n\t\t\tconst branches = userStoryBranches.slice(index, endIndex);\n\t\t\tawait this.executeCommand(\n\t\t\t\tthis.buildFetchFeatureBranchesCommand(branches),\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_FETCH,\n\t\t\t\ttrue\n\t\t\t);\n\t\t\tindex = endIndex;\n\t\t} while (index < userStoryBranches.length);\n\t}\n\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.GIT_FETCH_BRANCHES, processes);\n\tthis.logger('END fetch feature branches');\n}\n\nasync function checkoutFeatureAndPromotionBranch(userStoryBranch, promotionBranch) {\n\tconst checkoutFeatureAndPromotionBranch = `\n        git checkout \"${userStoryBranch}\" || exit 1\n        git checkout \"${promotionBranch}\"\n    `;\n\tawait this.executeCommand(checkoutFeatureAndPromotionBranch, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CHECKOUT);\n}\n\nasync function mergeFeatureBranchInPromotionBranch(userStoryBranch, promotionBranch) {\n\tconst command = `git merge -m \"Merging ${userStoryBranch} to ${promotionBranch}\" \"${userStoryBranch}\" -Xignore-space-change`;\n\tawait this.executeCommand(command, RESULT_INFO.CATEGORY.GIT_SERVICE, `${RESULT_INFO.ADDITIONAL_INFORMATION.GIT_MERGE} - ${userStoryBranch}`);\n}\n\nasync function handleConflicts(promotionChangesFilePath, promotionId, repositoryId, userStoryBranch, promotionBranch) {\n\tlet output;\n\tlet gitConflictsResolution = [];\n\n\t// Handle environment sync case where userStoryBranch doesn't contain '/'\n\tconst userStoryName = userStoryBranch.includes('/') ? userStoryBranch.split('/')[1] : userStoryBranch;\n\tawait this.resolveConflict(userStoryName, promotionChangesFilePath, promotionId, repositoryId);\n\tif (existsSync(OUTPUT_JSON_PATH)) {\n\t\toutput = JSON.parse(readFileSync(OUTPUT_JSON_PATH, 'utf8'));\n\t\tif (output?.some(file => file.strategy === 'ONLINE_CONFLICT_RESOLUTION')) {\n\t\t\tconst CONFLICT_MESSAGE = `Conflict found while merging ${userStoryBranch} to ${promotionBranch}. Conflict can be resolved manually from the Changes tab of the Promotion.`;\n\t\t\t//reseting the conflicted files to reuse the volume later in the same promotion\n\t\t\tawait this.executeCommand('git reset --hard || true', RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_RESET);\n\t\t\tawait this.executeCommand(\n\t\t\t\t`copado -p '${CONFLICT_MESSAGE}' -r '{\"status\": \"conflicts\"}'`,\n\t\t\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE\n\t\t\t);\n\n\t\t\tthis.populateResultViewer(\n\t\t\t\tRESULT_INFO.LEVEL.ERROR,\n\t\t\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE,\n\t\t\t\tCONFLICT_MESSAGE\n\t\t\t);\n\t\t\tthrow new CommandExecutionError(\n\t\t\t\tCONFLICT_MESSAGE,\n\t\t\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE\n\t\t\t);\n\t\t}\n\t}\n\tawait this.gitCommit(`Merging ${userStoryBranch} to ${promotionBranch} after auto conflict resolution`);\n\tif (output?.length) {\n\t\tgitConflictsResolution.push(...(await this.saveMergeCommitId(output)));\n\t}\n\treturn gitConflictsResolution;\n}\n\nasync function uploadGitConflictsResolution(gitConflictsResolution) {\n\tthis.logger('START Uploading conflict resolution');\n\tif (gitConflictsResolution?.length) {\n\t\tconst conflictResolutionsFilePath = `${TEMP_DIRECTORY}/GitConflictsResolution.json`;\n\t\twriteFileSync(conflictResolutionsFilePath, JSON.stringify(gitConflictsResolution, null, 2));\n\t\tawait this.executeCommand(\n\t\t\t`copado --uploadfile ${conflictResolutionsFilePath}`,\n\t\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.UPLOAD_FILES\n\t\t);\n\t}\n\tthis.logger('END Uploading conflict resolution');\n}\n\nasync function resolveConflict(userStoryName, promotionChangesFilePath, promotionId, repositoryId) {\n\tconst CONFLICTED_CHANGES = `${TEMP_DIRECTORY}/conflictedChanges`;\n\twriteFileSync(CONFLICTED_CHANGES, this.getConflictingFilePaths().join('\\n'), 'utf-8');\n\tconst promotionChanges = JSON.parse(readFileSync(promotionChangesFilePath, 'utf8'));\n\n\t// We encode Vlocity datapacks name to identify retrieved folder names.\n\tthis.updateVlocityChangesFile(promotionChangesFilePath, promotionChanges);\n\n\tawait this.enrichChangeList(promotionChangesFilePath, `${TARGET_DIRECTORY}/`, CONFLICTED_CHANGES, ENRICHED_CHANGE_FILE_PATH);\n\n\t// Escape special characters before writing solvedByUser.json\n\tconst solvedJson = JSON.stringify(conflictResolutionAttachments);\n\tconst escapedSolvedJson = this.escapeSpecialCharacters(solvedJson);\n\n\tawait this.executeCommand(\n\t\t`\n\techo \"${escapedSolvedJson}\" > ${TEMP_DIRECTORY}/solvedByUser.json\n    touch ${OUTPUT_JSON_PATH}`,\n\t\tRESULT_INFO.CATEGORY.FILE_SYSTEM,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.FILE_CREATE\n\t);\n\n\tawait this.executeCommand(\n\t\tthis.getResolveConflictCommand(\n\t\t\tpromotionChangesFilePath,\n\t\t\tGIT_STATUS_FILE_PATH,\n\t\t\tENRICHED_CHANGE_FILE_PATH,\n\t\t\tpromotionId,\n\t\t\trepositoryId,\n\t\t\tuserStoryName,\n\t\t\tdisableSmartConflictResolution\n\t\t),\n\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE\n\t);\n}\n\nasync function enrichChangeList(promotionChanges, targetRepository, conflictedChanges, outputFilePath) {\n\t// here\n\t// Log the content of conflictedChanges file if it exists\n\tif (conflictedChanges && existsSync(conflictedChanges)) {\n\t\tthis.logger('=== ENRICHER CONFLICTED CHANGES FILE CONTENT ===');\n\t\tconst conflictedContent = readFileSync(conflictedChanges, 'utf-8');\n\t\tthis.logger(`Conflicted changes file path: ${conflictedChanges}`);\n\t\tthis.logger(`Conflicted changes file content:`);\n\t\tthis.logger(conflictedContent);\n\t\tthis.logger('=== END ENRICHER CONFLICTED CHANGES FILE CONTENT ===');\n\t} else {\n\t\tthis.logger('No conflicted changes file found or file does not exist');\n\t}\n\n\tawait this.executeCommand(\n\t\t`enricher -p '${promotionChanges}' --repo ${targetRepository} ${conflictedChanges ? '--changefile ' + conflictedChanges : ''} ${\n\t\t\toutputFilePath ? '--out ' + outputFilePath : ''\n\t\t} --quick true`,\n\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.ENRICHER_SERVICE\n\t);\n}\n\nasync function gitCommit(commitMessage) {\n\tawait this.executeCommand(\n\t\t`\n        git add . # add all the resolved changes, if any \n        git commit -am \"${commitMessage}\" || true`,\n\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_ADD\n\t);\n}\n\nasync function saveMergeCommitId(output) {\n\tconst cmd = 'git rev-parse HEAD';\n\tconst mergeCommitId = (\n\t\tawait this.executeCommand(cmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_FIND_COMMIT_ID)\n\t)?.trim();\n\toutput.map(file => (file.sucessfulPromotion = mergeCommitId));\n\treturn output;\n}\n\nasync function gitPush(tag, promotionBranch) {\n\tthis.logger('START push promotion branch');\n\tconst escapedTag = tag ? this.escapeSpecialCharacters(tag).replace(/[|]/g, `'\\\\|'`) : null;\n\n\t// Get the appropriate push command\n\tconst pushCommand = await this.getPushCommand(promotionBranch);\n\n\tconst cmd = escapedTag\n\t\t? `git tag '${escapedTag}' || exit 1\n\t            copado-git-get -g \"git push --all\"`\n\t\t: `echo 'No tag specified'\n\t            copado-git-get -g \"${pushCommand}\"`;\n\tawait this.asyncCopadoLogMessage('Pushing all changes');\n\tawait this.executeCommand(cmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_PUSH);\n\tthis.logger('END push promotion branch');\n}\n\nasync function checkSFDXProjectJson(overriddenApiVersion, apiVersion) {\n\tconst SOURCE_API_VERSION = await this.getApiVersion(overriddenApiVersion, apiVersion);\n\tconst sfdxProjectJsonPath = `${TARGET_DIRECTORY}/sfdx-project.json`;\n\tif (existsSync(sfdxProjectJsonPath)) {\n\t\tlet fileContent = JSON.parse(readFileSync(sfdxProjectJsonPath, { encoding: 'utf8' }));\n\t\tif (fileContent.sourceApiVersion !== SOURCE_API_VERSION) {\n\t\t\tconst commitMessage = `Updated  sourceApiVersion from ${fileContent.sourceApiVersion} to ${SOURCE_API_VERSION} in sfdx-project.json to align the commit, promote and deploy operations with the latest supported api version of Copado.`;\n\t\t\tfileContent.sourceApiVersion = SOURCE_API_VERSION;\n\t\t\twriteFileSync(sfdxProjectJsonPath, JSON.stringify(fileContent, null, 2));\n\t\t\tawait this.gitCommit(commitMessage);\n\t\t}\n\t} else {\n\t\tthrow new Error(\n\t\t\t'Invalid configuration. sfdx-project.json is invalid or missing at project root. Copado Commit and Deploy operations are required to run from within a valid sfdx project.'\n\t\t);\n\t}\n}\n\nasync function deduplicateXMLTags(disableXMLDeDuplication, userStoryBranches, promotionChanges) {\n\tconst layoutsInPromotion = this.getLayoutsWithAddOrFullActionInPromotion(promotionChanges);\n\tif (disableXMLDeDuplication?.toLowerCase() == 'true' || layoutsInPromotion?.length == 0) {\n\t\treturn;\n\t}\n\n\tawait this.asyncCopadoLogMessage('Deduplicating XML tags');\n\n\tconst layoutsInPromotionChanges = `${TEMP_DIRECTORY}/LayoutsInPromotionChanges.json`;\n\twriteFileSync(layoutsInPromotionChanges, JSON.stringify(layoutsInPromotion));\n\n\tawait this.enrichChangeList(layoutsInPromotionChanges, `${TARGET_DIRECTORY}/`);\n\tawait this.executeCommand(\n\t\tthis.getDeduplicateXMLCommand(layoutsInPromotionChanges, userStoryBranches),\n\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE\n\t);\n\n\tawait this.gitCommit('Copado De-duplication of XML tags');\n}\n\nasync function createEnvironmentSyncPromotionBranch(branchName, commitRef) {\n\tthis.logger(`Creating new branch '${branchName}' from commit: ${commitRef}`);\n\n\ttry {\n\t\t// Verify the commit exists - handle special characters in commit references\n\t\tlet verifyCommand;\n\n\t\tconst isParentReference = commitRef.includes('^');\n\n\t\tif (isParentReference) {\n\t\t\t// For references with caret (^), use rev-parse with error suppression\n\t\t\tverifyCommand = `git rev-parse --verify \"${commitRef}\" 2>/dev/null || echo \"\"`;\n\t\t} else {\n\t\t\t// For normal commit hashes, use cat-file\n\t\t\tverifyCommand = `git cat-file -e \"${commitRef}^{commit}\" 2>/dev/null || echo \"\"`;\n\t\t}\n\n\t\tconst verifyOutput = await this.executeCommand(\n\t\t\tverifyCommand,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_CHECKOUT\n\t\t);\n\n\t\t// If verification failed, try to resolve the commit reference\n\t\tconst isCommitNotFound = !verifyOutput.trim();\n\n\t\tif (isCommitNotFound && isParentReference) {\n\t\t\tthis.logger(`Could not verify commit reference ${commitRef} directly, attempting to resolve it...`, LOG_LEVEL.WARN);\n\n\t\t\t// Extract the commit hash without the caret\n\t\t\tconst baseCommit = commitRef.split('^')[0];\n\t\t\tconst resolveCmd = `git rev-parse --verify \"${baseCommit}\" 2>/dev/null || echo \"\"`;\n\t\t\tconst resolveOutput = await this.executeCommand(resolveCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Resolve base commit');\n\n\t\t\tif (!resolveOutput.trim()) {\n\t\t\t\tthrow new Error(`Could not resolve base commit ${baseCommit}`);\n\t\t\t}\n\n\t\t\t// Try to get the parent commit\n\t\t\tconst parentCmd = `git rev-parse \"${baseCommit}^\" 2>/dev/null || echo \"\"`;\n\t\t\tconst parentOutput = await this.executeCommand(parentCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Get parent commit');\n\n\t\t\tif (!parentOutput.trim()) {\n\t\t\t\tthrow new Error(`Could not find parent of commit ${baseCommit}`);\n\t\t\t}\n\n\t\t\t// Use the parent commit instead of the original reference\n\t\t\tcommitRef = parentOutput.trim();\n\t\t\tthis.logger(`Resolved commit reference to ${commitRef}`);\n\t\t} else if (isCommitNotFound && !isParentReference) {\n\t\t\t// For non-parent references, log a warning but proceed anyway\n\t\t\tthis.logger(`Could not verify commit reference ${commitRef}, but proceeding with branch creation...`, LOG_LEVEL.WARN);\n\t\t}\n\n\t\t// Create the branch from the commit\n\t\tawait this.executeCommand(\n\t\t\t`git checkout -b \"${branchName}\" \"${commitRef}\"`,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_CHECKOUT\n\t\t);\n\t\treturn branchName;\n\t} catch (error) {\n\t\tthrow new Error(`Failed to create branch '${branchName}' from commit '${commitRef}': ${error.message}`);\n\t}\n}\n\nasync function configureSFDXCLI(sourceApiVersion, destinationInstanceUrl) {\n\tconst baseUrl = this.getInstanceUrl(destinationInstanceUrl);\n\tlet configSet = `\n\tSF_ACCESS_TOKEN=${destinationSessionid} sf org login access-token --instance-url ${baseUrl} --set-default --no-prompt || exit 1\n \tsf config set org-api-version=${sourceApiVersion}`;\n\n\tawait this.executeCommand(configSet, RESULT_INFO.CATEGORY.SFDX_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.SFDX_CONFIG);\n}\n\nasync function disableSourceTracking() {\n\tconst command = `sf org disable tracking`;\n\tawait this.executeCommand(command);\n}\n\nfunction getInstanceUrl(instanceUrl) {\n\treturn instanceUrl?.substring(0, instanceUrl?.indexOf('/', instanceUrl?.indexOf('/') + 2));\n}\n\nasync function handleEnvironmentSyncConflicts() {\n\tthis.logger('\\n--- Handling Environment Sync Conflicts ---');\n\n\t// For environment sync, we need to create a minimal promotion changes file\n\t// since we don't have the full promotion changes like in regular promotion\n\tconst envSyncPromotionChanges = await this.createEnvironmentSyncPromotionChanges();\n\tconst promotionChangesFilePath = `${TEMP_DIRECTORY}/envSyncPromotionChanges.json`;\n\twriteFileSync(promotionChangesFilePath, JSON.stringify(envSyncPromotionChanges, null, 2));\n\n\ttry {\n\t\t// Use the same conflict resolution strategy as regular promotion\n\t\tawait this.resolveConflict(LOG_MESSAGES.ENVIRONMENT_SYNC, promotionChangesFilePath, promotionId, repositoryId);\n\n\t\tif (existsSync(OUTPUT_JSON_PATH)) {\n\t\t\tconst output = JSON.parse(readFileSync(OUTPUT_JSON_PATH, 'utf8'));\n\t\t\tif (output?.some(file => file.strategy === 'ONLINE_CONFLICT_RESOLUTION')) {\n\t\t\t\tconst CONFLICT_MESSAGE = `Conflict found while merging environment sync changes. Conflict needs to be resolved manually.`;\n\n\t\t\t\t// Reset conflicted files to reuse the volume later\n\t\t\t\tawait this.executeCommand('git reset --hard || true', RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_RESET);\n\t\t\t\tawait this.executeCommand(\n\t\t\t\t\t`copado -p '${CONFLICT_MESSAGE}' -r '{\"status\": \"conflicts\"}'`,\n\t\t\t\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE\n\t\t\t\t);\n\n\t\t\t\tthis.populateResultViewer(\n\t\t\t\t\tRESULT_INFO.LEVEL.ERROR,\n\t\t\t\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE,\n\t\t\t\t\tCONFLICT_MESSAGE\n\t\t\t\t);\n\t\t\t\tthrow new CommandExecutionError(\n\t\t\t\t\tCONFLICT_MESSAGE,\n\t\t\t\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE\n\t\t\t\t);\n\t\t\t}\n\t\t}\n\n\t\t// Auto-resolution successful - commit the changes\n\t\tawait this.gitCommit(`Merging environment sync changes after auto conflict resolution`);\n\t\tthis.logger(' Environment sync conflicts resolved automatically');\n\t} catch (error) {\n\t\tif (error instanceof CommandExecutionError) {\n\t\t\tthrow error; // Re-throw manual resolution errors\n\t\t}\n\t\tthis.logger(`Error resolving environment sync conflicts: ${error.message}`, LOG_LEVEL.ERROR);\n\t\tthrow error;\n\t}\n}\n\n/**\n * Handles environment sync merge conflicts by surfacing the conflict and requiring manual resolution by the user.\n * Does NOT use createEnvironmentSyncPromotionChanges or regular promotion conflict resolution strategy.\n */\nasync function handleManualEnvironmentSyncConflicts() {\n\tthis.logger('\\n--- Handling Environment Sync Conflicts (Manual Resolution Required) ---');\n\t// If solvedByUser.json exists and is non-empty, process the user resolutions\n\tif (existsSync(`${TEMP_DIRECTORY}/solvedByUser.json`)) {\n\t\tconst solvedByUserContent = readFileSync(`${TEMP_DIRECTORY}/solvedByUser.json`, 'utf8');\n\t\ttry {\n\t\t\tconst solvedByUser = JSON.parse(solvedByUserContent);\n\t\t\tif (Array.isArray(solvedByUser) && solvedByUser.length > 0) {\n\t\t\t\tthis.logger('Detected user-resolved conflicts in solvedByUser.json. Applying resolutions...');\n\t\t\t\t// Proceed with the merge/commit logic using the resolved changes\n\t\t\t\tconst envSyncPromotionChanges = await this.createEnvironmentSyncPromotionChanges();\n\t\t\t\tconst promotionChangesFilePath = `${TEMP_DIRECTORY}/envSyncPromotionChanges.json`;\n\t\t\t\twriteFileSync(promotionChangesFilePath, JSON.stringify(envSyncPromotionChanges, null, 2));\n\n\t\t\t\tlet gitConflictsResolution = [];\n\t\t\t\ttry {\n\t\t\t\t\tgitConflictsResolution = await this.handleConflicts(\n\t\t\t\t\t\tpromotionChangesFilePath,\n\t\t\t\t\t\tpromotionId,\n\t\t\t\t\t\trepositoryId,\n\t\t\t\t\t\tLOG_MESSAGES.ENVIRONMENT_SYNC,\n\t\t\t\t\t\tpromotionBranch\n\t\t\t\t\t);\n\n\t\t\t\t\tif (gitConflictsResolution?.length) {\n\t\t\t\t\t\tthis.logger(`Successfully resolved ${gitConflictsResolution.length} conflicts (from user resolution)`);\n\t\t\t\t\t}\n\t\t\t\t} catch (error) {\n\t\t\t\t\tthrow new Error(`Error during conflict handling after user resolution: ${error.message}`);\n\t\t\t\t}\n\n\t\t\t\tawait this.uploadGitConflictsResolution(gitConflictsResolution);\n\t\t\t\treturn; // Resume process\n\t\t\t}\n\t\t} catch (e) {\n\t\t\tthis.logger('Could not parse solvedByUser.json: ' + e.message, LOG_LEVEL.ERROR);\n\t\t\t// Fall through to manual resolution logic\n\t\t}\n\t}\n\n\t// If not resolved by user, proceed with manual resolution logic\n\t// Create a minimal promotion changes file\n\tconst envSyncPromotionChanges = await this.createEnvironmentSyncPromotionChanges();\n\tconst promotionChangesFilePath = `${TEMP_DIRECTORY}/envSyncPromotionChanges.json`;\n\twriteFileSync(promotionChangesFilePath, JSON.stringify(envSyncPromotionChanges, null, 2));\n\n\t// Get conflicted files from git_status.txt\n\tlet conflictedFiles = [];\n\ttry {\n\t\tconflictedFiles = this.getConflictingFilePaths();\n\t} catch (e) {\n\t\tthis.logger('Could not determine conflicting files: ' + e.message, LOG_LEVEL.ERROR);\n\t}\n\n\t// Write output.json with ONLINE_CONFLICT_RESOLUTION for each conflicted file\n\tconst outputJson = conflictedFiles.length\n\t\t? conflictedFiles.map(file => ({\n\t\t\t\tconflictedPath: file,\n\t\t\t\tstrategy: 'ONLINE_CONFLICT_RESOLUTION',\n\t\t\t\tsucessfulPromotion: null // Will be populated after successful resolution\n\t\t  }))\n\t\t: [\n\t\t\t\t{\n\t\t\t\t\tconflictedPath: 'EnvironmentSync',\n\t\t\t\t\tstrategy: 'ONLINE_CONFLICT_RESOLUTION',\n\t\t\t\t\tsucessfulPromotion: null\n\t\t\t\t}\n\t\t  ];\n\twriteFileSync(OUTPUT_JSON_PATH, JSON.stringify(outputJson, null, 2));\n\n\t// Upload the conflict file for UI/manual resolution\n\tawait this.uploadGitConflictsResolution(outputJson);\n\n\t// Throw error to stop execution and surface manual resolution required\n\tconst CONFLICT_MESSAGE = `Manual conflict resolution required for Environment Sync. Please resolve conflicts in the UI and re-run the process.`;\n\tthis.populateResultViewer(\n\t\tRESULT_INFO.LEVEL.ERROR,\n\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE,\n\t\tCONFLICT_MESSAGE\n\t);\n\tthrow new CommandExecutionError(\n\t\tCONFLICT_MESSAGE,\n\t\tRESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.COPADO_MERGE\n\t);\n}\n\nfunction isEnvironmentSync() {\n\tif (promotionMethod == ENVIRONMENT_SYNC_CONFIG.PROMOTION_METHOD) {\n\t\tenvSyncSourceBranch = this.getEnvSyncSourceBranch();\n\n\t\tthis.logger('\\n=== Starting Environment Sync Flow ===');\n\t\tthis.logger(`Source Branch: ${envSyncSourceBranch}`);\n\t\tthis.logger(`Target Branch: ${targetBranch}`);\n\t\treturn true;\n\t}\n\treturn false;\n}\n\nfunction checkPrefetchedVolume() {\n\thasPrefetchedVolume = existsSync(TARGET_DIRECTORY);\n\tthis.logger(`hasPrefetchedVolume: ${hasPrefetchedVolume}`);\n}\n\nasync function executeEnvironmentSyncFlow(userStoryBranchesList, promotionChanges, shallowSinceDate) {\n\tthis.logger(`User stories ordered by commit sequence (from oldest to newest): ${userStoryBranchesList}`);\n\n\ttry {\n\t\tawait this.asyncCopadoLogMessage(LOG_MESSAGES.ENV_SYNC_START);\n\n\t\tawait this.setupEnvironmentSyncEnvironment(shallowSinceDate);\n\n\t\tawait this.createAndMergeEnvironmentSyncBranches(userStoryBranchesList, promotionChanges);\n\n\t\tawait this.createPromotionBranch();\n\n\t\tawait this.configureAndPushChanges();\n\n\t\tawait this.asyncCopadoLogMessage(LOG_MESSAGES.ENV_SYNC_COMPLETE);\n\t} catch (error) {\n\t\tthrow new Error(`Environment sync failed: ${error.message}`);\n\t}\n}\n\nasync function setupEnvironmentSyncEnvironment(shallowSinceDate) {\n\tawait this.setUpDirectory(TARGET_DIRECTORY);\n\tawait this.cloneShallowRepository(shallowSinceDate);\n}\n\nasync function createAndMergeEnvironmentSyncBranches(userStoryBranchesList, promotionChanges) {\n\tconst { initialCommit, finalCommit } = await this.findInitialAndFinalMergeCommits(userStoryBranchesList);\n\n\tconst verifyCommits = async () => {\n\t\tthis.logger(`Verifying if initial and final commit exist in the branch '${envSyncSourceBranch}'...`);\n\n\t\tawait this.executeCommand(\n\t\t\t`git rev-parse --verify \"${initialCommit}\"`,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t`Verify initial commit ${initialCommit} exists`\n\t\t);\n\t\tawait this.executeCommand(\n\t\t\t`git rev-parse --verify \"${finalCommit}\"`,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t`Verify final commit ${finalCommit} exists`\n\t\t);\n\n\t\tthis.logger('Commits verified successfully', LOG_LEVEL.SUCCESS);\n\t};\n\n\tconst createPreChangesBranch = async () => {\n\t\tthis.logger('Creating branch from initial commit...');\n\t\t// --- Creating pre-change Branch ---\n\t\tlet preChangeBranchCreated = false;\n\t\tlet preChangeBranchCommit = null;\n\t\ttry {\n\t\t\t// Check if the commit has a parent (not the first commit in the repository)\n\t\t\tconst hasParentCmd = `git rev-parse --verify \"${initialCommit}^\" 2>/dev/null || echo \"\"`;\n\t\t\tconst hasParentOutput = await this.executeCommand(hasParentCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Check if commit has parent');\n\t\t\tconst hasParentCommit = hasParentOutput.trim();\n\n\t\t\tif (hasParentCommit) {\n\t\t\t\t// Get the parent commit hash directly instead of using the caret notation\n\t\t\t\tconst parentCommitCmd = `git rev-parse \"${initialCommit}^\"`;\n\t\t\t\tconst parentCommitOutput = await this.executeCommand(parentCommitCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Get parent commit hash');\n\t\t\t\tpreChangeBranchCommit = parentCommitOutput.trim();\n\t\t\t\tthis.logger(`Using parent commit ${preChangeBranchCommit} for pre-change branch`);\n\t\t\t} else {\n\t\t\t\tpreChangeBranchCommit = initialCommit;\n\t\t\t\tthis.logger(`Initial commit ${initialCommit} has no parent, using it directly for pre-change branch`, LOG_LEVEL.WARN);\n\t\t\t}\n\n\t\t\t// Always delete the branch if it exists before creating\n\t\t\tconst branchExistsOutput = await this.executeCommand(\n\t\t\t\t`git branch --list ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH}`,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t`Check if ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH} exists`\n\t\t\t);\n\t\t\tconst branchExists = branchExistsOutput.trim();\n\t\t\tif (branchExists) {\n\t\t\t\tthis.logger(`Branch ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH} already exists. Deleting it first.`, LOG_LEVEL.WARN);\n\t\t\t\tawait this.executeCommand(\n\t\t\t\t\t`git branch -D ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH}`,\n\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\t`Delete existing ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH}`\n\t\t\t\t);\n\t\t\t}\n\n\t\t\t// Now create the branch once\n\t\t\tawait this.createEnvironmentSyncPromotionBranch(ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH, preChangeBranchCommit);\n\t\t\tpreChangeBranchCreated = true;\n\n\t\t\tthis.logger('pre-change branch created');\n\t\t} catch (error) {\n\t\t\tthis.logger(`Error creating pre-change branch: ${error.message}`, LOG_LEVEL.ERROR);\n\t\t\t// Only try fallback if branch was not created\n\t\t\tif (!preChangeBranchCreated) {\n\t\t\t\tthis.logger('Attempting to create pre-change branch using first commit on branch...');\n\t\t\t\tconst firstCommitCmd = 'git log --oneline --reverse | head -1';\n\t\t\t\tconst firstCommitOutput = await this.executeCommand(firstCommitCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Find first commit on branch');\n\t\t\t\tconst firstCommit = firstCommitOutput.trim().split(' ')[0];\n\n\t\t\t\t// Delete branch if it exists\n\t\t\t\tconst branchExistsOutput = await this.executeCommand(\n\t\t\t\t\t`git branch --list ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH}`,\n\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\t`Check if ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH} exists (fallback)`\n\t\t\t\t);\n\t\t\t\tconst branchExists = branchExistsOutput.trim();\n\t\t\t\tif (branchExists) {\n\t\t\t\t\tthis.logger(`Branch ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH} already exists (fallback). Deleting it first.`, LOG_LEVEL.WARN);\n\t\t\t\t\tawait this.executeCommand(\n\t\t\t\t\t\t`git branch -D ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH}`,\n\t\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\t\t`Delete existing ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH} (fallback)`\n\t\t\t\t\t);\n\t\t\t\t}\n\n\t\t\t\tawait this.createEnvironmentSyncPromotionBranch(ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH, firstCommit);\n\t\t\t}\n\t\t}\n\n\t\tthis.logger('Branch created from initial commit successfully', LOG_LEVEL.SUCCESS);\n\t};\n\n\tconst addWorkInProgressFiles = async () => {\n\t\t// --- Adding WIP files ---\n\t\tthis.logger(`Checking System Property \"Env_Sync_Back_Promote_Override_Destination_Changes\" in target environment '${targetBranch}'...`);\n\t\tconst override = overrideDestinationChanges ? overrideDestinationChanges.toLowerCase() === 'true' : false;\n\t\tthis.logger(`Override destination org: ${override}`);\n\n\t\tif (override) {\n\t\t\tthis.logger('Override enabled. Skipping WIP files in the target org.', LOG_LEVEL.WARN);\n\t\t} else {\n\t\t\tthis.logger('Override disabled. Adding Work In Progress (WIP) files from the target org; conflicts may arise.', LOG_LEVEL.WARN);\n\t\t\tawait this.addWIPDiffToPreChangeBranch(ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH, promotionChanges);\n\t\t}\n\t};\n\n\tconst createPostChangesBranch = async () => {\n\t\t// --- Creating post-change Branch ---\n\t\ttry {\n\t\t\t// Verify the final commit exists\n\t\t\tconst verifyFinalCmd = `git rev-parse --verify \"${finalCommit}\" 2>/dev/null || echo \"\"`;\n\t\t\tconst verifyFinalOutput = await this.executeCommand(\n\t\t\t\tverifyFinalCmd,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t`Verify final commit ${finalCommit} exists`\n\t\t\t);\n\n\t\t\tconst isFinalCommitNotFound = !verifyFinalOutput.trim();\n\t\t\tif (isFinalCommitNotFound) {\n\t\t\t\tthrow new Error(`Could not verify final commit ${finalCommit}`);\n\t\t\t}\n\n\t\t\t// Always delete the branch if it exists before creating\n\t\t\tconst branchExistsOutput = await this.executeCommand(\n\t\t\t\t`git branch --list ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH}`,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t`Check if ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH} exists`\n\t\t\t);\n\t\t\tconst branchExists = branchExistsOutput.trim();\n\t\t\tif (branchExists) {\n\t\t\t\tthis.logger(`Branch ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH} already exists. Deleting it first.`);\n\t\t\t\tawait this.executeCommand(\n\t\t\t\t\t`git branch -D ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH}`,\n\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\t`Delete existing ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH}`\n\t\t\t\t);\n\t\t\t}\n\n\t\t\tawait this.createEnvironmentSyncPromotionBranch(ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH, finalCommit);\n\t\t\tthis.logger('post-change branch created');\n\t\t} catch (error) {\n\t\t\tthis.logger(`Error creating post-change branch: ${error.message}`, LOG_LEVEL.ERROR);\n\t\t\tthis.logger('Attempting to create post-change branch using last commit on branch...');\n\n\t\t\t// Fallback: use the last commit on the branch\n\t\t\tconst lastCommitCmd = 'git log --oneline -n 1';\n\t\t\tconst lastCommitOutput = await this.executeCommand(lastCommitCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Find last commit on branch');\n\t\t\tconst lastCommit = lastCommitOutput.trim().split(' ')[0];\n\n\t\t\t// Delete branch if it exists\n\t\t\tconst branchExistsOutput = await this.executeCommand(\n\t\t\t\t`git branch --list ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH}`,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t`Check if ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH} exists (fallback)`\n\t\t\t);\n\t\t\tconst branchExists = branchExistsOutput.trim();\n\t\t\tif (branchExists) {\n\t\t\t\tthis.logger(`Branch ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH} already exists (fallback). Deleting it first.`, LOG_LEVEL.WARN);\n\t\t\t\tawait this.executeCommand(\n\t\t\t\t\t`git branch -D ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH}`,\n\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\t`Delete existing ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH} (fallback)`\n\t\t\t\t);\n\t\t\t}\n\n\t\t\tawait this.createEnvironmentSyncPromotionBranch(ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH, lastCommit);\n\t\t\tthis.logger('post-change branch created (using fallback method)');\n\t\t}\n\t};\n\n\tconst mergePostChangesBranchIntoPreChangesBranch = async () => {\n\t\t// Merge post-change into pre-change branch\n\t\ttry {\n\t\t\t// Checkout pre-change branch\n\t\t\tawait this.executeCommand(\n\t\t\t\t`git checkout ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH}`,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t'Checkout pre-change branch for merge'\n\t\t\t);\n\n\t\t\t// Merge post-change branch into pre-change branch\n\t\t\tawait this.executeCommand(\n\t\t\t\t`git merge ${ENVIRONMENT_SYNC_CONFIG.POST_CHANGE_BRANCH}`,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_MERGE\n\t\t\t);\n\n\t\t\tthis.logger('Branches merged successfully');\n\t\t} catch (error) {\n\t\t\t// Always write git status before handling conflicts\n\t\t\tconst gitStatus = await this.executeCommand(\n\t\t\t\t'git status --porcelain=v1',\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_STATUS\n\t\t\t);\n\t\t\twriteFileSync(GIT_STATUS_FILE_PATH, gitStatus);\n\t\t\tif (this.hasConflict()) {\n\t\t\t\tawait this.asyncCopadoLogMessage(LOG_MESSAGES.CONFLICT_RESOLUTION);\n\t\t\t\tlet gitConflictsResolution = [];\n\n\t\t\t\ttry {\n\t\t\t\t\t// Try automatic resolution first (same as normal promotion flow)\n\t\t\t\t\tlet envSyncPromotionChanges = await this.createEnvironmentSyncPromotionChanges();\n\t\t\t\t\tconst promotionChangesFilePath = `${TEMP_DIRECTORY}/envSyncPromotionChanges.json`;\n\t\t\t\t\twriteFileSync(promotionChangesFilePath, JSON.stringify(envSyncPromotionChanges, null, 2));\n\n\t\t\t\t\tgitConflictsResolution = await this.handleConflicts(\n\t\t\t\t\t\tpromotionChangesFilePath,\n\t\t\t\t\t\tpromotionId,\n\t\t\t\t\t\trepositoryId,\n\t\t\t\t\t\tLOG_MESSAGES.ENVIRONMENT_SYNC,\n\t\t\t\t\t\tENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH\n\t\t\t\t\t);\n\n\t\t\t\t\tthis.logger('Environment sync conflicts resolved automatically');\n\n\t\t\t\t\t// Upload resolution results for successful automatic resolution\n\t\t\t\t\tif (gitConflictsResolution?.length) {\n\t\t\t\t\t\tawait this.uploadGitConflictsResolution(gitConflictsResolution);\n\t\t\t\t\t}\n\t\t\t\t} catch (conflictError) {\n\t\t\t\t\t// If automatic resolution fails, fall back to manual resolution\n\t\t\t\t\tthis.logger('Automatic resolution failed, falling back to manual resolution');\n\t\t\t\t\tawait this.handleManualEnvironmentSyncConflicts(conflictError);\n\t\t\t\t\t// Note: uploadGitConflictsResolution is called inside handleManualEnvironmentSyncConflicts\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tthrow new Error(`Merge failed: ${error.message}`);\n\t\t\t}\n\t\t}\n\t};\n\n\tawait verifyCommits();\n\n\tawait createPreChangesBranch();\n\n\tawait addWorkInProgressFiles();\n\n\tawait createPostChangesBranch();\n\n\tawait mergePostChangesBranchIntoPreChangesBranch();\n}\n\nasync function createEnvironmentSyncBranch(branchName, commitHash, description) {\n\tthis.logger(`Creating ${description} branch from ${commitHash}...`);\n\n\tawait this.createEnvironmentSyncPromotionBranch(branchName, commitHash);\n\n\tthis.logger(`${description} branch created successfully`);\n}\n\nasync function createPromotionBranch() {\n\tthis.logger('Setting up promotion branch...');\n\n\tthis.logger(`Checking out destination branch '${targetBranch}' to create promotion branch from it`);\n\tawait this.executeCommand(`git checkout ${targetBranch}`, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Checkout destination branch as base for promotion');\n\n\tawait this.fetchCreatePromotionBranch(promotionBranch, recreatePromotionBranch);\n\tthis.logger(`Promotion branch '${promotionBranch}' ready (created from destination branch '${targetBranch}')`);\n\n\tawait this.applyEnvironmentSyncChangesToPromotion();\n}\n\nasync function applyEnvironmentSyncChangesToPromotion() {\n\tthis.logger('Applying environment sync changes to promotion branch...');\n\n\ttry {\n\t\t// Shallow clones may exclude the common ancestor between source and target branches,\n\t\t// so --allow-unrelated-histories is always included to prevent refused merges.\n\t\t// -X theirs resolves conflicts by taking envsync_prechanges.\n\t\tawait this.executeCommand(\n\t\t\t`git merge ${ENVIRONMENT_SYNC_CONFIG.PRE_CHANGE_BRANCH} -X theirs --allow-unrelated-histories`,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_MERGE\n\t\t);\n\n\t\tthis.logger('Environment Sync completed - original commits preserved', LOG_LEVEL.SUCCESS);\n\t} catch (error) {\n\t\tawait this.handleMergeConflicts(error);\n\t}\n}\n\nasync function handleMergeConflicts(originalError) {\n\tthis.logger('Merge conflicts detected, attempting resolution...');\n\n\tconst gitStatus = await this.executeCommand(\n\t\t'git status --porcelain=v1',\n\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_STATUS\n\t);\n\n\twriteFileSync(GIT_STATUS_FILE_PATH, gitStatus);\n\n\tif (this.hasConflict()) {\n\t\tawait this.asyncCopadoLogMessage(LOG_MESSAGES.CONFLICT_RESOLUTION);\n\t\tawait this.handleEnvironmentSyncConflicts();\n\t\tthis.logger('Conflicts resolved successfully');\n\t} else {\n\t\tthrow new Error(`Merge failed: ${originalError.message}`);\n\t}\n}\n\nasync function configureAndPushChanges() {\n\tthis.logger('Configuring deployment environment...');\n\n\t// Run configuration tasks in sequence\n\tawait this.configureGit(gitEmail, gitName);\n\tawait this.checkSFDXProjectJson(overriddenApiVersion, API_VERSION);\n\tawait this.configureSFDXCLI(API_VERSION, destinationInstanceUrl);\n\n\tthis.logger('Configuration completed, pushing changes...');\n\n\tawait this.gitPush(tag, promotionBranch);\n\n\tthis.logger('Environment Sync Flow Completed Successfully');\n}\n\nasync function getPushCommand(promotionBranch) {\n\t// For Environment Sync, the promotion branch is rebuilt from scratch each time,\n\t// so it may diverge from the remote. Use --force to overwrite the remote branch.\n\tif (this.isEnvironmentSync()) {\n\t\tthis.logger('Environment Sync: Using force push to overwrite remote promotion branch', LOG_LEVEL.WARN);\n\t\treturn `git push --force origin ${promotionBranch}`;\n\t}\n\treturn `git push origin ${promotionBranch}`;\n}\n\nasync function createEnvironmentSyncPromotionChanges() {\n\tconst conflictedFiles = this.getConflictingFilePaths();\n\n\tconst conflictedChangesFile = `${TEMP_DIRECTORY}/conflictedChanges`;\n\twriteFileSync(conflictedChangesFile, conflictedFiles.join('\\n'), 'utf-8');\n\n\tconst tempFile = `${TEMP_DIRECTORY}/env_sync_changes.json`;\n\twriteFileSync(tempFile, JSON.stringify([]));\n\n\tawait this.enrichChangeList(tempFile, TARGET_DIRECTORY, conflictedChangesFile);\n\n\tlet enrichedChanges = JSON.parse(readFileSync(tempFile));\n\n\tenrichedChanges = enrichedChanges.map(item => ({ ...item, a: ACTIONS.ADD }));\n\n\treturn enrichedChanges;\n}\n\nasync function findInitialAndFinalMergeCommits(userStoryBranches) {\n\tthis.logger('Finding merge commits from initial and final User Story commits...');\n\n\t// Finds initial and final commits on the *current* clone of sourceBranch.\n\t// This function itself does not perform any retries or deepening.\n\tconst findCommitsOnCurrentClone = async () => {\n\t\tawait this.executeCommand(\n\t\t\t`git checkout -B \"${envSyncSourceBranch}\" \"origin/${envSyncSourceBranch}\"`,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t'Checkout source branch'\n\t\t);\n\n\t\tconst getFastForwardCommit = async (branch, isInitialBranch = false) => {\n\t\t\tthis.logger(`Couldn't find merge commit for ${branch} on current branch, checking if it is fast forward`, LOG_LEVEL.WARN);\n\n\t\t\t// Try to find fast-forward merges using --decorate to show branch references\n\t\t\t// This is better for detecting remote branches like origin/feature/branch-name\n\t\t\tconst onlyBranchName = branch.replace('feature/', '');\n\t\t\tconst fastForwardCmd = `git log --decorate --oneline --first-parent HEAD | grep '${onlyBranchName}' | head -1`;\n\t\t\tconst fastForwardOutput = await this.executeCommand(\n\t\t\t\tfastForwardCmd,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t`Check for fast-forward merge of ${branch} with decoration`\n\t\t\t);\n\n\t\t\tconst fastForwardLine = fastForwardOutput.trim();\n\t\t\tif (!fastForwardLine) {\n\t\t\t\t// If still not found, try a more general search without --first-parent\n\t\t\t\tconst branchCommitFallbackCmd = `git log --decorate --oneline HEAD | grep '${branch}' | ${isInitialBranch ? 'tail -1' : 'head -1'}`;\n\t\t\t\tconst generalOutput = await this.executeCommand(\n\t\t\t\t\tbranchCommitFallbackCmd,\n\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\t`General search for ${branch} in commit messages`\n\t\t\t\t);\n\n\t\t\t\tconst generalCommitFound = generalOutput.trim();\n\t\t\t\tif (!generalCommitFound) {\n\t\t\t\t\tthrow new Error(`No commit found for feature branch: ${branch} on current branch`);\n\t\t\t\t}\n\n\t\t\t\tconst commitHash = generalCommitFound.split(' ')[0];\n\t\t\t\tthis.logger(`Found potential commit for ${branch} in commit messages: ${commitHash}`);\n\n\t\t\t\t// Find the commit on envSyncSourceBranch that contains the potential commit as a parent/ancestor.\n\t\t\t\t// The potential commit may live on a promotion branch that was merged into envSyncSourceBranch,\n\t\t\t\t// so we walk the ancestry path to find the merge commit on envSyncSourceBranch that brought it in.\n\t\t\t\tconst ancestryCmd = `git log --ancestry-path ${commitHash}..${envSyncSourceBranch} --oneline | head -1`;\n\t\t\t\tconst ancestryOutput = await this.executeCommand(\n\t\t\t\t\tancestryCmd,\n\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\t`Find commit on ${envSyncSourceBranch} containing ${commitHash}`\n\t\t\t\t);\n\t\t\t\tconst ancestryLine = ancestryOutput.trim();\n\t\t\t\tif (!ancestryLine) {\n\t\t\t\t\tthrow new Error(`Unable to find a commit on ${envSyncSourceBranch} that contains ${commitHash}`);\n\t\t\t\t}\n\n\t\t\t\tconst targetHash = ancestryLine.split(' ')[0];\n\t\t\t\tthis.logger(`Found commit ${targetHash} on ${envSyncSourceBranch} for ${branch} (from potential commit ${commitHash})`);\n\t\t\t\treturn targetHash;\n\t\t\t}\n\n\t\t\tconst commitHash = fastForwardLine.split(' ')[0];\n\t\t\tthis.logger(`Found potential fast-forward commit for ${branch} using decorated log: ${commitHash}`);\n\t\t\treturn commitHash;\n\t\t};\n\n\t\tconst getMergeCommit = async (branch, isInitialBranch = false) => {\n\t\t\tconst findMergeCommitCommand = `git log --merges --oneline --first-parent HEAD | grep '${branch}' | head -1`;\n\t\t\tconst output = await this.executeCommand(\n\t\t\t\tfindMergeCommitCommand,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t`Find merge commit for ${branch} on current branch`\n\t\t\t);\n\t\t\tconst mergeCommitFound = output.trim();\n\t\t\tif (!mergeCommitFound) {\n\t\t\t\treturn getFastForwardCommit(branch, isInitialBranch);\n\t\t\t}\n\n\t\t\tconst commitHash = mergeCommitFound.split(' ')[0];\n\t\t\tthis.logger(`Merge commit for ${branch} on current branch: ${commitHash}`);\n\t\t\treturn commitHash;\n\t\t};\n\n\t\tconst firstBranch = userStoryBranches[0];\n\t\tconst lastBranch = userStoryBranches[userStoryBranches.length - 1];\n\n\t\tconst isInitialBranch = true;\n\t\tconst isFinalBranch = false;\n\t\tconst initialCommit = await getMergeCommit(firstBranch, isInitialBranch);\n\t\tconst finalCommit = await getMergeCommit(lastBranch, isFinalBranch);\n\n\t\tthis.logger('===== Environment Sync commit range resolved =====');\n\t\tthis.logger(`- Initial commit (from ${firstBranch}): ${initialCommit}`);\n\t\tthis.logger(`- Final commit (from ${lastBranch}): ${finalCommit}`);\n\n\t\tif (!initialCommit || !finalCommit) {\n\t\t\tconst issues = [];\n\t\t\tif (!initialCommit) {\n\t\t\t\tissues.push(`initial commit for '${firstBranch}' could not be determined`);\n\t\t\t} else {\n\t\t\t\tissues.push(`initial commit for '${firstBranch}' resolved to ${initialCommit}`);\n\t\t\t}\n\t\t\tif (!finalCommit) {\n\t\t\t\tissues.push(`final commit for '${lastBranch}' could not be determined`);\n\t\t\t} else {\n\t\t\t\tissues.push(`final commit for '${lastBranch}' resolved to ${finalCommit}`);\n\t\t\t}\n\n\t\t\tthrow new Error(`Unable to proceed with Environment Sync: ${issues.join(' | ')}`);\n\t\t}\n\n\t\treturn { initialCommit, finalCommit };\n\t};\n\n\t// Try to find commits initially on the current clone\n\ttry {\n\t\treturn await findCommitsOnCurrentClone();\n\t} catch (error) {\n\t\treturn this.retryFindCommitsWithDepthForEnvSync(findCommitsOnCurrentClone);\n\t}\n}\n\n/**\n * When initial commit lookups fail, progressively deepens the repository history (up to 2 attempts).\n *\n * If the original clone used --shallow-since (shallowSinceSupportedForEnvSync=true), the first retry\n * wipes and re-clones with --depth (since --deepen is incompatible with shallow-since clones),\n * and the second retry uses --deepen on the now depth-based clone.\n *\n * If the original clone already used --depth (shallowSinceSupportedForEnvSync=false), both retries\n * use --deepen directly since it's compatible with depth-based clones.\n */\nasync function retryFindCommitsWithDepthForEnvSync(findCommits) {\n\tfor (let attempts = 0; attempts < 2; attempts++) {\n\t\tconst baseIncrement = GIT_DEPTH * 10;\n\t\tconst power = attempts + 1;\n\t\tconst deepenBy = baseIncrement ** power;\n\t\tconst newDepth = GIT_DEPTH + deepenBy;\n\n\t\tif (attempts === 0 && shallowSinceSupportedForEnvSync) {\n\t\t\t// First retry when cloned with --shallow-since: wipe and re-clone with --depth\n\t\t\tthis.logger(`Required commits not found locally. Re-cloning branch '${envSyncSourceBranch}' with depth ${newDepth} (attempt 1/2)...`);\n\n\t\t\tconst recloneCmd = [\n\t\t\t\t'find . -mindepth 1 -maxdepth 1 -exec rm -rf {} +',\n\t\t\t\t`copado-git-get --depth \"${newDepth}\" \"${envSyncSourceBranch}\"`\n\t\t\t].join(' && ');\n\n\t\t\tawait this.executeCommand(\n\t\t\t\trecloneCmd,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t`Re-clone shallow repository for branch ${envSyncSourceBranch} with depth ${newDepth}`\n\t\t\t);\n\n\t\t\ttry {\n\t\t\t\tconst result = await findCommits();\n\t\t\t\tawait this.fetchTargetBranch(targetBranch);\n\t\t\t\treturn result;\n\t\t\t} catch (retryError) {\n\t\t\t\t// Fall through to next retry\n\t\t\t}\n\t\t} else {\n\t\t\t// For subsequent retries (or when shallow-since was not supported), prefer using git fetch --deepen\n\t\t\t// where supported, but gracefully fall back to a full re-clone with higher --depth when the provider\n\t\t\t// does not support --deepen (e.g. Azure DevOps).\n\t\t\tif (gitDeepenSupportedForEnvSync) {\n\t\t\t\tthis.logger(\n\t\t\t\t\t`Required commits not found locally. Deepening history for branch '${envSyncSourceBranch}' by ${deepenBy} commits (attempt ${\n\t\t\t\t\t\tattempts + 1\n\t\t\t\t\t}/2)...`\n\t\t\t\t);\n\n\t\t\t\tconst deepenCmd = `copado-git-get -g \"git fetch --deepen=${deepenBy} origin ${envSyncSourceBranch}\"`;\n\n\t\t\t\ttry {\n\t\t\t\t\tawait this.executeCommand(\n\t\t\t\t\t\tdeepenCmd,\n\t\t\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t\t\t`Deepen shallow repository for branch ${envSyncSourceBranch} by ${deepenBy} commits`\n\t\t\t\t\t);\n\n\t\t\t\t\treturn await findCommits();\n\t\t\t\t} catch (retryError) {\n\t\t\t\t\tconst message = retryError?.message || '';\n\n\t\t\t\t\t// If the provider doesn't support --deepen, mark it as unsupported and\n\t\t\t\t\t// fall back to a full re-clone with higher --depth for this and future retries.\n\t\t\t\t\tif (message.includes('does not support --deepen')) {\n\t\t\t\t\t\tthis.logger(\n\t\t\t\t\t\t\t`Git provider does not support --deepen, falling back to re-clone with depth ${newDepth} for Environment Sync`,\n\t\t\t\t\t\t\tLOG_LEVEL.WARN\n\t\t\t\t\t\t);\n\t\t\t\t\t\tgitDeepenSupportedForEnvSync = false;\n\t\t\t\t\t\t// Fall through to the re-clone path below.\n\t\t\t\t\t} else {\n\t\t\t\t\t\t// For other git errors during deepening, rethrow so they surface clearly.\n\t\t\t\t\t\tthrow retryError;\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\n\t\t\t// Either --deepen is known to be unsupported or just failed due to lack of support.\n\t\t\t// Re-clone with a higher --depth instead.\n\t\t\tthis.logger(\n\t\t\t\t`Required commits not found locally. Re-cloning branch '${envSyncSourceBranch}' with depth ${newDepth} (attempt ${attempts + 1}/2)...`\n\t\t\t);\n\n\t\t\tconst recloneCmd = [\n\t\t\t\t'find . -mindepth 1 -maxdepth 1 -exec rm -rf {} +',\n\t\t\t\t`copado-git-get --depth \"${newDepth}\" \"${envSyncSourceBranch}\"`\n\t\t\t].join(' && ');\n\n\t\t\tawait this.executeCommand(\n\t\t\t\trecloneCmd,\n\t\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t\t`Re-clone shallow repository for branch ${envSyncSourceBranch} with depth ${newDepth}`\n\t\t\t);\n\n\t\t\ttry {\n\t\t\t\tconst result = await findCommits();\n\t\t\t\tawait this.fetchTargetBranch(targetBranch);\n\t\t\t\treturn result;\n\t\t\t} catch (retryError) {\n\t\t\t\tif (attempts === 1) {\n\t\t\t\t\tthrow new Error(\n\t\t\t\t\t\t`Unable to create environment sync branches: One or both required commits could not be determined or verified after deepening history.\n                - Error: ${retryError.message}\n                - initialCommit and finalCommit could not be found after ${attempts + 1} retry attempts.`\n\t\t\t\t\t);\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n}\n\nasync function addCopadoExcludeAutoresolveFile() {\n\t// Download .copado_exclude_autoresolve from destination branch to TEMP_DIRECTORY\n\tthis.logger(`Downloading .copado_exclude_autoresolve from destination branch ${targetBranch} to ${TEMP_DIRECTORY}...`);\n\n\ttry {\n\t\tawait this.executeCommand(\n\t\t\t`git show origin/${targetBranch}:.copado_exclude_autoresolve > ${TEMP_DIRECTORY}/.copado_exclude_autoresolve`,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t'Download .copado_exclude_autoresolve from destination branch to temp directory'\n\t\t);\n\t\tthis.logger(`.copado_exclude_autoresolve downloaded to ${TEMP_DIRECTORY}`);\n\t} catch (error) {\n\t\tthis.logger(`Warning: Could not download .copado_exclude_autoresolve from destination branch: ${error.message}`, LOG_LEVEL.WARN);\n\t}\n}\n\nasync function addWIPDiffToPreChangeBranch(preChangeBranch, promotionChanges) {\n\tthis.logger(`Checking for WIP changes between ${preChangeBranch} and ${targetBranch} to add to ${preChangeBranch}...`);\n\n\t// We need destination branch version of '.copado_exclude_autoresolve' file before WIP changes\n\tawait this.addCopadoExcludeAutoresolveFile();\n\n\t// --- Ensure SFDX CLI is authenticated and org is set as default ---\n\tawait this.configureSFDXCLI(API_VERSION, destinationInstanceUrl);\n\tawait this.disableSourceTracking();\n\n\ttry {\n\t\tconst retrievePromises = await this.retrieveWipMetadata(promotionChanges);\n\t\tif (retrievePromises) {\n\t\t\tthis.logger(`[WIP] Retrieval from destination org completed for the above metadata.`, LOG_LEVEL.SUCCESS);\n\t\t} else {\n\t\t\tthis.logger(`[WIP] No metadata to retrieve from destination org.`);\n\t\t}\n\t} catch (error) {\n\t\tthrow new Error(`Error retrieving metadata from destination org: ${error.message}`);\n\t}\n\n\t// 7. Add and commit the retrieved files to the pre-change branch\n\ttry {\n\t\tawait this.executeCommand(`git add .`, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Add WIP files');\n\t\tconst statusOutput = await this.executeCommand(`git status --porcelain`, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Detect pending changes');\n\t\tif (statusOutput && statusOutput.trim().length > 0) {\n\t\t\tawait this.executeCommand(`git commit -m \"WIP: Sync destination org changes\"`, RESULT_INFO.CATEGORY.GIT_SERVICE, 'Commit WIP changes');\n\t\t\tthis.logger('WIP changes committed to pre-change branch.', LOG_LEVEL.SUCCESS);\n\t\t} else {\n\t\t\tthis.logger('No WIP changes to commit; skipping commit.', LOG_LEVEL.SUCCESS);\n\t\t}\n\t} catch (error) {\n\t\tthis.logger(`Failed to commit WIP changes: ${error.message}`, LOG_LEVEL.ERROR);\n\t\tawait this.executeCommand('git reset --hard', RESULT_INFO.CATEGORY.GIT_SERVICE, 'Reset after failed WIP commit');\n\t}\n}\n\nasync function cloneShallowRepository(shallowSinceDate) {\n\tif (!shallowSinceDate) {\n\t\tthrow new Error('Shallow since date is required');\n\t}\n\n\t// First, try to clone using --shallow-since\n\tconst shallowSinceCmd = `copado-git-get -g \"git clone --single-branch -b ${envSyncSourceBranch} --shallow-since=${shallowSinceDate} {url} . || exit 1\"`;\n\n\ttry {\n\t\tawait this.executeCommand(shallowSinceCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLONE);\n\t\tawait this.addTargetBranchRefspecAndCheckout(targetBranch, shallowSinceDate);\n\t} catch (error) {\n\t\tconst message = error?.message || '';\n\n\t\t// Some Git providers might not support --shallow-since yet.\n\t\tif (message.includes('shallow-since')) {\n\t\t\tthis.logger('Git provider does not support --shallow-since, falling back to standard copado-git-get clone for source branch');\n\n\t\t\t// Mark that shallow-since was not available so later stages can try to deepen history if needed\n\t\t\tshallowSinceSupportedForEnvSync = false;\n\n\t\t\tconst fallbackCloneCmd = this.getRemoteBranchFetchCommand(envSyncSourceBranch);\n\t\t\tawait this.executeCommand(fallbackCloneCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLONE);\n\t\t\tawait this.fetchTargetBranch(targetBranch);\n\t\t} else {\n\t\t\t// Re-throw unexpected errors\n\t\t\tthrow error;\n\t\t}\n\t}\n}\n\n// =====================\n// Helper Functions\n// =====================\n\nfunction validateUserStoriesBranches(userStoryBranches) {\n\tconst isJsonParsable = value => {\n\t\tif (typeof value !== 'string') return false;\n\t\ttry {\n\t\t\tJSON.parse(value);\n\t\t\treturn true;\n\t\t} catch {\n\t\t\treturn false;\n\t\t}\n\t};\n\n\tlet userStoryBranchesList, errorInOrderingUS, shallowSinceDate;\n\tif (isJsonParsable(userStoryBranches)) {\n\t\tconst userStoryBranchesJson = JSON.parse(userStoryBranches);\n\n\t\tuserStoryBranchesList = userStoryBranchesJson?.userStoryBranches || userStoryBranchesJson;\n\t\terrorInOrderingUS = userStoryBranchesJson?.logError;\n\t\tshallowSinceDate = this.getAdjustedShallowSinceDate(userStoryBranchesJson?.shallowSinceDate);\n\t} else {\n\t\tuserStoryBranchesList = userStoryBranches;\n\t}\n\n\tif (!Array.isArray(userStoryBranchesList)) {\n\t\tthrow new Error('User story branches is not an array');\n\t} else if (userStoryBranchesList.length === 0) {\n\t\tthrow new Error('User story branches array is empty');\n\t}\n\n\treturn { userStoryBranchesList, errorInOrderingUS, shallowSinceDate };\n}\n\nfunction getAdjustedShallowSinceDate(shallowSinceDate) {\n\ttry {\n\t\tconst date = new Date(shallowSinceDate);\n\t\tdate.setMonth(date.getMonth() - 2);\n\n\t\treturn date.toISOString().split('T')[0];\n\t} catch {\n\t\treturn shallowSinceDate;\n\t}\n}\n\nfunction logUserStoryBranchesInfo(userStoryBranchesList, errorInOrderingUS) {\n\tif (userStoryBranchesList) {\n\t\tconst orderOfUserStories = `\n                Order of User Story Branches: ${userStoryBranchesList}`;\n\t\tconst orderingUSInfo = errorInOrderingUS\n\t\t\t? `Following error occurred while ordering the user stories: ${errorInOrderingUS}. Therefore, the merge order for back promotion of user stories is not necessarily going to follow the order as forward promotion.`\n\t\t\t: `The merge order of the user stories during forward promotions is governed by the Order By field.\n                    For back promotions, this field is ignored as user stories will automatically be merged in the same order they were merged during their original forward promotion.`;\n\t\tthis.logger(orderingUSInfo + orderOfUserStories);\n\t}\n}\n\nasync function asyncCopadoLogMessage(msg, logLevel) {\n\tif (msg) {\n\t\tthis.populateResultViewer(logLevel ? logLevel : RESULT_INFO.LEVEL.INFO, RESULT_INFO.CATEGORY.COPADO_INFO, '', msg);\n\t\tawait this.executeCommand(`copado -p \"${msg}\"`, RESULT_INFO.CATEGORY.COPADO_SERVICE);\n\t}\n}\n\nfunction populateResultViewer(level, category, additionalInfo, message) {\n\tif (message) {\n\t\tresultViewerJson.push({\n\t\t\tLevel: level,\n\t\t\tCategory: category,\n\t\t\tAdditionalInformation: additionalInfo,\n\t\t\tMessage: message\n\t\t});\n\t}\n}\n\nfunction getPath(filePath) {\n\treturn isTest ? `${__dirname}/__tests__/__mockDirectory__${filePath}` : filePath;\n}\n\nfunction buildFetchFeatureBranchesCommand(userStoryBranches) {\n\treturn `copado-git-get -g \"git fetch origin ${userStoryBranches.map(branch => `'${branch}'`).join(' ')} --depth ${GIT_DEPTH}\"`;\n}\n\nfunction getRemoteBranchFetchCommand(branch) {\n\treturn `copado-git-get --depth \"${GIT_DEPTH}\" \"${branch}\" ${\n\t\thasPrefetchedVolume ? '&& copado-git-get -g \"git pull origin ' + branch + ' --depth ' + GIT_DEPTH + '\"' : ''\n\t}`;\n}\n\nfunction hasConflict() {\n\tlet hasConflict = false;\n\tconst gitStatus = readFileSync(GIT_STATUS_FILE_PATH, 'utf-8');\n\tthis.logger(gitStatus);\n\tif (gitStatus) {\n\t\tconst porcelainStatus = gitStatus.split('\\n').map(str => str.split(' ')?.[0]);\n\t\thasConflict = porcelainStatus.some(status => {\n\t\t\tif (\n\t\t\t\t(status[0] && status[1] && status[0] === PORCELAIN_STATUS.ADDED && status[1] === PORCELAIN_STATUS.ADDED) ||\n\t\t\t\t(status[0] === PORCELAIN_STATUS.DELETED && status[1] === PORCELAIN_STATUS.DELETED)\n\t\t\t) {\n\t\t\t\treturn true;\n\t\t\t}\n\t\t\treturn status[0] === PORCELAIN_STATUS.UNMERGED || status[1] === PORCELAIN_STATUS.UNMERGED;\n\t\t});\n\t}\n\treturn hasConflict;\n}\n\nfunction getConflictingFilePaths() {\n\tconst lines = readFileSync(GIT_STATUS_FILE_PATH, 'utf-8')?.split('\\n');\n\tconst conflictedFiles = [];\n\tif (lines?.length) {\n\t\tlines.forEach(line => {\n\t\t\tif (line) {\n\t\t\t\tconst space = line.indexOf(' ');\n\t\t\t\t// AA tmp/filepath\n\t\t\t\tconst conflictType = line.substring(0, space);\n\t\t\t\t/* eslint-disable no-useless-escape */\n\t\t\t\tconst filePath = line.substring(space + 1).replaceAll(/^\\\"|\\\"$/g, '');\n\t\t\t\tif (filePath && conflictType.length == 2 && !conflictType.includes('?')) {\n\t\t\t\t\tconflictedFiles.push(filePath);\n\t\t\t\t}\n\t\t\t}\n\t\t});\n\t}\n\t// throwing an error when the backend service responds that the merge has conflict, but the git status does not provide the paths\n\tif (!conflictedFiles?.length) {\n\t\tthrow new Error('Could not find conflicting files');\n\t}\n\treturn conflictedFiles;\n}\n\nfunction escapeSpecialCharacters(text) {\n\treturn text.replace(/'/g, `'\\\\''`).replace(/\\$/g, '\\\\$');\n}\n\nfunction getGitDepth(gitDepth) {\n\tgitDepth = parseInt(gitDepth);\n\treturn gitDepth >= 0 ? gitDepth : 100;\n}\n\nfunction fetchCheckoutBranch(branch, forceCreate) {\n\treturn (\n\t\t`( copado-git-get -g \"git fetch origin ${branch} --depth ${GIT_DEPTH}\" && git checkout ${branch} )` +\n\t\t(forceCreate ? ` || git checkout -b ${branch}` : '')\n\t);\n}\n\nfunction updateVlocityChangesFile(promotionChangesFilePath, promotionChanges) {\n\tconst hasVlocityChanges = promotionChanges.find(changeObj => changeObj.c === VLOCITY_CATEGORY)?.c;\n\tif (hasVlocityChanges) {\n\t\tpromotionChanges.forEach(changeObj => {\n\t\t\tif (changeObj.c === VLOCITY_CATEGORY) {\n\t\t\t\tconst datapackKey = JSON.parse(changeObj.j)?.vk?.split('/');\n\t\t\t\tchangeObj.n = datapackKey[1]\n\t\t\t\t\t?.replace('\\\\', '-')\n\t\t\t\t\t.replace(/[^A-Za-z0-9/_\\-]+/g, '-')\n\t\t\t\t\t.replace(/[-]+/g, '-')\n\t\t\t\t\t.replace(/[-_]+_/g, '_')\n\t\t\t\t\t.replace(/[-]+\\/[-]+/g, '/')\n\t\t\t\t\t.replace(/^[-_\\\\/]+/, '')\n\t\t\t\t\t.replace(/[-_\\\\/]+$/, '');\n\t\t\t}\n\t\t});\n\t\twriteFileSync(promotionChangesFilePath, JSON.stringify(promotionChanges, null, 2));\n\t}\n}\n\nfunction getResolveConflictCommand(\n\tpromotionChangesFilePath,\n\tgitStatusFilePath,\n\tenrichedChangesFilePath,\n\tpromotionId,\n\trepositoryId,\n\tuserStoryName,\n\tdisableSmartConflictResolution\n) {\n\tconst excludeFileParameter = this.getExcludeFileParameter();\n\tconst disableSmartResolveParameter = this.getDisableSmartResolveParameter(disableSmartConflictResolution);\n\treturn `copado-merge ${TARGET_DIRECTORY} '${promotionChangesFilePath}' --out ${TEMP_DIRECTORY} -t sfdx -p ${gitStatusFilePath} -cp ${promotionId} -rp ${repositoryId} -r ${TEMP_DIRECTORY}/solvedByUser.json  -u ${userStoryName} -v2 --conflictedchanges '${enrichedChangesFilePath}' ${disableSmartResolveParameter} ${excludeFileParameter}`;\n}\n\nfunction getExcludeFileParameter() {\n\tconst excludeFile = existsSync(TEMP_DIRECTORY + '/.copado_exclude_autoresolve');\n\tif (excludeFile) {\n\t\tthis.logger('\"copado_exclude_autoresolve\" file found, applying it to the merge command');\n\t}\n\treturn excludeFile ? `-e '${TEMP_DIRECTORY}/.copado_exclude_autoresolve'` : '';\n}\n\nfunction getDeduplicateXMLCommand(layoutsInPromotionChanges, userStoryBranches) {\n\treturn `copado-merge ${TARGET_DIRECTORY} '${layoutsInPromotionChanges}' --out ${TEMP_DIRECTORY} -t sfdx deduplicate --mergedus ${this.getMergedUserStoriesFilePath(\n\t\tuserStoryBranches\n\t)}  --metadatas 'Layout'`;\n}\n\nfunction getMergedUserStoriesFilePath(userStoryBranches) {\n\tconst result = `${TEMP_DIRECTORY}/MergedUserStories.json`,\n\t\tfeature = 'feature/';\n\n\twriteFileSync(result, JSON.stringify(userStoryBranches.map(branch => branch?.substring(feature.length))));\n\treturn result;\n}\n\nfunction getLayoutsWithAddOrFullActionInPromotion(promotionChanges) {\n\tconst supportedActions = [ACTIONS.ADD, ACTIONS.FULL, ACTIONS.SELECTIVE_COMMIT];\n\tconst result = promotionChanges?.filter(change => {\n\t\treturn change.t?.toLowerCase() === METADATA_TYPE.LAYOUT && supportedActions.includes(change.a?.toLowerCase());\n\t});\n\treturn result;\n}\n\nfunction readFromPath(filePath) {\n\tif (!existsSync(filePath)) {\n\t\tthrow new Error(`Could not find file at path: ${filePath}`);\n\t}\n\tconst data = readFileSync(filePath, 'utf-8');\n\tlet result;\n\ttry {\n\t\tresult = JSON.parse(data);\n\t} catch (err) {\n\t\tthrow new Error(`Content at ${filePath} is not a valid JSON`);\n\t}\n\treturn result;\n}\n\nfunction logger(text, severity) {\n\tswitch (severity) {\n\t\tcase LOG_LEVEL.ERROR:\n\t\t\tconsole.error('❌', text);\n\t\t\tbreak;\n\t\tcase LOG_LEVEL.WARN:\n\t\t\tconsole.warn('⚠️', text);\n\t\t\tbreak;\n\t\tcase LOG_LEVEL.SUCCESS:\n\t\t\tconsole.log('✅', text);\n\t\t\tbreak;\n\t\tdefault:\n\t\t\tconsole.log(text);\n\t\t\tbreak;\n\t}\n}\n\nasync function uploadResultViewerJson(data, columns, header, headerIcon) {\n\tconst RESULT_VIEWER_JSON_PATH = `${TEMP_DIRECTORY}/ResultViewer.json`;\n\n\tconst fileContent = { data, columns, header, headerIcon };\n\twriteFileSync(RESULT_VIEWER_JSON_PATH, JSON.stringify(fileContent, null, 2));\n\tawait this.uploadFileAtPath(RESULT_VIEWER_JSON_PATH);\n}\n\nasync function uploadFileAtPath(filePath) {\n\tawait this.executeCommand(\n\t\t`copado --uploadfile ${filePath}`,\n\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.UPLOAD_FILES\n\t);\n}\n\nfunction getDisableSmartResolveParameter(disableSmartConflictResolution) {\n\treturn disableSmartConflictResolution?.toLowerCase() === 'true' ? '--disablesmartresolve' : '';\n}\n\nfunction startWatch(processType, processName, processes) {\n\tif (!processName || !processType) {\n\t\treturn;\n\t}\n\tconst startTime = process.hrtime();\n\tif (!totalTimeByType[processType]) {\n\t\ttotalTimeByType[processType] = 0;\n\t}\n\tprocesses.push({ name: processName, type: processType, startTime, endTime: null, elapsedTime: null });\n}\n\nfunction endWatch(processName, processes) {\n\tif (!processName) {\n\t\treturn;\n\t}\n\tconst processIndex = processes.length;\n\tif (!processIndex && processes[processIndex - 1].name !== processName) {\n\t\tconsole.error(`Process '${processName}' not started.`);\n\t\treturn;\n\t}\n\tconst endTime = process.hrtime();\n\tconst elapsedTime = process.hrtime(processes[processIndex - 1].startTime);\n\tprocesses[processIndex - 1].endTime = endTime;\n\tprocesses[processIndex - 1].elapsedTime = elapsedTime[0] * 1e9 + elapsedTime[1];\n}\n\nfunction printMetrics() {\n\tlet ux = new Ux();\n\tthis.logger('\\n');\n\tux.styledHeader('   ====================      OVERALL METRICS      ====================   ');\n\tconst resultData = [];\n\tprocesses.forEach(process => {\n\t\t// store data\n\t\tresultData.push({\n\t\t\tprocessType: '| ' + process.type,\n\t\t\tprocessName: '| ' + process.name,\n\t\t\t'startTime(UTC)': process.startTime ? '| ' + this.formatTime(process.startTime) : '| ' + 'N/A',\n\t\t\t'endTime(UTC)': process.endTime ? '| ' + this.formatTime(process.endTime) : '| ' + 'N/A',\n\t\t\telapseTime: process.elapsedTime ? '| ' + `${(process.elapsedTime / 1e9).toFixed(2)} s` + ' |' : '| ' + 'N/A' + ' |'\n\t\t});\n\t\t// Aggregate total time by type\n\t\tif (process.elapsedTime) {\n\t\t\tif (!totalTimeByType[process.type]) {\n\t\t\t\ttotalTimeByType[process.type] = 0;\n\t\t\t}\n\t\t\ttotalTimeByType[process.type] += process.elapsedTime;\n\t\t}\n\t});\n\n\tux.table(resultData, { processType: {}, processName: {}, 'startTime(UTC)': {}, 'endTime(UTC)': {}, elapseTime: {} });\n\tthis.logger('\\n' + '   ====================       EXECUTION SUMMARY      ====================   ');\n\t// Print total aggregate time by type\n\tObject.entries(totalTimeByType).forEach(([type, totalTime]) => {\n\t\tthis.logger(`${type} Total Time: ${(totalTime / 1e9).toFixed(2)} seconds`);\n\t});\n\tthis.logger('   ====================       EXECUTION SUMMARY      ====================   ' + '\\n');\n}\n\nfunction formatTime(time) {\n\tconst date = new Date(time[0] * 1000 + time[1] / 1e6);\n\tconst hours = date.getUTCHours().toString().padStart(2, '0');\n\tconst minutes = date.getUTCMinutes().toString().padStart(2, '0');\n\tconst seconds = date.getUTCSeconds().toString().padStart(2, '0');\n\tconst milliseconds = date.getUTCMilliseconds().toString().padStart(3, '0');\n\treturn `${hours}:${minutes}:${seconds}.${milliseconds}`;\n}\n\n// WIP helpers\nasync function retrieveWipMetadata(promotionChanges) {\n\tconst manifestPath = `${TEMP_DIRECTORY}/manifest.xml`;\n\n\t// Group members by metadata type\n\tconst metadataByType = new Map();\n\tfor (const change of promotionChanges) {\n\t\tconst type = change?.t;\n\t\tconst name = change?.n;\n\t\tif (!type || !name) continue;\n\t\tif (!metadataByType.has(type)) metadataByType.set(type, new Set());\n\t\tmetadataByType.get(type).add(name);\n\t}\n\n\tif (metadataByType.size === 0) {\n\t\treturn null;\n\t}\n\n\t// Build manifest content\n\tconst manifestLines = [];\n\tmanifestLines.push('<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\" ?>\\n');\n\tmanifestLines.push('<Package xmlns=\"http://soap.sforce.com/2006/04/metadata\">\\n');\n\tfor (const [type, membersSet] of metadataByType.entries()) {\n\t\tconst members = Array.from(membersSet).filter(Boolean);\n\t\tif (members.length === 0) continue;\n\t\tmanifestLines.push('\\t<types>\\n');\n\t\tfor (const member of members) {\n\t\t\tmanifestLines.push(`\\t\\t<members>${member}</members>\\n`);\n\t\t}\n\t\tmanifestLines.push(`\\t\\t<name>${type}</name>\\n`);\n\t\tmanifestLines.push('\\t</types>\\n');\n\t}\n\tmanifestLines.push(`\\t<version>${API_VERSION}</version>\\n`);\n\tmanifestLines.push('</Package>\\n');\n\n\t// Write manifest to disk\n\twriteFileSync(manifestPath, manifestLines.join(''));\n\n\t// Log manifest content for visibility\n\tthis.logger('START -Salesforce- Retrieve Destination Org Metadata');\n\tthis.asyncCopadoLogMessage('Retrieve Destination Org Metadata - Building manifest');\n\n\t// Execute SFDX retrieve\n\tconst retrieveCmd = `sf project retrieve start --manifest ${manifestPath} --ignore-conflicts --json || true`;\n\tlet retrieveResult;\n\ttry {\n\t\tretrieveResult = await this.executeCommand(retrieveCmd, 'SFDX CLI', '', true, true);\n\t} catch (error) {\n\t\tthrow new Error(`Error retrieving metadata: ${error.message}`);\n\t}\n\n\tthis.logger('END -Salesforce- Retrieve Destination Org Metadata');\n\n\treturn { sfRetrieveResult: retrieveResult };\n}\n\nclass CommandExecutionError extends Error {\n\tconstructor(message, category, additionalInfo) {\n\t\tsuper(`${category ? category + ' - ' : ''}${additionalInfo ? additionalInfo + ' : ' : ''}${message}`);\n\t\tthis.name = CUSTOM_ERROR.COMMAND_EXECUTION_ERROR;\n\t}\n}\n\nfunction executeCommand(command, category, additionalInfo, disableMetrics, hasJsonResponse, disableLog, disableStderrLog) {\n\tthis.logger(`==> ${command}`);\n\treturn new Promise((resolve, reject) => {\n\t\tlet output = '',\n\t\t\terror = '';\n\n\t\tif (!disableMetrics) {\n\t\t\tthis.startWatch(category, additionalInfo, processes);\n\t\t}\n\t\tconst childProcess = child_process.spawn(command, [], { shell: true });\n\n\t\tchildProcess.stdout.on('data', data => {\n\t\t\tconst outputStream = data?.toString();\n\t\t\tif (!disableLog) {\n\t\t\t\tthis.logger(outputStream);\n\t\t\t}\n\t\t\toutput += outputStream;\n\t\t});\n\n\t\tchildProcess.stderr.on('data', data => {\n\t\t\tconst errorStream = data?.toString();\n\t\t\tif (!disableStderrLog) {\n\t\t\t\tthis.logger(errorStream);\n\t\t\t}\n\t\t\terror += data?.toString();\n\t\t});\n\n\t\tchildProcess.on('close', code => {\n\t\t\tif (code !== 0) {\n\t\t\t\tthis.logger(`Code: ${code}`);\n\t\t\t\tlet errorMessage = '';\n\t\t\t\tif (hasJsonResponse) {\n\t\t\t\t\ttry {\n\t\t\t\t\t\tresolve(JSON.parse(output));\n\t\t\t\t\t} catch (error) {\n\t\t\t\t\t\terrorMessage = error;\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\terrorMessage = error;\n\t\t\t\t}\n\t\t\t\terrorMessage = errorMessage ? errorMessage : `Error executing the command ${command.trim()}`;\n\t\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, category, additionalInfo, errorMessage);\n\n\t\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\t\terrorMessage\n\t\t\t\t\t\t.split('\\n')\n\t\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t\t.join(' ')\n\t\t\t\t);\n\t\t\t\treject(new CommandExecutionError(truncatedError, category, additionalInfo));\n\t\t\t}\n\t\t\tresolve(hasJsonResponse ? JSON.parse(output) : output);\n\t\t\tif (!disableMetrics) {\n\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.on('error', error => {\n\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, category, additionalInfo, error);\n\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\terror\n\t\t\t\t\t.split('\\n')\n\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t.join(' ')\n\t\t\t);\n\t\t\treject(new CommandExecutionError(truncatedError, category, additionalInfo));\n\t\t\tif (!disableMetrics) {\n\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t}\n\t\t});\n\t});\n}\n\nfunction getErrorCommand(error) {\n\tconst suffix = 'Please, check the logs for more details.';\n\treturn `copado -p \"Error\" -e ${JSON.stringify(error?.trim()?.substring(0, 32760) + '; ' + suffix)}`;\n}\n\nasync function getApiVersion(overriddenApiVersion, apiVersion) {\n\tconst finalApiVersion = overriddenApiVersion || apiVersion;\n\tconst regExpApiVersion = /\\d\\d\\.0/;\n\tif (!regExpApiVersion.test(finalApiVersion)) {\n\t\tawait this.executeCommand(this.getErrorCommand(`Invalid API Version: ${finalApiVersion}`));\n\t\tprocess.exit(1);\n\t}\n\treturn finalApiVersion;\n}\n\nfunction getEnvSyncSourceBranch() {\n\tif (!otherInformationJson) {\n\t\tthis.logger('No otherInformationJson provided, using fallback sourceBranch', LOG_LEVEL.WARN);\n\t\treturn sourceBranch;\n\t}\n\n\ttry {\n\t\tconst otherInfo = JSON.parse(otherInformationJson);\n\t\tconst envSyncSourceBranch = otherInfo?.envSyncSourceBranch;\n\n\t\tif (envSyncSourceBranch) {\n\t\t\treturn envSyncSourceBranch;\n\t\t} else {\n\t\t\tthis.logger('envSyncSourceBranch not found in otherInformationJson, using fallback sourceBranch', LOG_LEVEL.WARN);\n\t\t\treturn sourceBranch;\n\t\t}\n\t} catch (error) {\n\t\tthis.logger(`Error parsing otherInformationJson: ${error.message}. Using fallback sourceBranch`, LOG_LEVEL.ERROR);\n\t\treturn sourceBranch;\n\t}\n}\n\nmodule.exports.execute = execute;\nmodule.exports.asyncCopadoLogMessage = asyncCopadoLogMessage;\nmodule.exports.getPromotionChanges = getPromotionChanges;\nmodule.exports.setUpDirectory = setUpDirectory;\nmodule.exports.fetchTargetBranch = fetchTargetBranch;\nmodule.exports.fetchCreatePromotionBranch = fetchCreatePromotionBranch;\nmodule.exports.configureGit = configureGit;\nmodule.exports.promote = promote;\nmodule.exports.uploadGitConflictsResolution = uploadGitConflictsResolution;\nmodule.exports.hasConflict = hasConflict;\nmodule.exports.resolveConflict = resolveConflict;\nmodule.exports.getConflictingFilePaths = getConflictingFilePaths;\nmodule.exports.gitCommit = gitCommit;\nmodule.exports.saveMergeCommitId = saveMergeCommitId;\nmodule.exports.gitPush = gitPush;\nmodule.exports.checkSFDXProjectJson = checkSFDXProjectJson;\nmodule.exports.getErrorCommand = getErrorCommand;\nmodule.exports.executeCommand = executeCommand;\nmodule.exports.getApiVersion = getApiVersion;\nmodule.exports.escapeSpecialCharacters = escapeSpecialCharacters;\nmodule.exports.fetchFeatureBranches = fetchFeatureBranches;\nmodule.exports.mergeFeatureBranchInPromotionBranch = mergeFeatureBranchInPromotionBranch;\nmodule.exports.getRemoteBranchFetchCommand = getRemoteBranchFetchCommand;\nmodule.exports.remotePromotionBranchExists = remotePromotionBranchExists;\nmodule.exports.getPath = getPath;\nmodule.exports.handleConflicts = handleConflicts;\nmodule.exports.getGitDepth = getGitDepth;\nmodule.exports.fetchCheckoutBranch = fetchCheckoutBranch;\nmodule.exports.buildFetchFeatureBranchesCommand = buildFetchFeatureBranchesCommand;\nmodule.exports.checkoutFeatureAndPromotionBranch = checkoutFeatureAndPromotionBranch;\nmodule.exports.updateVlocityChangesFile = updateVlocityChangesFile;\nmodule.exports.deduplicateXMLTags = deduplicateXMLTags;\nmodule.exports.readFromPath = readFromPath;\nmodule.exports.getLayoutsWithAddOrFullActionInPromotion = getLayoutsWithAddOrFullActionInPromotion;\nmodule.exports.enrichChangeList = enrichChangeList;\nmodule.exports.getMergedUserStoriesFilePath = getMergedUserStoriesFilePath;\nmodule.exports.getResolveConflictCommand = getResolveConflictCommand;\nmodule.exports.getDeduplicateXMLCommand = getDeduplicateXMLCommand;\nmodule.exports.populateResultViewer = populateResultViewer;\nmodule.exports.uploadResultViewerJson = uploadResultViewerJson;\nmodule.exports.uploadFileAtPath = uploadFileAtPath;\nmodule.exports.startWatch = startWatch;\nmodule.exports.endWatch = endWatch;\nmodule.exports.formatTime = formatTime;\nmodule.exports.printMetrics = printMetrics;\nmodule.exports.getDisableSmartResolveParameter = getDisableSmartResolveParameter;\nmodule.exports.logger = logger;\nmodule.exports.checkPrefetchedVolume = checkPrefetchedVolume;\nmodule.exports.getAdjustedShallowSinceDate = getAdjustedShallowSinceDate;\n\n// Environment Sync exports\nmodule.exports.createEnvironmentSyncPromotionBranch = createEnvironmentSyncPromotionBranch;\nmodule.exports.configureSFDXCLI = configureSFDXCLI;\nmodule.exports.getInstanceUrl = getInstanceUrl;\nmodule.exports.handleEnvironmentSyncConflicts = handleEnvironmentSyncConflicts;\nmodule.exports.createEnvironmentSyncPromotionChanges = createEnvironmentSyncPromotionChanges;\nmodule.exports.isEnvironmentSync = isEnvironmentSync;\nmodule.exports.executeEnvironmentSyncFlow = executeEnvironmentSyncFlow;\nmodule.exports.setupEnvironmentSyncEnvironment = setupEnvironmentSyncEnvironment;\nmodule.exports.createAndMergeEnvironmentSyncBranches = createAndMergeEnvironmentSyncBranches;\nmodule.exports.createEnvironmentSyncBranch = createEnvironmentSyncBranch;\nmodule.exports.createPromotionBranch = createPromotionBranch;\nmodule.exports.handleMergeConflicts = handleMergeConflicts;\nmodule.exports.configureAndPushChanges = configureAndPushChanges;\nmodule.exports.getPushCommand = getPushCommand;\nmodule.exports.findInitialAndFinalMergeCommits = findInitialAndFinalMergeCommits;\nmodule.exports.addCopadoExcludeAutoresolveFile = addCopadoExcludeAutoresolveFile;\nmodule.exports.addWIPDiffToPreChangeBranch = addWIPDiffToPreChangeBranch;\nmodule.exports.handleManualEnvironmentSyncConflicts = handleManualEnvironmentSyncConflicts;\nmodule.exports.validateUserStoriesBranches = validateUserStoriesBranches;\nmodule.exports.initializeExecution = initializeExecution;\nmodule.exports.executeRegularPromotionFlow = executeRegularPromotionFlow;\nmodule.exports.logUserStoryBranchesInfo = logUserStoryBranchesInfo;\nmodule.exports.handleExecutionError = handleExecutionError;\nmodule.exports.finalizeExecution = finalizeExecution;\nmodule.exports.applyEnvironmentSyncChangesToPromotion = applyEnvironmentSyncChangesToPromotion;\nmodule.exports.retrieveWipMetadata = retrieveWipMetadata;\nmodule.exports.getExcludeFileParameter = getExcludeFileParameter;\nmodule.exports.cloneShallowRepository = cloneShallowRepository;\nmodule.exports.addTargetBranchRefspecAndCheckout = addTargetBranchRefspecAndCheckout;\nmodule.exports.disableSourceTracking = disableSourceTracking;\nmodule.exports.retryFindCommitsWithDepthForEnvSync = retryFindCommitsWithDepthForEnvSync;\nmodule.exports.getEnvSyncSourceBranch = getEnvSyncSourceBranch;\n\n!isTest && this.execute();",
                    "copado__Type__c": "Standard",
                    "copado__Worker_Size__c": "M",
                    "Id": "a0l7Q000000iAiMQAU",
                    "LastReferencedDate": "2023-12-19T12:42:05.000+0000",
                    "LastViewedDate": "2023-12-19T12:42:05.000+0000",
                    "Name": "Promote"
                },
                {
                    "attributes": {
                        "type": "copado__Function__c",
                        "url": "/services/data/v55.0/sobjects/copado__Function__c/a0l7Q000000MDYyQAO"
                    },
                    "copado__API_Name__c": "sfdx_encode_file_names",
                    "copado__Image_Name__c": "copado-multicloud-dx:v6",
                    "copado__Options__c": "[ ]",
                    "copado__Parameters__c": "[ {\n  \"name\" : \"file_changes_id\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.fileWithSelectedChanges}\"\n}, {\n  \"name\" : \"file_name\",\n  \"defaultValue\" : \"Copado Deploy changes\"\n} ]",
                    "copado__Script__c": "#!/usr/bin/env node\nconst execSync = require('child_process').execSync,\n    { existsSync, writeFileSync, readFileSync } = require('fs');\n\nlet deploymentMetadata = [];\n\n// EXECUTION\n\nexecute();\n\nfunction execute() {\n    getDeployChanges();\n    if (deploymentMetadata.length) {\n        encodeFileNames();\n    }\n}\n\n// SCRIPT FUNCTIONS\n\nfunction getDeployChanges() {\n    const { file_name, file_changes_id } = process.env;\n    execSync(`copado --downloadfiles ${file_changes_id} --downloaddir /tmp/`);\n    let downloadedFileName;\n    if (existsSync(`/tmp/${file_name}`)) {\n        downloadedFileName = file_name;\n    } else if (existsSync(`/tmp/${file_name}.json`)) {\n        downloadedFileName = `${file_name}.json`;\n    } else {\n        throw 'Error fetching Deployment Changes';\n    }\n    deploymentMetadata = readFromPath(`/tmp/${downloadedFileName}`);\n    printChanges(deploymentMetadata);\n\n    //TODO : First condition needs to be removed, adding this now to make sure already committed files do not fail in further operations.\n    deploymentMetadata = deploymentMetadata.filter(element => element.c?.toLowerCase() !== 'vlocity');\n}\n\nfunction encodeFileNames() {\n    for (let change of deploymentMetadata) {\n        switch (change.t) {\n            /*\n                This decoding logic for DashboardFolder, ReportFolder and EmailTemplate is no longer needed from DX v5.9 as US-0072554 removed the encoding for these metadata from SourceMember.cls\n                but we shall keep it in place for backward compatibility\n            */\n            case 'DashboardFolder':\n            case 'ReportFolder':\n            case 'Document':\n                change.n = change.n.substring(0, change.n.lastIndexOf('.')) ? change.n.substring(0, change.n.lastIndexOf('.')) : change.n;\n                break;\n\n            case 'EmailTemplate':\n                change.n = change.n.replace(/%24/gi, '$').replace(/%2F/gi, '/');\n                break;\n\n            case 'Layout': {\n                const regExp = '(?:([a-zA-Z_][a-zA-Z0-9_]{0,14}?(?!__c-))__)?([^-]+)-(?:([a-zA-Z_][a-zA-Z0-9_]{0,14}?_?(?!__c$))__)?(.+)\\n?';\n                const layoutFullName = change.n.match(regExp);\n                let layoutName = layoutFullName[4].replace(/_{2}(?!c)/g, (match) => {\n                    return match.replace(/_/gi, '%5F');\n                });\n                layoutName = layoutName.replace(/\\./, '%2E');\n                change.n = `${layoutFullName[1] ? layoutFullName[1] + '__' : ''}${layoutFullName[2]}-${layoutFullName[3] ? layoutFullName[3] + '__' : ''\n                    }${layoutName}`;\n                break;\n            }\n\n            case 'Profile':\n                change.n = change.n.replace(/\\./gi, '%2E').replace(/__/gi, '%5F%5F');\n                break;\n        }\n    }\n    writeFileSync('/app/encoded_changes.json', JSON.stringify(deploymentMetadata));\n}\n\nfunction readFromPath(filePath) {\n    return JSON.parse(readFileSync(filePath, 'utf-8'));\n}\n\nfunction printChanges(changes) {\n    console.log(`Metadata list as JSON: ${JSON.stringify(changes)}`);\n}",
                    "copado__Type__c": "Standard",
                    "Id": "a0l7Q000000MDYyQAO",
                    "LastReferencedDate": "2022-09-16T10:59:41.000+0000",
