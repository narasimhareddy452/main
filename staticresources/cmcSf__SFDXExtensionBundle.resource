                        "url": "/services/data/v65.0/sobjects/copado__Function__c/a0oRR00000N9ZcPYAV"
                    },
                    "copado__API_Name__c": "SFDX_Create_Isolation_Branch",
                    "copado__Description__c": "Creates an Isolation Branch that allows the user to see only the components that have been committed in the User Story in the Pull Request while merging to the next environment",
                    "copado__Image_Name__c": "copado-multicloud-dx:v6",
                    "copado__Options__c": "[ ]",
                    "copado__Parameters__c": "[ {\n  \"required\" : true,\n  \"name\" : \"gitName\",\n  \"defaultValue\" : \"{$User.Name}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"gitEmail\",\n  \"defaultValue\" : \"{$User.Email}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"gitDepth\",\n  \"defaultValue\" : \"100\"\n}, {\n  \"required\" : true,\n  \"name\" : \"git_json\",\n  \"defaultValue\" : \"{$Context.Repository.Credential}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"dataJson\",\n  \"defaultValue\" : \"\"\n}, {\n  \"name\" : \"repositoryId\",\n  \"defaultValue\" : \"\"\n} ]",
                    "copado__Result_Viewer_Component__c": "cmcSf:resultViewer",
                    "copado__Script__c": "#!/usr/bin/env node\n'use strict';\n\n// #region Setup\nconst child_process = require('child_process');\nconst fs = require('fs');\n\nconst { gitDepth, dataJson, isTest } = process.env;\n\nconst CUSTOM_ERROR = {\n\t\tCOMMAND_EXECUTION_ERROR: 'CommandExecutionError'\n\t},\n\tRESULT_INFO = {\n\t\tLEVEL: {\n\t\t\tINFO: 'INFO',\n\t\t\tERROR: 'ERROR',\n\t\t\tWARN: 'WARN'\n\t\t},\n\t\tADDITIONAL_INFORMATION: {\n\t\t\tGIT_CLONE: 'Git Clone',\n\t\t\tGIT_CHECKOUT: 'Git Checkout',\n\t\t\tGIT_COMMIT: 'Git Commit',\n\t\t\tGIT_PUSH: 'Git Push',\n\t\t\tGIT_FIND_COMMIT_ID: 'Git Find Commit Id',\n\t\t\tUPLOAD_FILES: 'Upload Files'\n\t\t},\n\t\tCATEGORY: {\n\t\t\tUNKNOWN_EXCEPTION: 'Unknown Exception',\n\t\t\tCOPADO_INFO: 'Copado Info',\n\t\t\tCOPADO_SERVICE: 'Copado Service',\n\t\t\tFILE_SYSTEM: 'File System'\n\t\t}\n\t},\n\tTEMP_DIRECTORY = getPath('/tmp'),\n\tCOPADO_INFO_PREFIX = 'CopadoFunction INFO',\n\tRESULT_TABLE_COLUMNS = [\n\t\t{\n\t\t\tlabel: 'Level',\n\t\t\tfieldName: 'Level',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Level',\n\t\t\tinitialWidth: 80\n\t\t},\n\t\t{\n\t\t\tlabel: 'Category',\n\t\t\tfieldName: 'Category',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Category',\n\t\t\tinitialWidth: 120\n\t\t},\n\t\t{\n\t\t\tlabel: 'Additional Information',\n\t\t\tfieldName: 'AdditionalInformation',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Additional_Information',\n\t\t\tinitialWidth: 200\n\t\t},\n\t\t{\n\t\t\tlabel: 'Message',\n\t\t\tfieldName: 'Message',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Message'\n\t\t}\n\t],\n\tRESULT_TABLE_HEADER = {\n\t\tlabel: 'Create Isolation Branch Result',\n\t\tcustomLabel: 'create_isolation_branch_result'\n\t},\n\tHEADER_ICON = 'standard:note',\n\tGIT_DEPTH = getGitDepth(),\n\tparsedDataJson = parseDataJson(),\n\tisolationBranchName = `isolation/${parsedDataJson.featureBranchName}`, // Only exist to show clean PR to developer, but will not be merged, merge is done in feature branch\n\tcommitMessageValue = parsedDataJson.commitMessage || parsedDataJson.featureBranchName;\n\nlet executionError,\n\tprocesses = new Map(),\n\tresultViewerJson = [];\n// #endregion\n\n// SCRIPT FUNCTIONS\n\nasync function execute() {\n\ttry {\n\t\tawait this.cloneRepositoryAndCheckoutFeatureBranch();\n\t\tawait this.fetchRequiredBranches();\n\t\tawait this.createIsolationBranchFromDestinationBranch();\n\t\tawait this.createSquashBranch();\n\t\tawait this.squashCommits();\n\t\tawait this.cherryPickAndResolveConflicts();\n\t\tawait this.pushIsolationBranchToRemote();\n\t} catch (err) {\n\t\tthis.logger(`Error stack: ${err.stack}`);\n\t\tif (!(err instanceof CommandExecutionError)) {\n\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, RESULT_INFO.CATEGORY.UNKNOWN_EXCEPTION, 'See logs for more info', err.message);\n\t\t}\n\t\texecutionError = err.message || err?.toString() || 'Unknown Error occurred';\n\t} finally {\n\t\tif (resultViewerJson?.length) {\n\t\t\tthis.uploadResultViewerJson(resultViewerJson, RESULT_TABLE_COLUMNS, RESULT_TABLE_HEADER, HEADER_ICON);\n\t\t}\n\t\tif (executionError) {\n\t\t\tawait this.executeCommand(this.getErrorCmdString(executionError));\n\t\t}\n\t\tthis.printMetrics();\n\t\tif (executionError) {\n\t\t\tprocess.exit(1);\n\t\t}\n\t}\n}\n\nfunction parseDataJson() {\n\t// Merge dataJson with environment variables\n\tlet parsedDataJson = {};\n\tif (process.env.dataJson) {\n\t\ttry {\n\t\t\tparsedDataJson = JSON.parse(dataJson);\n\t\t} catch (e) {\n\t\t\tconsole.error('Failed to parse dataJson. Ensure it is valid JSON.', e);\n\t\t\tprocess.exit(1);\n\t\t}\n\t}\n\treturn parsedDataJson;\n}\n\nasync function cloneRepositoryAndCheckoutFeatureBranch() {\n\tconst cloneRepository = `copado-git-get --depth \"${GIT_DEPTH}\" \"${parsedDataJson.featureBranchName}\"`;\n\tawait this.asyncCopadoLogMessage('Cloning repository and checking out feature branch...');\n\tawait this.executeCommand(cloneRepository, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLONE);\n}\n\nasync function fetchRequiredBranches() {\n\t// Fetch only the destination branch and isolation branch (if it exists)\n\tconst fetchDestination = `copado-git-get -g \"git fetch origin ${parsedDataJson.destinationBranchName}\"`;\n\tawait this.asyncCopadoLogMessage(`Fetching destination branch ${parsedDataJson.destinationBranchName}...`);\n\tawait this.executeCommand(fetchDestination, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLONE);\n\n\t// Try to fetch isolation branch - if it exists, we should exit\n\ttry {\n\t\tconst fetchIsolation = `copado-git-get -g \"git fetch origin ${isolationBranchName}\"`;\n\t\tawait this.asyncCopadoLogMessage(`Checking if isolation branch ${isolationBranchName} exists...`);\n\t\tawait this.executeCommand(fetchIsolation, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLONE);\n\t\t// If fetch succeeds, the branch exists on remote\n\t\tconsole.log(`Isolation branch ${isolationBranchName} already exists on remote`);\n\t\tawait this.asyncCopadoLogMessage('Isolation branch exists');\n\t\tprocess.exit(0);\n\t} catch (error) {\n\t\t// Branch does not exist - this is expected, continue with creation\n\t\tconsole.log(`${isolationBranchName} does not exist, proceeding with creation...`);\n\t}\n}\n\nasync function createIsolationBranchFromDestinationBranch() {\n\tconst cmd = `git checkout -b ${isolationBranchName} origin/${parsedDataJson.destinationBranchName}`;\n\tawait this.asyncCopadoLogMessage('Creating isolation branch from destination branch...');\n\tawait this.executeCommand(cmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CHECKOUT);\n}\n\nasync function createSquashBranch() {\n\tconst cmd = `git checkout -b squashBranch ${parsedDataJson.featureBranchName}`;\n\tawait this.asyncCopadoLogMessage('Isolating changes');\n\tawait this.executeCommand(cmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CHECKOUT);\n}\n\nasync function squashCommits() {\n\tconst parentCommitCmd = `git rev-parse ${parsedDataJson.initialCommitHash}^`;\n\tlet parentCommit;\n\ttry {\n\t\tparentCommit = await this.executeCommand(\n\t\t\tparentCommitCmd,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_FIND_COMMIT_ID,\n\t\t\tfalse,\n\t\t\tfalse,\n\t\t\tfalse\n\t\t);\n\t\tconsole.log('Parent commit:', parentCommit);\n\t} catch (e) {\n\t\tconsole.error('Error finding parent commit:', e);\n\t\tprocess.exit(1);\n\t}\n\n\tawait this.asyncCopadoLogMessage('Resetting to parent commit...');\n\tawait this.executeCommand(`git reset --soft ${parentCommit}`, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLONE);\n\tawait this.asyncCopadoLogMessage('Creating squashed commit...');\n\tawait this.executeCommand(\n\t\t`git commit -m \"${commitMessageValue}\"`,\n\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_COMMIT\n\t);\n}\n\nasync function cherryPickAndResolveConflicts() {\n\t// Switch back to isolation branch before cherry-picking\n\tawait this.asyncCopadoLogMessage('Switching to isolation branch...');\n\tawait this.executeCommand(\n\t\t`git checkout ${isolationBranchName}`,\n\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_CHECKOUT\n\t);\n\n\tconst cherryPickCmd = `git cherry-pick squashBranch`;\n\ttry {\n\t\tawait this.asyncCopadoLogMessage('Cherry-picking squashed commit...');\n\t\tawait this.executeCommand(cherryPickCmd, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLONE);\n\t} catch (error) {\n\t\t// If cherry-pick fails due to conflicts, resolve them by taking feature branch changes\n\t\tconsole.log('Conflicts detected during cherry-pick, resolving with feature branch winning...');\n\t\t// Feature branch always wins\n\t\tconst resolveConflicts = `git checkout --theirs . && git add . && git commit -m \"${commitMessageValue}\"`;\n\t\tawait this.asyncCopadoLogMessage('Resolving conflicts with feature branch changes...');\n\t\tawait this.executeCommand(resolveConflicts, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLONE);\n\t\tconsole.log('Conflicts resolved - feature branch changes preserved');\n\t}\n}\n\nasync function pushIsolationBranchToRemote() {\n\tconst pushIsolationBranch = `copado-git-get -g \"git push origin ${isolationBranchName}\"`;\n\tawait this.asyncCopadoLogMessage('Pushing to origin');\n\tawait this.executeCommand(pushIsolationBranch, RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_PUSH);\n\tconsole.log('\\n Execution completed successfully');\n}\n\n// INNER CLASS\nclass CommandExecutionError extends Error {\n\tconstructor(message, category, additionalInfo) {\n\t\tsuper(`${category ? category + ' - ' : ''}${additionalInfo ? additionalInfo + ' : ' : ''}${message}`);\n\t\tthis.name = CUSTOM_ERROR.COMMAND_EXECUTION_ERROR;\n\t}\n}\n\n// INNER FUNCTIONS\nfunction executeCommand(command, category, additionalInfo, disableMetrics, hasJsonResponse, disableLogs, options) {\n\tthis.logger(`===> ${command}`);\n\treturn new Promise((resolve, reject) => {\n\t\tlet output = '',\n\t\t\terror = '';\n\t\tif (!disableMetrics) {\n\t\t\tthis.startWatch(category, additionalInfo, processes);\n\t\t}\n\t\tconst childProcess = child_process.spawn(command, [], options ? options : { shell: true });\n\n\t\tchildProcess.stdout.on('data', data => {\n\t\t\tconst outputStream = data?.toString();\n\t\t\tif (!disableLogs && outputStream) {\n\t\t\t\tthis.logger(outputStream);\n\t\t\t}\n\t\t\toutput += outputStream;\n\t\t});\n\n\t\tchildProcess.stderr.on('data', data => {\n\t\t\tconst errorStream = data?.toString();\n\t\t\tif (errorStream) {\n\t\t\t\tthis.logger(errorStream);\n\t\t\t\terror += errorStream;\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.on('close', code => {\n\t\t\tif (code !== 0) {\n\t\t\t\tlet errorMessage = '';\n\t\t\t\tif (hasJsonResponse) {\n\t\t\t\t\ttry {\n\t\t\t\t\t\tresolve(JSON.parse(output));\n\t\t\t\t\t} catch (error) {\n\t\t\t\t\t\terrorMessage = error;\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\terrorMessage = error;\n\t\t\t\t}\n\t\t\t\terrorMessage = errorMessage ? errorMessage : `Error executing the command ${command.trim()}`;\n\n\t\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, category, additionalInfo, errorMessage);\n\t\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\t\terrorMessage\n\t\t\t\t\t\t.split('\\n')\n\t\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t\t.join(' ')\n\t\t\t\t);\n\t\t\t\treject(new CommandExecutionError(truncatedError, category, additionalInfo));\n\t\t\t}\n\t\t\tresolve(hasJsonResponse ? JSON.parse(output) : output);\n\t\t\tif (!disableMetrics) {\n\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.on('error', error => {\n\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, category, additionalInfo, error);\n\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\terror\n\t\t\t\t\t.split('\\n')\n\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t.join(' ')\n\t\t\t);\n\t\t\treject(new CommandExecutionError(truncatedError, category, additionalInfo));\n\t\t\tif (!disableMetrics) {\n\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t}\n\t\t});\n\t});\n}\n\nfunction getGitDepth() {\n\tconst gitDepthParsed = parseInt(gitDepth);\n\tif (gitDepthParsed >= 0) {\n\t\treturn gitDepthParsed;\n\t}\n\treturn 100;\n}\n\nfunction startWatch(processType, processName, processes) {\n\tif (!processName || !processType) {\n\t\treturn;\n\t}\n\tconst startTime = process.hrtime();\n\tprocesses.set(processName, { name: processName, type: processType, startTime, endTime: null, elapsedTime: null });\n}\n\nfunction endWatch(processName, processes) {\n\tif (!processName) {\n\t\treturn;\n\t}\n\n\tif (!processes.has(processName)) {\n\t\tconsole.error(`Process '${processName}' not started.`);\n\t\treturn;\n\t}\n\tconst processEntry = processes.get(processName);\n\tconst endTime = process.hrtime();\n\tconst elapsedTime = process.hrtime(processEntry.startTime);\n\tprocessEntry.endTime = endTime;\n\tprocessEntry.elapsedTime = elapsedTime[0] * 1e9 + elapsedTime[1];\n\tprocesses.set(processName, processEntry);\n}\n\nfunction logger(text) {\n\tconsole.log(text);\n}\n\nfunction populateResultViewer(level, category, additionalInfo, message) {\n\tresultViewerJson.push({\n\t\tLevel: level,\n\t\tCategory: category,\n\t\tMessage: message,\n\t\tAdditionalInformation: additionalInfo\n\t});\n}\nasync function asyncCopadoLogMessage(msg, logLevel) {\n\tif (msg) {\n\t\tthis.populateResultViewer(logLevel ? logLevel : RESULT_INFO.LEVEL.INFO, RESULT_INFO.CATEGORY.COPADO_INFO, '', msg);\n\t\tawait this.executeCommand(`copado -p \"${msg}\"`, RESULT_INFO.CATEGORY.COPADO_SERVICE);\n\t}\n}\n\nfunction uploadResultViewerJson(data, columns, header, headerIcon) {\n\tconst RESULT_VIEWER_JSON_PATH = `${TEMP_DIRECTORY}/ResultViewer.json`;\n\n\tconst fileContent = { data, columns, header, headerIcon };\n\tfs.writeFileSync(RESULT_VIEWER_JSON_PATH, JSON.stringify(fileContent, null, 2));\n\tthis.uploadFileAtPath(RESULT_VIEWER_JSON_PATH);\n}\n\nfunction getPath(filePath) {\n\treturn isTest ? `${__dirname}/__tests__/__mockDir__${filePath}` : filePath;\n}\n\nfunction uploadFileAtPath(filePath) {\n\tthis.executeCommand(`copado --uploadfile ${filePath}`, RESULT_INFO.CATEGORY.COPADO_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.UPLOAD_FILES);\n}\n\nfunction getErrorCmdString(error) {\n\tconst suffix = 'Please check the logs for details.';\n\treturn `copado -p \"Error\" -e ${JSON.stringify((error || '').trim().substring(0, 32760) + '; ' + suffix)}`;\n}\n\nfunction printMetrics() {\n\tthis.logger('\\n   ====================       EXECUTION SUMMARY      ====================   ');\n}\n\n// Exported for tests and parity with other scripts\nmodule.exports.execute = execute;\nmodule.exports.executeCommand = executeCommand;\nmodule.exports.cloneRepositoryAndCheckoutFeatureBranch = cloneRepositoryAndCheckoutFeatureBranch;\nmodule.exports.fetchRequiredBranches = fetchRequiredBranches;\nmodule.exports.createIsolationBranchFromDestinationBranch = createIsolationBranchFromDestinationBranch;\nmodule.exports.createSquashBranch = createSquashBranch;\nmodule.exports.squashCommits = squashCommits;\nmodule.exports.cherryPickAndResolveConflicts = cherryPickAndResolveConflicts;\nmodule.exports.pushIsolationBranchToRemote = pushIsolationBranchToRemote;\nmodule.exports.getGitDepth = getGitDepth;\nmodule.exports.asyncCopadoLogMessage = asyncCopadoLogMessage;\nmodule.exports.startWatch = startWatch;\nmodule.exports.endWatch = endWatch;\nmodule.exports.logger = logger;\nmodule.exports.populateResultViewer = populateResultViewer;\nmodule.exports.uploadResultViewerJson = uploadResultViewerJson;\nmodule.exports.CommandExecutionError = CommandExecutionError;\nmodule.exports.uploadFileAtPath = uploadFileAtPath;\nmodule.exports.getErrorCmdString = getErrorCmdString;\nmodule.exports.printMetrics = printMetrics;\n\n// EXECUTION\n!isTest && this.execute();",
                    "copado__Type__c": "Standard",
                    "copado__Version__c": "1",
                    "copado__Worker_Size__c": "S",
                    "Id": "a0oRR00000N9ZcPYAV",
                    "LastReferencedDate": "2025-11-07T08:15:22.000+0000",
                    "LastViewedDate": "2025-11-07T08:15:22.000+0000",
                    "Name": "Create Isolation Branch"
                },
                {
                    "attributes": {
                        "type": "copado__Function__c",
                        "url": "/services/data/v65.0/sobjects/copado__Function__c/a0oUB000009cjjhYAA"
                    },
                    "copado__API_Name__c": "SFDXRunFlowTests",
                    "copado__Image_Name__c": "copado-multicloud-dx:v6",
                    "copado__Options__c": "[ ]",
                    "copado__Parameters__c": "[ {\n  \"required\" : true,\n  \"name\" : \"sourceSessionId\",\n  \"defaultValue\" : \"{$Source.Credential.SessionId}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"sourceEndpoint\",\n  \"defaultValue\" : \"{$Source.Credential.Endpoint}\"\n}, {\n  \"name\" : \"testMinutesTimeout\",\n  \"defaultValue\" : \"1440\"\n}, {\n  \"name\" : \"testResultIds\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.resultIds}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"flowTestFileVersionDetails\",\n  \"defaultValue\" : \"{$Context.apex.cmcSf.GetFileVersionIdOfFlowTest}\"\n}, {\n  \"name\" : \"consolidatedResultId\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.resultId}\"\n}, {\n  \"name\" : \"maxBuffer\",\n  \"defaultValue\" : \"5242880\"\n}, {\n  \"name\" : \"fileWithSelectedChanges\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.fileWithSelectedChanges}\"\n} ]",
                    "copado__Script__c": "#!/usr/bin/env node\n'use strict';\n\nconst child_process = require('child_process'),\n    { mkdirSync, writeFileSync, existsSync, readFile } = require('fs'),\n    {\n        sourceSessionId,\n        sourceEndpoint,\n        testMinutesTimeout,\n        testResultIds,\n        flowTestFileVersionDetails,\n        fileWithSelectedChanges,\n        consolidatedResultId,\n        maxBuffer,\n        isTest,\n        API_VERSION\n    } = process.env,\n    { Ux } = isTest ? require('@salesforce/sf-plugins-core') : require('/usr/local/lib/node_modules/@salesforce/sf-plugins-core'),\n    TEMP_DIRECTORY = getPath('/tmp'),\n    SFDX_PROJECT_DIRECTORY = `${TEMP_DIRECTORY}/sfdx-project`,\n    STDIO = {\n        INHERIT: 'inherit',\n        PIPE: 'pipe',\n        IGNORE: 'ignore'\n    },\n    NUMBER_OF_RUN_FLOW_TESTS_RETRIES = 10,\n    CONSTANTS = {\n        FLOW_TEST_FILE_NAME: 'cmcSf_FlowTests',\n        FLOW_TESTS_INFO: 'flow-tests-info',\n        FLOW_TEST_RESULT_FILE: 'flow-tests-output.json',\n        FLOW_TEST_TRUNCATED_RESULT_FILE: 'flow-tests-truncated-output.json'\n    },\n    { cpus } = require('os'),\n    RESULT_INFO = {\n        CATEGORY: {\n            SFDX_CLI: 'Salesforce CLI'\n        },\n        ADDITIONAL_INFORMATION: {\n            INSTANCE_URL: 'INSTANCE URL',\n            RUN_FLOW_TEST: 'RUN FLOW TEST'\n        }\n    };\n\nlet totalTimeByType = {},\n    processes = [];\n\n// SCRIPT FUNCTIONS\n\nasync function execute() {\n    try {\n        this.asyncCopadoLogMessage('Preparing sfdx project configuration');\n        this.setup(SFDX_PROJECT_DIRECTORY);\n        this.switchToDirectory(SFDX_PROJECT_DIRECTORY);\n        this.setInstanceUrl(sourceEndpoint);\n        const contentVersionIdsOfFlowTests = this.getContentVersionIdsOfFlowTests(flowTestFileVersionDetails);\n        const flowTests = await this.getFlowTests(contentVersionIdsOfFlowTests);\n        const testResult = await this.executeFlowTest(sourceSessionId, flowTests?.selectedFlowTests, testMinutesTimeout, 0);\n        this.switchToDirectory(TEMP_DIRECTORY);\n        this.asyncCopadoLogMessage('Uploading flow tests execution result');\n        const uploadFiles = [\n            ...this.uploadTestResult(testResult, TEMP_DIRECTORY, consolidatedResultId, testResultIds),\n            this.uploadFlowTests(flowTests?.allFlowTests, TEMP_DIRECTORY)\n        ];\n        await Promise.all(uploadFiles);\n    } catch (error) {\n        const executionError = error.message || error?.toString() || 'Unknown Error occurred';\n        this.executeCommand(this.getErrorCmdString(executionError));\n        !isTest && process.exit(1);\n    } finally {\n        this.printMetrics();\n    }\n}\n\nfunction setup(projectDirectory) {\n    mkdirSync(projectDirectory, { recursive: true, force: true });\n    const projectJSON = {\n        packageDirectories: [\n            {\n                path: 'force-app',\n                default: true\n            }\n        ],\n        name: 'sfdx-project',\n        namespace: '',\n        sfdcLoginUrl: 'https://login.salesforce.com',\n        sourceApiVersion: API_VERSION\n    };\n    writeFileSync(`${projectDirectory}/sfdx-project.json`, JSON.stringify(projectJSON));\n}\n\nfunction setInstanceUrl(sourceEndpoint) {\n    this.startWatch(RESULT_INFO.CATEGORY.SFDX_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.INSTANCE_URL, processes);\n    const baseUrl = sourceEndpoint?.substring(0, sourceEndpoint?.indexOf('/', sourceEndpoint?.indexOf('/') + 2));\n    const command = `\n        sf config set org-instance-url ${baseUrl}\n    `;\n    this.executeCommand(command);\n    this.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.INSTANCE_URL, processes);\n}\n\nasync function extractFlowNameFromFlowTest(flowTests, sourceSessionId) {\n    const getFlowNameByFlowTest = new Map();\n\n    for (const flowTest of flowTests) {\n        const command = `sf data query --query \"SELECT Id, DeveloperName, Metadata FROM FlowTest WHERE DeveloperName = '${flowTest}' LIMIT 1\" --use-tooling-api --json --target-org ${sourceSessionId}`;\n        const response = await this.executeCommandAsync(command, true, true);\n        getFlowNameByFlowTest.set(flowTest, response?.result?.records[0]?.Metadata?.flowApiName);\n    }\n\n    return getFlowNameByFlowTest;\n}\n\nasync function executeFlowTest(sourceSessionId, flowTests, testMinutesTimeout, retryCount) {\n    if (!flowTests || flowTests.length === 0) {\n        if (!fileWithSelectedChanges && !JSON.parse(flowTestFileVersionDetails)?.length) {\n            throw new Error('No flow tests were found for execution');\n        }\n        const committedFlowNames = await this.getFlows(fileWithSelectedChanges);\n        const hasAutoLaunchedFlow = await this.checkForAutoLaunchedFlows(sourceSessionId, committedFlowNames);\n        if (hasAutoLaunchedFlow) {\n            throw new Error('There is no flow test available for execution');\n        }\n        this.asyncCopadoLogMessage('Skipping execution. No flow tests and no supported flows detected');\n        return {\n            result: {\n                summary: {\n                    outcome: 'Skipped',\n                    testsRan: 0,\n                    passing: 0,\n                    failing: 0,\n                    skipped: 0\n                },\n                tests: []\n            }\n        };\n    }\n\n\tthis.asyncCopadoLogMessage('Running flow tests in the source environment');\n    const getFlowNameByFlowTest = await this.extractFlowNameFromFlowTest(flowTests, sourceSessionId);\n    this.startWatch(RESULT_INFO.CATEGORY.SFDX_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.RUN_FLOW_TEST, processes);\n    const testsParam = flowTests\n        ?.map((flowTestDeveloperName) => {\n            const flowName = getFlowNameByFlowTest.get(flowTestDeveloperName);\n            return `--tests ${flowName}.${flowTestDeveloperName}`;\n        })\n        ?.join(' ');\n    const command = `sf flow run test --target-org ${sourceSessionId} ${testsParam} --json`;\n    try {\n        const runResponse = await this.executeCommandAsync(command, true, true);\n        const testRunId = runResponse?.result?.testRunId;\n        const finalResponse = await this.pollFlowTestResult(sourceSessionId, testRunId, testMinutesTimeout);\n        return finalResponse;\n    } catch (error) {\n        const errStr = toErrorString(error);\n        if (errStr.includes('ETIMEDOUT') && retryCount < NUMBER_OF_RUN_FLOW_TESTS_RETRIES) {\n            this.messageLogger(`Retrying attempt ${retryCount + 1}`);\n            return await this.executeFlowTest(sourceSessionId, flowTests, testMinutesTimeout, ++retryCount);\n        } else {\n            throw error;\n        }\n    } finally {\n        this.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.RUN_FLOW_TEST, processes);\n    }\n}\n\nfunction toErrorString(err) {\n    if (!err) return '';\n    if (typeof err === 'string') return err;\n    if (err && typeof err === 'object') {\n        if (err.message) return err.message;\n        try {\n            return JSON.stringify(err);\n        } catch (e) {\n            return String(err);\n        }\n    }\n    return String(err);\n}\n\nasync function pollFlowTestResult(sourceSessionId, testRunId, testMinutesTimeout) {\n    const pollIntervalMs = 5000;\n    const maxWaitMs = (parseInt(testMinutesTimeout, 10) || 10) * 60 * 1000;\n    const startTime = Date.now();\n    while (true) {\n        if (Date.now() - startTime > maxWaitMs) {\n            throw new Error(`Flow test execution timed out after ${testMinutesTimeout} minute(s).`);\n        }\n        await delay(pollIntervalMs);\n        const command = `sf data query --query \"SELECT Id, Status FROM ApexTestRunResult WHERE AsyncApexJobId ='${testRunId}' LIMIT 1\" --json --target-org ${sourceSessionId}`;\n        const response = await this.executeCommandAsync(command, true, true);\n        const status = response?.result?.records[0]?.Status;\n        if (!status) {\n            continue;\n        }\n        const normalizedOutcome = status.toLowerCase();\n        if (['queued', 'pending', 'processing', 'running'].includes(normalizedOutcome)) {\n            continue;\n        }\n        await delay(pollIntervalMs);\n        const flowCommand = `sf flow get test --target-org ${sourceSessionId} --test-run-id ${testRunId} --json`;\n        const finalFlowResponse = await this.executeCommandAsync(flowCommand, true, true);\n        return finalFlowResponse;\n    }\n}\n\nfunction delay(ms) {\n    return new Promise((resolve) => {\n        setTimeout(resolve, ms);\n    });\n}\n\nfunction uploadTestResult(testResult, TEMP_DIRECTORY, consolidatedResultId, testResultIds) {\n    let promises = [];\n    promises.concat(this.uploadTestResultToFunctionResult(testResult, TEMP_DIRECTORY));\n    promises.concat(this.uploadTestResultToConsolidatedAndTestResult(testResult, TEMP_DIRECTORY, consolidatedResultId, testResultIds));\n    return promises;\n}\n\nfunction uploadFlowTests(flowTests, tmpDirectory) {\n    writeFileSync(`${tmpDirectory}/${CONSTANTS.FLOW_TESTS_INFO}`, JSON.stringify(flowTests));\n    const command = `\n        copado --uploadfile '${tmpDirectory}/${CONSTANTS.FLOW_TESTS_INFO}' --name '${CONSTANTS.FLOW_TESTS_INFO}'\n    `;\n    return this.executeCommandAsync(command);\n}\n\nfunction uploadTestResultToFunctionResult(testResult, tmpDirectory) {\n    const promises = [];\n    this.removeUsernameFromTestResult(testResult);\n    const testResultFileName = `${tmpDirectory}/${CONSTANTS.FLOW_TEST_RESULT_FILE}`;\n    writeFileSync(testResultFileName, JSON.stringify(testResult));\n    const command = `\n        copado --uploadfile ${testResultFileName} --name \"${CONSTANTS.FLOW_TEST_RESULT_FILE}\"\n    `;\n    promises.push(this.executeCommandAsync(command));\n    return promises;\n}\n\nfunction uploadTestResultToConsolidatedAndTestResult(testResult, tmpDirectory, consolidatedResultId, testResultIds) {\n    if (!consolidatedResultId && !testResultIds) {\n        throw new Error('No appropriate result record found');\n    }\n    const promises = [];\n    this.removeUsernameFromTestResult(testResult);\n    this.removeCoveredLinesFromTestResult(testResult);\n    this.removeSummaryAndRecordDetailsFromTestResult(testResult);\n    const testResultFileName = `${tmpDirectory}/${CONSTANTS.FLOW_TEST_TRUNCATED_RESULT_FILE}`;\n    writeFileSync(testResultFileName, JSON.stringify(testResult));\n\n    const resultIds = testResultIds ? JSON.parse(testResultIds) : [];\n    consolidatedResultId && resultIds.push(consolidatedResultId);\n\n    resultIds.forEach((resultId) => {\n        const command = `\n            copado --uploadfile ${testResultFileName} --name \"${CONSTANTS.FLOW_TEST_RESULT_FILE}\" --parentid ${resultId}\n        `;\n        promises.push(this.executeCommandAsync(command));\n    });\n    return promises;\n}\n\nfunction asyncCopadoLogMessage(msg) {\n    new Promise((resolve) => {\n        child_process.exec(`copado -p \"${msg}\"`, { stdio: STDIO.INHERIT }, () => {\n            resolve();\n        });\n    });\n}\n\nfunction switchToDirectory(workingDirectory) {\n    process.chdir(workingDirectory);\n}\n\nfunction getPath(filePath) {\n    return isTest ? `${__dirname}/__tests__/__mockDirectory__${filePath}` : filePath;\n}\n\nfunction executeCommand(command, hasJsonResponse, disableLogs) {\n    let errorMessage;\n    const response = child_process.spawnSync(command, this.getOptions());\n    const { outputStream, errorStream } = this.log(response, disableLogs);\n    if (response?.status == 0) {\n        return hasJsonResponse ? JSON.parse(outputStream) : outputStream;\n    }\n    if (!hasJsonResponse) {\n        errorMessage = errorStream ? errorStream : `Error executing the command ${command.trim()}`;\n    } else {\n        try {\n            return JSON.parse(outputStream);\n        } catch (error) {\n            errorMessage = errorStream ? errorStream : `Error executing the command ${command.trim()}`;\n        }\n    }\n    if (errorMessage) {\n        throw new Error(errorMessage);\n    }\n}\n\nfunction executeCommandAsync(command, hasJsonResponse, disableLog) {\n    return new Promise((resolve, reject) => {\n        let output = '',\n            error = '';\n        const childProcess = child_process.spawn(command, [], { shell: true });\n\n        childProcess.stdout.on('data', (data) => {\n            output += data?.toString();\n        });\n\n        childProcess.stderr.on('data', (data) => {\n            error += data?.toString();\n        });\n\n        childProcess.on('close', (code) => {\n            let rejected = false;\n            if (code !== 0) {\n                let errorMessage = '';\n                if (hasJsonResponse) {\n                    try {\n                        resolve(JSON.parse(output));\n                    } catch (ex) {\n                        errorMessage = error;\n                    }\n                } else {\n                    errorMessage = error;\n                }\n                errorMessage = errorMessage ? errorMessage : `Error executing the command ${command.trim()}`;\n                reject(errorMessage);\n                rejected = true;\n            }\n            if (!disableLog) {\n                this.messageLogger(code?.toString());\n                this.messageLogger(output);\n                this.messageLogger(error);\n            }\n            if (!rejected) {\n                resolve(hasJsonResponse ? JSON.parse(output) : output);\n            }\n        });\n\n        childProcess.on('error', (error) => {\n            reject(error);\n        });\n    });\n}\n\nfunction getOptions() {\n    const options = {\n        shell: true,\n        maxBuffer: parseInt(maxBuffer)\n    };\n    return options;\n}\n\nfunction log(response, disableLogs) {\n    const outputStream = response?.stdout?.toString().trim();\n    const errorStream = response?.stderr?.toString().trim();\n    if (!disableLogs) {\n        if (outputStream) {\n            this.messageLogger(outputStream);\n        }\n        if (errorStream) {\n            this.messageLogger(errorStream);\n        }\n    }\n    return { outputStream, errorStream };\n}\n\nfunction messageLogger(message) {\n    console.log(message);\n}\n\nfunction getErrorCmdString(error) {\n    const suffix = 'Please check the logs for details.';\n    return `copado -p \"Error\" -e \"${error.trim()?.substring(0, 32760)}; ${suffix}\"`;\n}\n\nfunction removeUsernameFromTestResult(testResult) {\n    if (testResult?.result?.summary?.username) {\n        delete testResult.result.summary.username;\n    }\n}\n\nfunction removeCoveredLinesFromTestResult(testResult) {\n    testResult?.result?.coverage?.coverage?.forEach((element) => {\n        delete element.lines;\n    });\n}\n\nfunction removeSummaryAndRecordDetailsFromTestResult(testResult) {\n    if (testResult?.result?.coverage?.summary) {\n        delete testResult.result.coverage.summary;\n    }\n\n    if (testResult?.result?.coverage?.records) {\n        delete testResult.result.coverage.records;\n    }\n}\n\nasync function getFlows(fileWithSelectedChanges) {\n    if (!fileWithSelectedChanges) {\n        return [];\n    }\n\n    try {\n        await this.downloadFile(fileWithSelectedChanges);\n        const filePath = `${TEMP_DIRECTORY}/${fileWithSelectedChanges}/Copado Commit changes`;\n        if (!existsSync(filePath)) {\n            return [];\n        }\n\n        const fileContent = await this.readFileAsync(filePath, true);\n        if (!Array.isArray(fileContent)) {\n            return [];\n        }\n\n        const committedFlowNames = [];\n        for (const change of fileContent) {\n            if (change.t === 'Flow' && change.a === 'Add' && change.n) {\n                committedFlowNames.push(change.n);\n            }\n        }\n\n        return [...new Set(committedFlowNames)];\n    } catch (error) {\n        this.messageLogger(`Warning: Could not read committed changes file. ${toErrorString(error)}`);\n        return [];\n    }\n}\n\nasync function checkForAutoLaunchedFlows(sourceSessionId, flowNames) {\n    if (!flowNames?.length) {\n        return false;\n    }\n\n    const namesClause = flowNames.map(name => `'${name}'`).join(',');\n    const query = `SELECT ProcessType FROM Flow WHERE Definition.DeveloperName IN (${namesClause})`;\n    const command = `sf data query --query \"${query}\" --use-tooling-api --json --target-org ${sourceSessionId}`;\n\n    try {\n        const response = await this.executeCommandAsync(command, true, true);\n        const records = response?.result?.records || [];\n        return records.some(record => record.ProcessType === 'AutoLaunchedFlow');\n    } catch (error) {\n        this.messageLogger(`Warning: Could not verify Flow ProcessType. ${toErrorString(error)}`);\n        return false;\n    }\n}\n\nasync function getFlowTests(contentVersionIdsOfFlowTests) {\n    if (!contentVersionIdsOfFlowTests?.length) {\n        return { selectedFlowTests: [], allFlowTests: [] };\n    }\n\n\tthis.asyncCopadoLogMessage('Finding flow tests for execution');\n    const commands = contentVersionIdsOfFlowTests.map((contentVersionId) => ({\n        value: `\n            mkdir -p ${TEMP_DIRECTORY}/${contentVersionId}\n            copado --downloadfiles \"${contentVersionId}\" --downloaddir ${TEMP_DIRECTORY}/${contentVersionId}\n        `,\n        hasJsonResponse: false,\n        disableLogs: false\n    }));\n\n    await this.executeParallelCommands(commands);\n\n    let selectedFlowTests = new Set();\n    let allFlowTests = new Set();\n\n    let flowTestsFileContent = await Promise.all(this.getPromisesToReadFlowTestsFile(contentVersionIdsOfFlowTests));\n    flowTestsFileContent.forEach((fileContent) => {\n        fileContent?.forEach((flowTest) => {\n            if (!flowTest?.n) {\n                return;\n            }\n            allFlowTests.add(flowTest.n);\n            if (flowTest.s) {\n                selectedFlowTests.add(flowTest.n);\n            }\n        });\n    });\n    messageLogger(`Flow tests found for execution ${[...selectedFlowTests]}`);\n\n    return { selectedFlowTests: [...selectedFlowTests], allFlowTests: [...allFlowTests] };\n}\n\nfunction getPromisesToReadFlowTestsFile(contentVersionIdsOfFlowTests) {\n    const promises = [];\n    contentVersionIdsOfFlowTests.forEach((contentVersionId) => {\n        const flowTestsFilePath = `${TEMP_DIRECTORY}/${contentVersionId}/${CONSTANTS.FLOW_TEST_FILE_NAME}`;\n        if (existsSync(flowTestsFilePath)) {\n            promises.push(this.readFileAsync(flowTestsFilePath, true));\n        }\n    });\n    return promises;\n}\n\nasync function downloadFile(contentVersionId) {\n    const commands = [{\n        value: `\n            mkdir -p ${TEMP_DIRECTORY}/${contentVersionId}\n            copado --downloadfiles \"${contentVersionId}\" --downloaddir ${TEMP_DIRECTORY}/${contentVersionId}\n        `,\n        hasJsonResponse: false,\n        disableLogs: false\n    }];\n    await this.executeParallelCommands(commands);\n}\n\nasync function executeParallelCommands(commands) {\n    const totalCpus = cpus().length;\n    const parallelCommandExecutor = new this.ParallelCommandExecutor(commands, totalCpus == 1 ? 1 : totalCpus - 1);\n    await Promise.all(parallelCommandExecutor.startExecution());\n}\n\nfunction getContentVersionIdsOfFlowTests(flowTestFileVersionDetails) {\n    let result;\n    try {\n        result = flowTestFileVersionDetails ? JSON.parse(flowTestFileVersionDetails) : [];\n    } catch (error) {\n        throw new Error(`Error finding flow test file ids, ${error.toString()}`);\n    }\n    return result;\n}\n\nclass ParallelCommandExecutor {\n    commands;\n    maxAllowedChildProcesses;\n\n    constructor(commands, maxAllowedChildProcesses) {\n        this.commands = commands;\n        this.maxAllowedChildProcesses = maxAllowedChildProcesses;\n    }\n\n    startExecution() {\n        const promises = [];\n        let totalConsumedChildProcesses = 0;\n        const totalCommands = this.commands?.length;\n        if (!totalCommands || totalCommands < 1) {\n            throw new Error('No commands supplied to the command processor');\n        }\n\n        while (this.commands.length && this.maxAllowedChildProcesses > totalConsumedChildProcesses) {\n            promises.push(\n                new Promise((resolve, reject) => {\n                    this._executeCommand(this.commands.shift(), resolve, reject);\n                })\n            );\n            totalConsumedChildProcesses++;\n        }\n        messageLogger(`Parallel command executor started ${promises.length} child process(es) for processing ${totalCommands} command(s)`);\n        return promises;\n    }\n\n    _executeCommand(command, resolve, reject) {\n        let output = '',\n            error = '';\n        const childProcess = child_process.spawn(command.value, [], {\n            shell: true\n        });\n\n        childProcess.stdout.on('data', (data) => {\n            output += data?.toString();\n        });\n\n        childProcess.stderr.on('data', (data) => {\n            error += data?.toString();\n        });\n\n        childProcess.on('error', (data) => {\n            error += data?.toString();\n        });\n\n        childProcess.on('close', (code) => {\n            if (!command.disableLogs) {\n                messageLogger(`command: ${command.value}, \\ncode: ${code}`);\n                if (output) {\n                    messageLogger(output);\n                }\n                if (error) {\n                    messageLogger(error);\n                }\n            }\n\n            if (code !== 0) {\n                let errorMessage = '';\n                if (command.hasJsonResponse) {\n                    try {\n                        errorMessage = JSON.parse(output);\n                    } catch (err) {\n                        errorMessage = err.toString();\n                    }\n                } else {\n                    errorMessage = error;\n                }\n                errorMessage = errorMessage ? errorMessage : `Error executing the command ${command.value}`;\n                reject(errorMessage);\n            } else {\n                this._handleNextExecution(resolve, reject);\n            }\n        });\n    }\n\n    _handleNextExecution(resolve, reject) {\n        if (this.commands.length) {\n            this._executeCommand(this.commands.shift(), resolve, reject);\n        } else {\n            messageLogger('Parallel command executor resolved a child process');\n            resolve('Parallel command executor resolved a child process');\n        }\n    }\n}\n\nfunction readFileAsync(filePath, isJsonContent) {\n    return new Promise((resolve, reject) => {\n        readFile(filePath, (error, data) => {\n            if (error) {\n                reject(error);\n            } else {\n                try {\n                    resolve(isJsonContent ? JSON.parse(data.toString()) : data.toString());\n                } catch (err) {\n                    reject(err.toString());\n                }\n            }\n        });\n    });\n}\n\nfunction startWatch(processType, processName, processes) {\n    if (!processName || !processType) {\n        return;\n    }\n    const startTime = process.hrtime();\n    if (!totalTimeByType[processType]) {\n        totalTimeByType[processType] = 0;\n    }\n    processes.push({ name: processName, type: processType, startTime, endTime: null, elapsedTime: null });\n}\n\nfunction endWatch(processType, processes) {\n    if (!processType) {\n        return;\n    }\n    const processIndex = processes.length;\n    if (!processIndex && processes[processIndex - 1].type !== processType) {\n        // we call endWatch in sync with startwatch for same process & doesnt overlap with others endWatch. additionally checking that it belongs to the same processType in the processes index before we store it.\n        console.error(`Process '${processType}' not started.`);\n        return;\n    }\n    const endTime = process.hrtime();\n    const elapsedTime = process.hrtime(processes[processIndex - 1].startTime);\n    processes[processIndex - 1].endTime = endTime;\n    processes[processIndex - 1].elapsedTime = elapsedTime[0] * 1e9 + elapsedTime[1];\n}\n\nfunction printMetrics() {\n    let ux = new Ux();\n    this.messageLogger('\\n');\n    ux.styledHeader('====================      OVERALL METRICS      ====================');\n    const resultData = [];\n    processes.forEach((process) => {\n        // store data\n        resultData.push({\n            processType: '| ' + process.type,\n            processName: '| ' + process.name,\n            'startTime(UTC)': process.startTime ? '| ' + this.formatTime(process.startTime) : '| ' + 'N/A',\n            'endTime(UTC)': process.endTime ? '| ' + this.formatTime(process.endTime) : '| ' + 'N/A',\n            elapseTime: process.elapsedTime ? '| ' + `${(process.elapsedTime / 1e9).toFixed(2)} s` + ' |' : '| ' + 'N/A' + ' |'\n        });\n        // Aggregate total time by type\n        if (process.elapsedTime) {\n            if (!totalTimeByType[process.type]) {\n                totalTimeByType[process.type] = 0;\n            }\n            totalTimeByType[process.type] += process.elapsedTime;\n        }\n    });\n\n    ux.table(resultData, { processType: {}, processName: {}, 'startTime(UTC)': {}, 'endTime(UTC)': {}, elapseTime: {} });\n    this.messageLogger('\\n' + '   ====================       EXECUTION SUMMARY      ====================   ');\n    // Print total aggregate time by type\n    Object.entries(totalTimeByType).forEach(([type, totalTime]) => {\n        this.messageLogger(`${type} Total Time: ${(totalTime / 1e9).toFixed(2)} seconds`);\n    });\n    this.messageLogger('   ====================       EXECUTION SUMMARY      ====================   ' + '\\n');\n}\n\nfunction formatTime(time) {\n    const date = new Date(time[0] * 1000 + time[1] / 1e6);\n    const hours = date.getUTCHours().toString().padStart(2, '0');\n    const minutes = date.getUTCMinutes().toString().padStart(2, '0');\n    const seconds = date.getUTCSeconds().toString().padStart(2, '0');\n    const milliseconds = date.getUTCMilliseconds().toString().padStart(3, '0');\n    return `${hours}:${minutes}:${seconds}.${milliseconds}`;\n}\n\nmodule.exports.setup = setup;\nmodule.exports.setInstanceUrl = setInstanceUrl;\nmodule.exports.extractFlowNameFromFlowTest = extractFlowNameFromFlowTest;\nmodule.exports.executeFlowTest = executeFlowTest;\nmodule.exports.getFlows = getFlows;\nmodule.exports.checkForAutoLaunchedFlows = checkForAutoLaunchedFlows;\nmodule.exports.pollFlowTestResult = pollFlowTestResult;\nmodule.exports.downloadFile = downloadFile;\nmodule.exports.executeParallelCommands = executeParallelCommands;\nmodule.exports.uploadFlowTests = uploadFlowTests;\nmodule.exports.uploadTestResult = uploadTestResult;\nmodule.exports.uploadTestResultToFunctionResult = uploadTestResultToFunctionResult;\nmodule.exports.uploadTestResultToConsolidatedAndTestResult = uploadTestResultToConsolidatedAndTestResult;\nmodule.exports.asyncCopadoLogMessage = asyncCopadoLogMessage;\nmodule.exports.switchToDirectory = switchToDirectory;\nmodule.exports.getPath = getPath;\nmodule.exports.executeCommand = executeCommand;\nmodule.exports.executeCommandAsync = executeCommandAsync;\nmodule.exports.getOptions = getOptions;\nmodule.exports.log = log;\nmodule.exports.messageLogger = messageLogger;\nmodule.exports.getErrorCmdString = getErrorCmdString;\nmodule.exports.removeUsernameFromTestResult = removeUsernameFromTestResult;\nmodule.exports.removeCoveredLinesFromTestResult = removeCoveredLinesFromTestResult;\nmodule.exports.removeSummaryAndRecordDetailsFromTestResult = removeSummaryAndRecordDetailsFromTestResult;\nmodule.exports.execute = execute;\nmodule.exports.getFlowTests = getFlowTests;\nmodule.exports.getContentVersionIdsOfFlowTests = getContentVersionIdsOfFlowTests;\nmodule.exports.getPromisesToReadFlowTestsFile = getPromisesToReadFlowTestsFile;\nmodule.exports.ParallelCommandExecutor = ParallelCommandExecutor;\nmodule.exports.readFileAsync = readFileAsync;\nmodule.exports.startWatch = startWatch;\nmodule.exports.endWatch = endWatch;\nmodule.exports.formatTime = formatTime;\nmodule.exports.printMetrics = printMetrics;\n\n// EXECUTION\n\n!isTest && this.execute();",
