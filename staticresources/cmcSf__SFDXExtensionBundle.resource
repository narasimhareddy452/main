                    "copado__Parameters__c": "[ {\n  \"required\" : true,\n  \"name\" : \"sourceOrgId\",\n  \"defaultValue\" : \"{$Source.Id}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"sourceInstanceUrl\",\n  \"defaultValue\" : \"{$Source.Credential.Endpoint}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"sourceSessionId\",\n  \"defaultValue\" : \"{$Source.Credential.SessionId}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"destinationOrgId\",\n  \"defaultValue\" : \"{$Destination.Id}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"destinationInstanceUrl\",\n  \"defaultValue\" : \"{$Destination.Credential.Endpoint}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"destinationSessionId\",\n  \"defaultValue\" : \"{$Destination.Credential.SessionId}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"maxBuffer\",\n  \"defaultValue\" : \"5242880\"\n}, {\n  \"required\" : true,\n  \"name\" : \"pollInterval\",\n  \"defaultValue\" : \"5000\"\n}, {\n  \"required\" : true,\n  \"name\" : \"isValidation\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.deploymentDryRun}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"dataTemplateInfo\",\n  \"defaultValue\" : \"{$Context.Apex.cmcSf.GetMainDataTemplateInfo}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"dataTemplateEnvId\",\n  \"defaultValue\" : \"{$Context.Apex.cmcSf.GetCurrentEnvId}\"\n} ]",
                    "copado__Result_Viewer_Component__c": "cmcSf:resultViewerForDataDeploy",
                    "copado__Script__c": "#!/usr/bin/env node\n'use strict';\n\n/**\n * Performs deployment of data based on the data template details provided as input\n * Returns (If ACTION success) the data records are successfully inserted/upserted from the source to the destination org\n * (If ACTION failed) Returns details with error status on the result record\n * @param sourceOrgId\n * @param sourceInstanceUrl\n * @param sourceSessionId\n * @param destinationOrgId\n * @param destinationInstanceUrl\n * @param destinationSessionId\n * @param maxBuffer\n * @param dataTemplateInfo\n * @param dataTemplateEnvId\n */\n\nconst child_process = require('child_process'),\n\tfs = require('fs'),\n\t{\n\t\tsourceOrgId,\n\t\tsourceInstanceUrl,\n\t\tsourceSessionId,\n\t\tdestinationOrgId,\n\t\tdestinationInstanceUrl,\n\t\tdestinationSessionId,\n\t\tmaxBuffer,\n\t\tCF_BACKEND_ENDPOINT,\n\t\tpollInterval,\n\t\tisTest,\n\t\tisValidation,\n\t\tdataTemplateInfo,\n\t\tdataTemplateEnvId\n\t} = process.env,\n\tresponse = {\n\t\tSTATUS: {\n\t\t\tREQUEST_ACCEPTED: 'REQUEST_ACCEPTED',\n\t\t\tFAILED: 'FAILED',\n\t\t\tCOMPLETED: 'COMPLETED'\n\t\t},\n\t\tTYPE: {\n\t\t\tJSON: 'json',\n\t\t\tBUFFER: 'buffer'\n\t\t}\n\t},\n\trequest = {\n\t\tGET: 'GET',\n\t\tPOST: 'POST'\n\t},\n\tTEMP_DIRECTORY = getPath('/tmp'),\n\tRESULT_ZIP_FILE_PATH = `${TEMP_DIRECTORY}/deploymentResult.zip`,\n\tDATA_DEPLOYMENT_RESULT_DIR = `${TEMP_DIRECTORY}/result`,\n\tMAXBUFFER = parseInt(maxBuffer),\n\tVALIDATION_MODE_MESSAGE = 'This step will not be executed for validate changes',\n\tRESULT_INFO = {\n\t\tLEVEL: {\n\t\t\tINFO: 'INFO',\n\t\t\tERROR: 'ERROR',\n\t\t\tWARN: 'WARN'\n\t\t},\n\t\tCATEGORY: {\n\t\t\tUNKNOWN_EXCEPTION: 'Unknown Exception',\n\t\t\tCOPADO_INFO: 'Copado Info',\n\t\t\tCOPADO_SERVICE: 'Copado Service',\n\t\t\tFILE_SYSTEM: 'File System'\n\t\t},\n\t\tADDITIONAL_INFORMATION: {\n\t\t\tPOPULATE_INFO_ON_RESULT: 'Populate Information on the result record',\n\t\t\tEXTRACT_DATA_DEPLOYMENT_RESULT: 'Extract Data Deployment Result',\n\t\t\tUPLOAD_FILES: 'Upload Files'\n\t\t}\n\t},\n\tSTDIO = {\n\t\tINHERIT: 'inherit'\n\t},\n\tCUSTOM_ERROR = {\n\t\tCOMMAND_EXECUTION_ERROR: 'CommandExecutionError'\n\t},\n\tTABLE_COLUMNS = {\n\t\tRESULT_VIEWER: [\n\t\t\t{\n\t\t\t\tlabel: 'Level',\n\t\t\t\tfieldName: 'Level',\n\t\t\t\ttype: 'text',\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'Level',\n\t\t\t\tinitialWidth: 80\n\t\t\t},\n\t\t\t{\n\t\t\t\tlabel: 'Category',\n\t\t\t\tfieldName: 'Category',\n\t\t\t\ttype: 'text',\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'Category',\n\t\t\t\tinitialWidth: 120\n\t\t\t},\n\t\t\t{\n\t\t\t\tlabel: 'Additional Information',\n\t\t\t\tfieldName: 'AdditionalInformation',\n\t\t\t\ttype: 'text',\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'Additional_Information',\n\t\t\t\tinitialWidth: 200\n\t\t\t},\n\t\t\t{\n\t\t\t\tlabel: 'Message',\n\t\t\t\tfieldName: 'Message',\n\t\t\t\ttype: 'text',\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'Message'\n\t\t\t}\n\t\t],\n\t\tDEPLOYMENT_SUMMARY_VIEWER: [\n\t\t\t{\n\t\t\t\tlabel: 'Template Name',\n\t\t\t\tfieldName: 'templateUrl',\n\t\t\t\ttype: 'url',\n\t\t\t\ttypeAttributes: {\n\t\t\t\t\tlabel: {\n\t\t\t\t\t\tfieldName: 'templateName'\n\t\t\t\t\t}\n\t\t\t\t},\n\t\t\t\tcustomLabel: 'Template_Name',\n\t\t\t\thideDefaultActions: true\n\t\t\t},\n\t\t\t{\n\t\t\t\tlabel: 'SObject',\n\t\t\t\tfieldName: 'objectName',\n\t\t\t\ttype: 'text',\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'SObject',\n\t\t\t\thideDefaultActions: true\n\t\t\t},\n\t\t\t{\n\t\t\t\tlabel: 'Success',\n\t\t\t\tfieldName: 'deployedRecords',\n\t\t\t\ttype: 'number',\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'Success',\n\t\t\t\thideDefaultActions: true,\n\t\t\t\tinitialWidth: 100\n\t\t\t},\n\t\t\t{\n\t\t\t\tlabel: 'Failed',\n\t\t\t\tfieldName: 'failedRecords',\n\t\t\t\ttype: 'number',\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'Failed',\n\t\t\t\thideDefaultActions: true,\n\t\t\t\tinitialWidth: 100\n\t\t\t},\n\t\t\t{\n\t\t\t\tlabel: 'Generated Ids',\n\t\t\t\tfieldName: 'generatedIds',\n\t\t\t\ttype: 'number',\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'Generated_Ids',\n\t\t\t\thideDefaultActions: true,\n\t\t\t\tinitialWidth: 120\n\t\t\t},\n\t\t\t{\n\t\t\t\tlabel: 'CSV File',\n\t\t\t\tfieldName: 'csvFileLink',\n\t\t\t\ttype: 'button-icon',\n\t\t\t\ttypeAttributes: {\n\t\t\t\t\ticonName: {\n\t\t\t\t\t\tfieldName: 'csvFileIcon'\n\t\t\t\t\t},\n\t\t\t\t\tdisabled: {\n\t\t\t\t\t\tfieldName: 'isCsvFileIconDisabled'\n\t\t\t\t\t},\n\t\t\t\t\ttype: 'url',\n\t\t\t\t\tfieldName: 'csvFileLink',\n\t\t\t\t\tvariant: 'bare'\n\t\t\t\t},\n\t\t\t\twrapText: true,\n\t\t\t\tcustomLabel: 'CSV_File',\n\t\t\t\thideDefaultActions: true,\n\t\t\t\tinitialWidth: 80\n\t\t\t}\n\t\t]\n\t},\n\tHEADER = {\n\t\tRESULT_VIEWER: {\n\t\t\tlabel: 'Execution Details',\n\t\t\tcustomLabel: 'Execution_Details'\n\t\t},\n\t\tDEPLOYMENT_SUMMARY_VIEWER: {\n\t\t\tlabel: 'Data Deployment Result',\n\t\t\tcustomLabel: 'Data_Deployment_Result'\n\t\t}\n\t},\n\tFILE_NAMES = {\n\t\tRESULT_VIEWER: 'ResultViewer.json',\n\t\tDEPLOYMENT_SUMMARY_JSON: 'deployment_summary.json',\n\t\tDEPLOYMENT_SUMMARY_VIEWER: 'DeploymentSummaryViewer.json'\n\t},\n\tHEADER_ICON = {\n\t\tRESULT_VIEWER: 'standard:note',\n\t\tDEPLOYMENT_SUMMARY_VIEWER: 'standard:picklist_type'\n\t},\n\tCONTINUE_ON_ERROR = {\n\t\tSTOP_DEPLOYMENT_ON_FIRST_ISSUE: 'Stop deployment on first issue'\n\t},\n\tresultViewerJson = [];\n\nlet executionError,\n\ttotalTimeByType = {},\n\tprocesses = new Map();\n\nasync function execute() {\n\ttry {\n\t\tawait this.validateExecutionMode(isTest, isValidation, VALIDATION_MODE_MESSAGE);\n\n\t\tconst dataTemplateJson = this.parseDatatemplate(dataTemplateInfo);\n\t\tconst dataTemplateId = dataTemplateJson.templateId;\n\t\tconst queryFilterList = dataTemplateJson.queryFilterList;\n\t\tconst filterLogic = dataTemplateJson.filterLogic;\n\t\tconst continueOnError = dataTemplateJson.continueOnError;\n\n\t\tconst apiPayload = this.populateCredentialsValues(dataTemplateId, queryFilterList, filterLogic, dataTemplateEnvId);\n\n\t\tconst deploymentId = await this.initiateDataDeployment(apiPayload);\n\t\tawait this.pollDataDeploymentStatus(deploymentId);\n\t\tawait this.downloadDataDeploymentResult(deploymentId);\n\t\tthis.uploadDataDeploymentInfoOnResult(continueOnError);\n\t} catch (err) {\n\t\tconsole.log('Error stack: ', err.stack);\n\t\tif (!(err instanceof CommandExecutionError)) {\n\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, RESULT_INFO.CATEGORY.UNKNOWN_EXCEPTION, `See logs for more info`, err.message);\n\t\t}\n\t\texecutionError = err.message || err?.toString() || `Unknown Error occurred`;\n\t} finally {\n\t\tif (resultViewerJson?.length) {\n\t\t\tthis.uploadResultTableJson(\n\t\t\t\tresultViewerJson,\n\t\t\t\tTABLE_COLUMNS.RESULT_VIEWER,\n\t\t\t\tFILE_NAMES.RESULT_VIEWER,\n\t\t\t\tHEADER.RESULT_VIEWER,\n\t\t\t\tHEADER_ICON.RESULT_VIEWER\n\t\t\t);\n\t\t}\n\t\tif (executionError) {\n\t\t\tawait this.executeCommand(\n\t\t\t\tthis.getErrorCmdString(executionError),\n\t\t\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.POPULATE_INFO_ON_RESULT\n\t\t\t);\n\t\t\tprocess.exit(1);\n\t\t}\n\t}\n}\n\nasync function validateExecutionMode(isTest, isValidation, validationModeMessage) {\n\tconst isValidationDeployment = isValidation === 'true';\n\tif (isTest) {\n\t\treturn isValidationDeployment;\n\t} else if (isValidationDeployment) {\n\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.INFO, RESULT_INFO.CATEGORY.COPADO_INFO, '', validationModeMessage);\n\t\tawait this.executeCommand(\n\t\t\t`copado -p '${validationModeMessage}' --result-data '${validationModeMessage}'`,\n\t\t\tRESULT_INFO.CATEGORY.COPADO_INFO,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.POPULATE_INFO_ON_RESULT\n\t\t);\n\t\tprocess.exit(0);\n\t}\n}\n\nfunction getDataTemplateInfo(dataTemplateId, queryFilterList, filterLogic, dataTemplateEnvId) {\n\tif (!dataTemplateId) {\n\t\tthrow new Error('Data template ID is empty');\n\t}\n\tif (!dataTemplateEnvId) {\n\t\tthrow new Error('Data template environment ID is empty');\n\t}\n\tconst dataTemplate = {\n\t\tdataTemplateId,\n\t\tcopadoOrg: {\n\t\t\torganizationId: dataTemplateEnvId,\n\t\t\tinstance: process.env.CF_SF_ENDPOINT,\n\t\t\ttoken: process.env.CF_SF_SESSIONID\n\t\t},\n\t\tfilterLogic: filterLogic,\n\t\tqueryFilterList: queryFilterList\n\t};\n\treturn dataTemplate;\n}\n\nfunction parseDatatemplate(dataTemplate) {\n\ttry {\n\t\tconst result = JSON.parse(dataTemplate);\n\t\treturn result;\n\t} catch (error) {\n\t\tthis.logger(dataTemplate);\n\t\tthrow new Error('The input data template information is not a valid JSON');\n\t}\n}\n\nfunction setPayloadDataLimit(payload) {\n\tpayload.main_template['limit'] = payload.main_template['limitValue'];\n\tdelete payload.main_template['limitValue'];\n\tpayload.related_templates?.forEach(template => {\n\t\ttemplate['limit'] = template['limitValue'];\n\t\tdelete template['limitValue'];\n\t});\n}\n\nfunction populateCredentialsValues(dataTemplateId, queryFilterList, filterLogic, dataTemplateEnvId) {\n\tconst dataTemplate = this.getDataTemplateInfo(dataTemplateId, queryFilterList, filterLogic, dataTemplateEnvId);\n\n\tconst result = {\n\t\torg_credentials: {\n\t\t\tsource: {\n\t\t\t\torganizationId: sourceOrgId,\n\t\t\t\tinstance: sourceInstanceUrl,\n\t\t\t\ttoken: sourceSessionId\n\t\t\t},\n\t\t\tdestination: {\n\t\t\t\torganizationId: destinationOrgId,\n\t\t\t\tinstance: destinationInstanceUrl,\n\t\t\t\ttoken: destinationSessionId\n\t\t\t}\n\t\t},\n\t\tdataTemplate\n\t};\n\treturn result;\n}\n\nasync function initiateDataDeployment(payload) {\n\tconst result = await this.sendRequest('/ddapi/data_deploy', request.POST, response.TYPE.JSON, payload);\n\t// Added logs to debug in case of unprecedented response from the api\n\tthis.asyncCopadoLogMessage('Initiate Data Deployment');\n\tthis.logger(result);\n\tif (!result?.deploymentId) {\n\t\tthrow new Error(`${result.status} - ${result.errorMessage ? result.errorMessage : result.error}`);\n\t}\n\treturn result.deploymentId;\n}\n\nfunction pollDataDeploymentStatus(deploymentId) {\n\tthis.asyncCopadoLogMessage('Polling data deployment status');\n\treturn new Promise((resolve, reject) => {\n\t\tconst pollDeploymentStatus = setInterval(async () => {\n\t\t\ttry {\n\t\t\t\tconst result = await this.sendRequest(`/ddapi/data_job/${deploymentId}/status`, request.GET, response.TYPE.JSON);\n\t\t\t\t// Adding debug to track progress in logs\n\t\t\t\tswitch (result.status) {\n\t\t\t\t\tcase response.STATUS.FAILED:\n\t\t\t\t\t\tclearInterval(pollDeploymentStatus);\n\t\t\t\t\t\treject(new Error(result.step));\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tcase response.STATUS.COMPLETED:\n\t\t\t\t\t\tthis.asyncCopadoLogMessage(result.step);\n\t\t\t\t\t\tclearInterval(pollDeploymentStatus);\n\t\t\t\t\t\tresolve();\n\t\t\t\t\t\tbreak;\n\t\t\t\t\tdefault:\n\t\t\t\t\t\tthis.asyncCopadoLogMessage(result.step);\n\t\t\t\t}\n\t\t\t} catch (error) {\n\t\t\t\treject(error);\n\t\t\t}\n\t\t}, pollInterval);\n\t});\n}\n\nasync function downloadDataDeploymentResult(deploymentId) {\n\tthis.asyncCopadoLogMessage('Downloading Data Deployment Result');\n\tconst result = await this.sendRequest(`/ddapi/data_job/${deploymentId}/result`, request.GET, response.TYPE.BUFFER);\n\tfs.writeFileSync(RESULT_ZIP_FILE_PATH, result);\n\tawait this.executeCommand(\n\t\t`unzip -d ${DATA_DEPLOYMENT_RESULT_DIR} ${RESULT_ZIP_FILE_PATH}`,\n\t\tRESULT_INFO.CATEGORY.FILE_SYSTEM,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.EXTRACT_DATA_DEPLOYMENT_RESULT\n\t);\n}\n\nasync function sendRequest(path, method, responseType, payload) {\n\tlet result;\n\ttry {\n\t\tconst apiResponse = await fetch(CF_BACKEND_ENDPOINT + path, this.getOptions(method, payload));\n\t\tswitch (responseType) {\n\t\t\tcase response.TYPE.BUFFER:\n\t\t\t\tresult = Buffer.from(await apiResponse.arrayBuffer());\n\t\t\t\tbreak;\n\t\t\tcase response.TYPE.JSON:\n\t\t\t\tresult = await apiResponse.json();\n\t\t\t\tbreak;\n\t\t\tdefault:\n\t\t\t\tresult = await apiResponse.text();\n\t\t}\n\t} catch (error) {\n\t\tthrow new Error(`ERROR: ${method} ${path} : ${error}`);\n\t}\n\treturn result;\n}\n\nfunction getOptions(method, payload) {\n\tconst options = {\n\t\tmethod: method,\n\t\theaders: {\n\t\t\t'Content-Type': 'application/json'\n\t\t}\n\t};\n\tif (method === request.POST) {\n\t\toptions.body = JSON.stringify(payload);\n\t}\n\treturn options;\n}\n\nfunction uploadDataDeploymentInfoOnResult(continueOnError) {\n\tthis.asyncCopadoLogMessage('Uploading data deployment detail files on the result record');\n\n\tfs.readdirSync(DATA_DEPLOYMENT_RESULT_DIR, { encoding: 'utf-8',recursive: true })?.forEach(file => {\n\t\tconst fullPath = `${DATA_DEPLOYMENT_RESULT_DIR}/${file}`;\n\t\tif(!fs.statSync(fullPath).isFile()){\n\t\t\treturn\n\t\t}\n\t\tconst safeName = file.replace(/[/\\\\]/g, '_').replace(/['\"$]/g, ''); \n\t\tthis.populateResultViewer(\n\t\t\tRESULT_INFO.LEVEL.INFO,\n\t\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.UPLOAD_FILES,\n\t\t\tfullPath\n\t\t);\n\t\tthis.executeCommand(`copado --uploadfile '${fullPath.replace(/'/g,\"'\\\\''\")}' --name '${safeName}'`);\n\t});\n\n\tconst deploymentSummary = this.getDeploymentSummary(`${DATA_DEPLOYMENT_RESULT_DIR}/${FILE_NAMES.DEPLOYMENT_SUMMARY_JSON}`);\n\n\tthis.uploadResultTableJson(\n\t\tdeploymentSummary,\n\t\tTABLE_COLUMNS.DEPLOYMENT_SUMMARY_VIEWER,\n\t\tFILE_NAMES.DEPLOYMENT_SUMMARY_VIEWER,\n\t\tHEADER.DEPLOYMENT_SUMMARY_VIEWER,\n\t\tHEADER_ICON.DEPLOYMENT_SUMMARY_VIEWER\n\t);\n\n\tconst resultData = this.getResultData(deploymentSummary);\n\tif (resultData) {\n\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.INFO, RESULT_INFO.CATEGORY.COPADO_SERVICE, 'Updating Data deployment info', resultData);\n\t\tthis.executeCommand(\n\t\t\t`copado -p 'Updating Data deployment info' -r '${resultData}'`,\n\t\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.POPULATE_INFO_ON_RESULT\n\t\t);\n\t}\n\n\tif (continueOnError == CONTINUE_ON_ERROR.STOP_DEPLOYMENT_ON_FIRST_ISSUE) {\n\t\tcheckDeploymentSummary(deploymentSummary);\n\t}\n}\n\nfunction checkDeploymentSummary(deploymentSummary) {\n\tif (deploymentSummary?.length > 0) {\n\t\tdeploymentSummary.forEach(result => {\n\t\t\tif (result.failedRecords > 0) {\n\t\t\t\tthrow new Error('Some deployed records failed. Find more information in result files');\n\t\t\t}\n\t\t})\n\t}\n}\n\nfunction getDeploymentSummary(filePath) {\n\tlet result = '';\n\tif (fs.existsSync(filePath)) {\n\t\tconst fileData = fs.readFileSync(filePath, 'utf-8');\n\t\tif (fileData) {\n\t\t\tresult = JSON.parse(fileData);\n\t\t}\n\t}\n\treturn result;\n}\nfunction getResultData(deploymentSummary) {\n\tlet result = '';\n\tif (deploymentSummary) {\n\t\tresult = deploymentSummary\n\t\t\t.map(templateDeploymentResult =>\n\t\t\t\tObject.keys(templateDeploymentResult)\n\t\t\t\t\t.map(key => `${key} : ${templateDeploymentResult[key]}`)\n\t\t\t\t\t.join('\\n')\n\t\t\t)\n\t\t\t.join('\\n------------------------\\n');\n\t\tresult =\n\t\t\t'To find more info related to the data deployment result, please look at the deployment_summary.json attached to this result record\\n' +\n\t\t\tresult;\n\t}\n\treturn result?.substring(0, 131070); // truncating the string to prevent the length from exceeding Long Text Area(131072) size limit\n}\n\nfunction getErrorCmdString(error) {\n\tconst suffix = 'Please check the logs for details.';\n\treturn `copado -p 'Error' -e \"${error?.substring(0, 32765)}. ${suffix}\"`;\n}\n\nfunction getPath(filePath) {\n\treturn isTest ? `${__dirname}/__tests__/__mockDir__${filePath}` : filePath;\n}\n\nfunction executeCommand(command, category, additionalInfo, disableMetrics, hasJsonResponse, disableLogs, options) {\n\tthis.logger(`===> ${command}`);\n\treturn new Promise((resolve, reject) => {\n\t\tlet output = '',\n\t\t\terror = '';\n\t\tif (!disableMetrics) {\n\t\t\tthis.startWatch(category, additionalInfo, processes);\n\t\t}\n\t\tconst childProcess = child_process.spawn(command, [], options ? options : { shell: true });\n\n\t\tchildProcess.stdout.on('data', data => {\n\t\t\tconst outputStream = data?.toString();\n\t\t\tif (!disableLogs && outputStream) {\n\t\t\t\tthis.logger(outputStream);\n\t\t\t}\n\t\t\toutput += outputStream;\n\t\t});\n\n\t\tchildProcess.stderr.on('data', data => {\n\t\t\tconst errorStream = data?.toString();\n\t\t\tif (errorStream) {\n\t\t\t\tthis.logger(errorStream);\n\t\t\t\terror += errorStream;\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.on('close', code => {\n\t\t\tif (code !== 0) {\n\t\t\t\tlet errorMessage = '';\n\t\t\t\tif (hasJsonResponse) {\n\t\t\t\t\ttry {\n\t\t\t\t\t\tresolve(JSON.parse(output));\n\t\t\t\t\t} catch (error) {\n\t\t\t\t\t\terrorMessage = error;\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\terrorMessage = error;\n\t\t\t\t}\n\t\t\t\terrorMessage = errorMessage ? errorMessage : `Error executing the command ${command.trim()}`;\n\n\t\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, category, additionalInfo, errorMessage);\n\t\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\t\terrorMessage\n\t\t\t\t\t\t.split('\\n')\n\t\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t\t.join(' ')\n\t\t\t\t);\n\t\t\t\treject(new CommandExecutionError(truncatedError, category, additionalInfo));\n\t\t\t}\n\t\t\tresolve(hasJsonResponse ? JSON.parse(output) : output);\n\t\t\tif (!disableMetrics) {\n\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.on('error', error => {\n\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, category, additionalInfo, error);\n\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\terror\n\t\t\t\t\t.split('\\n')\n\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t.join(' ')\n\t\t\t);\n\t\t\treject(new CommandExecutionError(truncatedError, category, additionalInfo));\n\t\t\tif (!disableMetrics) {\n\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t}\n\t\t});\n\t});\n}\n\nfunction startWatch(processType, processName, processes) {\n\tif (!processName || !processType) {\n\t\treturn;\n\t}\n\tconst startTime = process.hrtime();\n\tif (!totalTimeByType[processType]) {\n\t\ttotalTimeByType[processType] = 0;\n\t}\n\tprocesses.set(processName, { name: processName, type: processType, startTime, endTime: null, elapsedTime: null });\n}\n\nfunction endWatch(processName, processes) {\n\tif (!processName) {\n\t\treturn;\n\t}\n\n\tif (!processes.has(processName)) {\n\t\t// we call endWatch in sync with startwatch for same process & doesnt overlap with others endWatch. additionally checking that it belongs to the same processType in the processes index before we store it.\n\t\tconsole.error(`Process '${processName}' not started.`);\n\t\treturn;\n\t}\n\tconst processEntry = processes.get(processName);\n\tconst endTime = process.hrtime();\n\tconst elapsedTime = process.hrtime(processEntry.startTime);\n\tprocessEntry.endTime = endTime;\n\tprocessEntry.elapsedTime = elapsedTime[0] * 1e9 + elapsedTime[1];\n\tprocesses.set(processName, processEntry);\n}\n\nfunction log(response) {\n\tconst outputStream = response?.stdout?.toString().trim();\n\tconst errorStream = response?.stderr?.toString().trim();\n\tif (outputStream) {\n\t\tthis.logger(outputStream);\n\t}\n\tif (errorStream) {\n\t\tthis.logger(errorStream);\n\t}\n\treturn { outputStream, errorStream };\n}\n\nfunction asyncCopadoLogMessage(msg, level) {\n\tthis.populateResultViewer(level ? level : RESULT_INFO.LEVEL.INFO, RESULT_INFO.CATEGORY.COPADO_INFO, '', msg);\n\t\n    this.executeCommand(`copado -p \"${msg}\"`, RESULT_INFO.CATEGORY.COPADO_SERVICE);\n}\n\nfunction populateResultViewer(level, category, additionalInfo, message) {\n\tresultViewerJson.push({\n\t\tLevel: level,\n\t\tCategory: category,\n\t\tMessage: message,\n\t\tAdditionalInformation: additionalInfo\n\t});\n}\n\nfunction uploadResultTableJson(data, columns, fileName, header, headerIcon) {\n\tconst RESULT_VIEWER_JSON_PATH = `${TEMP_DIRECTORY}/${fileName}`;\n\n\tconst fileContent = {\n\t\tdata,\n\t\tcolumns,\n\t\theader,\n\t\theaderIcon\n\t};\n\tfs.writeFileSync(RESULT_VIEWER_JSON_PATH, JSON.stringify(fileContent, null, 2));\n\tthis.uploadFileAtPath(RESULT_VIEWER_JSON_PATH);\n}\n\nfunction uploadFileAtPath(filePath) {\n\tnew Promise((resolve, reject) => {\n\t\tchild_process.exec(`copado --uploadfile ${filePath}`, {}, (error, stdout, stderr) => {\n\t\t\tif (error?.code) {\n\t\t\t\tconst errorResponse = stderr ? stderr : `Error executing the command : ${error?.cmd}`;\n\t\t\t\tthis.populateResultViewer(\n\t\t\t\t\tRESULT_INFO.LEVEL.ERROR,\n\t\t\t\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\t\t\t\t`Uploading file at ${filePath}`,\n\t\t\t\t\terrorResponse\n\t\t\t\t);\n\t\t\t\treject(new CommandExecutionError(errorResponse));\n\t\t\t} else {\n\t\t\t\tresolve();\n\t\t\t}\n\t\t});\n\t});\n}\n\nfunction logger(value) {\n\tconsole.log(value);\n}\n\nclass CommandExecutionError extends Error {\n\tconstructor(message) {\n\t\tsuper(message);\n\t\tthis.name = CUSTOM_ERROR.COMMAND_EXECUTION_ERROR;\n\t}\n}\n\nmodule.exports.initiateDataDeployment = initiateDataDeployment;\nmodule.exports.pollDataDeploymentStatus = pollDataDeploymentStatus;\nmodule.exports.populateCredentialsValues = populateCredentialsValues;\nmodule.exports.downloadDataDeploymentResult = downloadDataDeploymentResult;\nmodule.exports.sendRequest = sendRequest;\nmodule.exports.getOptions = getOptions;\nmodule.exports.uploadDataDeploymentInfoOnResult = uploadDataDeploymentInfoOnResult;\nmodule.exports.getErrorCmdString = getErrorCmdString;\nmodule.exports.getPath = getPath;\nmodule.exports.executeCommand = executeCommand;\nmodule.exports.log = log;\nmodule.exports.execute = execute;\nmodule.exports.startWatch = startWatch;\nmodule.exports.endWatch = endWatch;\nmodule.exports.getResultData = getResultData;\nmodule.exports.parseDatatemplate = parseDatatemplate;\nmodule.exports.validateExecutionMode = validateExecutionMode;\nmodule.exports.setPayloadDataLimit = setPayloadDataLimit;\nmodule.exports.logger = logger;\nmodule.exports.asyncCopadoLogMessage = asyncCopadoLogMessage;\nmodule.exports.populateResultViewer = populateResultViewer;\nmodule.exports.uploadResultTableJson = uploadResultTableJson;\nmodule.exports.getDeploymentSummary = getDeploymentSummary;\nmodule.exports.uploadFileAtPath = uploadFileAtPath;\nmodule.exports.getDataTemplateInfo = getDataTemplateInfo;\nmodule.exports.checkDeploymentSummary = checkDeploymentSummary;\nmodule.exports.CommandExecutionError = CommandExecutionError;\n\n!isTest && this.execute();",
                    "copado__Type__c": "Standard",
                    "copado__Worker_Size__c": "S",
                    "Id": "a0l7Q000000OyrMQAS",
                    "LastReferencedDate": "2023-06-06T04:39:46.000+0000",
                    "LastViewedDate": "2023-06-06T04:39:46.000+0000",
                    "Name": "SFDX Data Deploy"
                },
                {
                    "attributes": {
                        "type": "copado__Function__c",
                        "url": "/services/data/v58.0/sobjects/copado__Function__c/a0l7Q00000DF2LhQAL"
                    },
                    "copado__API_Name__c": "sfdx_git_snapshot",
                    "copado__Image_Name__c": "copado-multicloud-dx:v6",
                    "copado__Options__c": "[ ]",
                    "copado__Parameters__c": "[ {\n  \"required\" : true,\n  \"name\" : \"git_json\",\n  \"defaultValue\" : \"{$Context.Repository.Credential}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"gitName\",\n  \"defaultValue\" : \"{$User.Name}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"gitEmail\",\n  \"defaultValue\" : \"{$User.Email}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"sourceEndpoint\",\n  \"defaultValue\" : \"{$Source.Credential.Endpoint}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"sourceSessionId\",\n  \"defaultValue\" : \"{$Source.Credential.SessionId}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"branch\",\n  \"defaultValue\" : \"{$Job.ExecutionParent.copado__Branch__c}\"\n}, {\n  \"name\" : \"selectedMetadata\",\n  \"defaultValue\" : \"{$Job.ExecutionParent.copado__Scope__c}\"\n}, {\n  \"name\" : \"snapshotInformation\",\n  \"defaultValue\" : \"{$Job.ExecutionParent.copado__Other_Information__c}\"\n}, {\n  \"required\" : false,\n  \"name\" : \"metadataRefreshResult\",\n  \"defaultValue\" : \"{$Job.PrevStep.Result__r.Result_Data__c}\"\n}, {\n  \"name\" : \"overriddenApiVersion\",\n  \"defaultValue\" : \"\"\n}, {\n  \"required\" : true,\n  \"name\" : \"maximumRetryCount\",\n  \"defaultValue\" : \"1\"\n}, {\n  \"required\" : true,\n  \"name\" : \"commitMessage\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.message}\"\n}, {\n  \"required\" : false,\n  \"name\" : \"processesUsedForRetrieval\",\n  \"defaultValue\" : \"{$Pipeline.Property.sfdx_git_snapshot_processesUsedForRetrieval}\"\n}, {\n  \"name\" : \"environmentVariables\",\n  \"defaultValue\" : \"{$Source.apex.EnvironmentVariables}\"\n}, {\n  \"name\" : \"findAndReplaceFileId\",\n  \"defaultValue\" : \"{$Context.apex.GlobalFindAndReplaceSourceId}\"\n}, {\n  \"required\" : false,\n  \"name\" : \"metadataChunkInfo\",\n  \"defaultValue\" : \"{$Pipeline.Property.sfdx_git_snapshot_metadataChunkInfo}\"\n}, {\n  \"name\" : \"vlocityFolder\",\n  \"defaultValue\" : \"vlocity\"\n}, {\n  \"required\" : true,\n  \"name\" : \"repositoryId\",\n  \"defaultValue\" : \"{$Job.ExecutionParent.copado__Git_Repository__r.Id}\"\n} ]",
                    "copado__Script__c": "#!/usr/bin/env node\n'use strict';\n\n/**\n * This function takes a snapshot of the salesforce org and pushes its content in git\n * @param gitName,\n * @param gitEmail,\n * @param sourceEndpoint,\n * @param sourceSessionId,\n * @param branch,\n * @param selectedMetadata,\n * @param snapshotInformation,\n * @param metadataRefreshResult,\n * @param maximumRetryCount,\n * @param processesUsedForRetrieval,\n * @param commitMessage,\n * @param environmentVariables,\n * @param overriddenApiVersion,\n * @param findAndReplaceFileId,\n * @param maxBuffer,\n * @param API_VERSION\n */\n\nconst child_process = require('child_process'),\n\t{ parse } = require('path'),\n\t{\n\t\tisTest,\n\t\tgitName,\n\t\tgitEmail,\n\t\tsourceEndpoint,\n\t\tsourceSessionId,\n\t\tbranch,\n\t\tselectedMetadata,\n\t\tsnapshotInformation,\n\t\tmetadataRefreshResult,\n\t\tmaximumRetryCount,\n\t\tprocessesUsedForRetrieval,\n\t\tcommitMessage,\n\t\tenvironmentVariables,\n\t\toverriddenApiVersion,\n\t\tfindAndReplaceFileId,\n\t\tAPI_VERSION,\n\t\tmetadataChunkInfo,\n\t\tvlocityFolder\n\t} = process.env,\n\t{ Ux } = isTest ? require('@salesforce/sf-plugins-core') : require('/usr/local/lib/node_modules/@salesforce/sf-plugins-core'),\n\t{ spawn } = require('child_process'),\n\t{ cpus } = require('os'),\n\t{ Retriever, CopaReconcilerInput, Operation } = isTest\n\t\t? require('../common/__mocks__/modules/copado-metadata-reconciler')\n\t\t: require('/usr/local/lib/node_modules/@mcdx/copado-metadata-reconciler'),\n\tCOPADO_INFO_PREFIX = 'CopadoFunction INFO',\n\tAPP_DIRECTORY = getPath('/app'),\n\tTEMP_DIRECTORY = getPath('/tmp'),\n\tTARGET_DIRECTORY = `${APP_DIRECTORY}/repository`,\n\t{ existsSync, writeFileSync, readFileSync, mkdirSync, readdirSync } = require('fs'),\n\tCREDENTIAL_FILE_NAME = 'MetaData',\n\tPROFILE = 'Profile',\n\tretryLimit = parseInt(maximumRetryCount) ? parseInt(maximumRetryCount) : 1,\n\tmaxAllowedProcesses = parseInt(processesUsedForRetrieval) ? parseInt(processesUsedForRetrieval) : 8,\n\tadditionalInfoForSnapshot = snapshotInformation ? getParsedData(snapshotInformation) : {},\n\tnestedMetadataToBeBypassed = [\n\t\t'workflowfieldupdate',\n\t\t'workflowknowledgepublish',\n\t\t'workflowtask',\n\t\t'workflowalert',\n\t\t'workflowsend',\n\t\t'workflowoutboundmessage',\n\t\t'workflowflowautomation',\n\t\t'workflowrule',\n\t\t'sharingownerrule',\n\t\t'sharingcriteriarule',\n\t\t'sharingguestrule',\n\t\t'sharingterritoryrule',\n\t\t'assignmentrule',\n\t\t'autoresponserule',\n\t\t'matchingrule',\n\t\t'customfield',\n\t\t'index',\n\t\t'businessprocess',\n\t\t'recordtype',\n\t\t'compactlayout',\n\t\t'weblink',\n\t\t'validationrule',\n\t\t'sharingreason',\n\t\t'listview',\n\t\t'fieldset'\n\t],\n\tignoredMetadata = ['document', 'documentfolder', 'customlabels'],\n\tmetadataChunkSize = metadataChunkInfo ? getParsedData(metadataChunkInfo) : {},\n\tdefaultMetadataChunkSize = metadataChunkSize?.defaultMetadataChunkInfo ? metadataChunkSize?.defaultMetadataChunkInfo : 5000,\n\tfolderedMetadataToBeBypassed = ['reportfolder', 'dashboardfolder', 'emailtemplatefolder', 'emailfolder'],\n\tfolderedMetadata = ['report', 'dashboard', 'emailtemplate'],\n\tdirectoryByMetadataType = new Map([\n\t\t[\n\t\t\t'customlabel',\n\t\t\t{\n\t\t\t\troot: process.env.CUSTOM_LABEL_RETRIEVE_REPOSITORY_PATH,\n\t\t\t\toutputDirectory: 'copadoLabels{0}/main/default/',\n\t\t\t\tsuffix: 0,\n\t\t\t\trelativeFilePath: 'labels/CustomLabels.labels-meta.xml'\n\t\t\t}\n\t\t]\n\t]),\n\tmetadatasInNonPackageDirectoryByType = new Map(),\n\tdefaultMetadataChunkSizeMap = {\n\t\tstaticresource: 10,\n\t\tcontentasset: 10,\n\t\tlightningcomponentbundle: 500,\n\t\tauradefinitionbundle: 500,\n\t\texperiencebundle: 200,\n\t\tcustomlabel: 999\n\t},\n\t// Translation-related metadata type constants\n\tTRANSLATION_METADATA_TYPES = {\n\t\tTRANSLATIONS: 'translations',\n\t\tCUSTOM_OBJECT: 'customobject',\n\t\tCUSTOM_OBJECT_TRANSLATION: 'customobjecttranslation',\n\t\tCUSTOM_FIELD_TRANSLATION: 'customfieldtranslation'\n\t},\n\tTRANSLATION_METADATA_API_TYPES = {\n\t\t[TRANSLATION_METADATA_TYPES.CUSTOM_OBJECT]: 'CustomObject',\n\t\t[TRANSLATION_METADATA_TYPES.CUSTOM_OBJECT_TRANSLATION]: 'CustomObjectTranslation',\n\t\t[TRANSLATION_METADATA_TYPES.CUSTOM_FIELD_TRANSLATION]: 'CustomFieldTranslation',\n\t\t[TRANSLATION_METADATA_TYPES.TRANSLATIONS]: 'Translations'\n\t},\n\t// Metadata types that have translatable content under the Translations metadata type\n\tMETADATA_TYPES_WITH_TRANSLATIONS = new Set([\n\t\t'bot',\n\t\t'botblock',\n\t\t'bottemplate',\n\t\t'conversationmessagedefinition',\n\t\t'customapplication',\n\t\t'customtab',\n\t\t'custompageweblink',\n\t\t'customlabel',\n\t\t'explainabilitymsgtemplate',\n\t\t'flowdefinition',\n\t\t'reporttype',\n\t\t'pipelineinspmetricconfig',\n\t\t'productspecificationtypedefinition',\n\t\t'serviceprocess',\n\t\t'recordalertcategory',\n\t\t'globalvalueset',\n\t\t'standardvalueset',\n\t\t'quickaction',\n\t\t'prompt',\n\t\t'scontrol'\n\t]),\n\tRESULT_INFO = {\n\t\tCATEGORY: {\n\t\t\tGIT_SERVICE: 'Git Service',\n\t\t\tSFDX_CLI: 'SFDX CLI',\n\t\t\tMETADATA_EXECUTION: 'Metadata Validation',\n\t\t\tFILE_SYSTEM: 'File System'\n\t\t},\n\t\tADDITIONAL_INFORMATION: {\n\t\t\tGIT_COMMIT: 'Git Commit',\n\t\t\tGIT_CONFIG: 'Git Configuration',\n\t\t\tSFDX_CONFIG: 'SFDX Configuration',\n\t\t\tENRICHER_SERVICE: 'Enricher Service',\n\t\t\tMETADATA_PROCESSOR: 'Metadata Processor',\n\t\t\tGLOBAL_FIND_AND_REPLACE: 'Global Find and Replace',\n\t\t\tUPLOAD_FILES: 'Upload Files',\n\t\t\tGIT_PUSH: 'Git Push',\n\t\t\tDOWNLOAD_FILES: 'Download Files',\n\t\t\tMETADATA_RETRIEVAL: 'Metadata Retrieval',\n\t\t\tMETADATA_SELECTION: 'Metadata Selection',\n\t\t\tMETADATA_VALIDATION: 'Metadata Validation',\n\t\t\tDIRECTORY_CONFIGURATION: 'Directory Configuration'\n\t\t}\n\t};\nlet apiVersion,\n\terrorMessage,\n\ttotalTimeByType = {},\n\tprocesses = [],\n\tdefaultPackageDirectoryPath = 'force-app';\n\n// SCRIPT FUNCTIONS\n\nasync function execute() {\n\ttry {\n\t\tthis.asyncCopadoLogMessage(`Configured processes to be used for retrieval : ${maxAllowedProcesses}`);\n\t\tthis.asyncCopadoLogMessage(`Default Metadata chunk size : ${defaultMetadataChunkSize}`);\n\t\tapiVersion = await this.getApiVersion(overriddenApiVersion, API_VERSION);\n\t\tthis.asyncCopadoLogMessage('Downloading metadata details of the source environment');\n\t\tthis.startWatch(RESULT_INFO.CATEGORY.SFDX_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.METADATA_VALIDATION, processes);\n\t\tconst selectedMetadatas = await this.getSelectedMetadatas(selectedMetadata);\n\t\tconst nestedMetadataInSnapshotScope = this.getNestedMetadataInSnasphotScope(selectedMetadatas, nestedMetadataToBeBypassed);\n\t\tif (nestedMetadataInSnapshotScope.length) {\n\t\t\tthis.logger(\n\t\t\t\t`These nested metadata ${nestedMetadataInSnapshotScope.toString()} will be skipped in the snapshot, in order to retrieve them correctly please be sure their parents are in the snapshot scope.`\n\t\t\t);\n\t\t}\n\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.METADATA_VALIDATION, processes);\n\t\tlet metadatas, profiles, metadataNamesByType;\n\t\tif (selectedMetadatas.length) {\n\t\t\tthis.startWatch(RESULT_INFO.CATEGORY.SFDX_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.METADATA_SELECTION, processes);\n\t\t\tmetadataNamesByType = await this.getMetadataNamesByType(metadataRefreshResult, TEMP_DIRECTORY, CREDENTIAL_FILE_NAME);\n\t\t\tprofiles = this.getProfilesForRetrieval(\n\t\t\t\tmetadataNamesByType,\n\t\t\t\tselectedMetadatas,\n\t\t\t\tPROFILE,\n\t\t\t\tapiVersion,\n\t\t\t\tignoredMetadata,\n\t\t\t\tnestedMetadataToBeBypassed\n\t\t\t);\n\t\t\tmetadatas = this.getMetadataItemsForRetrieval(\n\t\t\t\tmetadataNamesByType,\n\t\t\t\tselectedMetadatas,\n\t\t\t\tapiVersion,\n\t\t\t\tTEMP_DIRECTORY,\n\t\t\t\tignoredMetadata,\n\t\t\t\tmetadataChunkSize,\n\t\t\t\tdefaultMetadataChunkSize,\n\t\t\t\tnestedMetadataToBeBypassed\n\t\t\t);\n\t\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.METADATA_RETRIEVAL, processes);\n\t\t\tif (!profiles.length && !metadatas.length) {\n\t\t\t\tawait this.exitProcess('No metadata available for snapshot');\n\t\t\t}\n\t\t}\n\t\tthis.asyncCopadoLogMessage('Setting up working directory');\n\t\tthis.startWatch(RESULT_INFO.CATEGORY.SFDX_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.DIRECTORY_CONFIGURATION, processes);\n\t\tawait this.setUpWorkingDirectory(TARGET_DIRECTORY);\n\t\tawait this.createSFProjectInNonPackageRetrievePaths(API_VERSION);\n\t\tawait this.switchToWorkingDirectory(TARGET_DIRECTORY);\n\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.DIRECTORY_CONFIGURATION, processes);\n\t\tthis.asyncCopadoLogMessage('Fetching remote branch');\n\t\tthis.startWatch(RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CONFIG, processes);\n\t\tawait this.fetchRemoteGitBranch(branch);\n\t\tawait this.copyVlocityFiles(`${APP_DIRECTORY}/${vlocityFolder}`, TARGET_DIRECTORY);\n\t\tconst previousCommitId = await this.getCommitId();\n\t\tawait this.configureGit(gitEmail, gitName);\n\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CONFIG, processes);\n\n\t\tlet errorsMsg;\n\t\tif (selectedMetadatas.length) {\n\t\t\tthis.startWatch(RESULT_INFO.CATEGORY.SFDX_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.SFDX_CONFIG, processes);\n\t\t\tawait this.updateSourceApiVersion(`${TARGET_DIRECTORY}/sfdx-project.json`, apiVersion);\n\t\t\tthis.createDefaultDirectory();\n\t\t\tawait this.configureSFDXCli(apiVersion, sourceEndpoint, sourceSessionId);\n\t\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.SFDX_CONFIG, processes);\n\t\t\tawait this.disableSourceTracking();\n\t\t\tconst processUsedForRetrieval = this.getMaxAllowedProcesses(maxAllowedProcesses);\n\t\t\tconst retrieveResult = await this.runMetadataRetrieval(processUsedForRetrieval, metadatas, profiles, TEMP_DIRECTORY);\n\t\t\terrorsMsg = retrieveResult.errors;\n\t\t\twriteMergedTranslationFiles(retrieveResult.mergedTranslations);\n\t\t}\n\n\t\tawait this.copyFilesToTargetDirectory();\n\n\t\tawait this.runVarReplace(additionalInfoForSnapshot, environmentVariables, TARGET_DIRECTORY);\n\t\tawait this.runFindAndReplace(additionalInfoForSnapshot, findAndReplaceFileId, branch, TEMP_DIRECTORY, TARGET_DIRECTORY, 'Copado');\n\t\tawait this.pushChangesToRemoteBranch(branch, commitMessage);\n\t\tconst newCommitId = await this.getCommitId();\n\t\tif (newCommitId !== previousCommitId) {\n\t\t\tawait this.updateResultStatus(errorsMsg, newCommitId);\n\t\t} else {\n\t\t\tawait this.updateResultStatus(errorsMsg, undefined, 'No changes');\n\t\t}\n\t} catch (error) {\n\t\tif (error?.stack) {\n\t\t\tthis.logger(`Error stack: ${error.stack}`);\n\t\t}\n\t\terrorMessage = error.message || error?.toString() || 'Unknown Error occurred';\n\t} finally {\n\t\tif (errorMessage) {\n\t\t\tawait this.executeCommand(this.getErrorCommand(errorMessage));\n\t\t}\n\t\tthis.printMetrics();\n\t\tif (errorMessage) {\n\t\t\tprocess.exit(1);\n\t\t}\n\t}\n}\n\nfunction asyncCopadoLogMessage(msg) {\n\tthis.executeCommand(`copado -p '${msg}'`);\n}\n\nfunction getPath(filePath) {\n\treturn isTest ? `${__dirname}/__tests__/__mockDirectory__${filePath}` : filePath;\n}\n\nasync function getApiVersion(overriddenApiVersion, apiVersion) {\n\tconst finalApiVersion = overriddenApiVersion || apiVersion;\n\tconst regExpApiVersion = /\\d\\d\\.0/;\n\tif (!regExpApiVersion.test(finalApiVersion)) {\n\t\tawait this.executeCommand(this.getErrorCommand(`Invalid API Version: ${finalApiVersion}`));\n\t}\n\treturn finalApiVersion;\n}\n\nasync function getSelectedMetadatas(selectedMetadata) {\n\tlet result;\n\ttry {\n\t\tconst selection = JSON.parse(selectedMetadata);\n\t\tresult = selection?.SFDX?.included?.map(element => element.toLowerCase());\n\t\tif (!result) {\n\t\t\tconst message = JSON.stringify('Snapshot does not contain any Salesforce Metadata');\n\t\t\tawait this.executeCommand(`copado -p ${message}`);\n\t\t}\n\t} catch (error) {\n\t\tresult = selectedMetadata.split(';').map(element => element.toLowerCase());\n\t}\n\treturn result?.length ? result : [];\n}\n\nfunction getParsedData(data) {\n\tlet result = {};\n\ttry {\n\t\tresult = JSON.parse(data);\n\t} catch (error) {\n\t\tlogger(`Error occurred while parsing data : ${error}`);\n\t}\n\treturn result;\n}\n\nasync function copyVlocityFiles(source, target) {\n\tif (existsSync(`${APP_DIRECTORY}/${vlocityFolder}`)) {\n\t\tawait this.executeCommand(`\n                cp -R ${source} ${target}\n        `);\n\t}\n}\n\nasync function getMetadataNamesByType(metadataRefreshResult, downloadDirectory, fileName) {\n\tconst result = new Map();\n\tlet fileDetails;\n\ttry {\n\t\tfileDetails = JSON.parse(metadataRefreshResult);\n\t} catch (error) {\n\t\tthrow 'Failure while parsing the metadata refresh resul';\n\t}\n\tif (!fileDetails.contentVersionId) {\n\t\tthrow 'Content version id missing from the metadata refresh job step';\n\t}\n\tawait this.executeCommand(`\n        copado --downloadfiles '${fileDetails.contentVersionId}' --downloaddir '${downloadDirectory}'\n    `);\n\tconst metadatas = this.getMetaDataFileContent(downloadDirectory, fileName);\n\tmetadatas.forEach(metadata => {\n\t\t// In the below condition we want to make sure that we do not retrieve\n\t\t// the vlocity and managed packaged static resources in the snapshot process\n\t\tif (!metadata.vk && !(metadata.t?.toLowerCase() === 'staticresource' && metadata.n?.includes('__'))) {\n\t\t\tif (result.has(metadata.t)) {\n\t\t\t\tresult.get(metadata.t)?.push(metadata.n);\n\t\t\t} else {\n\t\t\t\tresult.set(metadata.t, [metadata.n]);\n\t\t\t}\n\t\t}\n\t});\n\treturn result;\n}\n\nfunction getMetaDataFileContent(downloadDirectory, fileName) {\n\tconst file = `${downloadDirectory}/${fileName}`;\n\tif (!existsSync(file)) {\n\t\tthrow `Error fetching ${fileName} file`;\n\t}\n\treturn JSON.parse(readFileSync(`${file}`, 'utf-8'));\n}\n\nfunction isValidMetadata(ignoredMetadata, metadata, selectedMetadatas, nestedMetadataToBeBypassed) {\n\tconst metadataName = metadata?.toLowerCase();\n\tconst result =\n\t\t!ignoredMetadata.includes(metadataName) &&\n\t\t!nestedMetadataToBeBypassed.includes(metadataName) &&\n\t\t!folderedMetadataToBeBypassed.includes(metadataName) &&\n\t\t(!selectedMetadatas.length || selectedMetadatas.includes(metadataName));\n\treturn result;\n}\n\nfunction getProfilesForRetrieval(metadataNamesByType, selectedMetadatas, profileMetadata, apiVersion, ignoredMetadata, nestedMetadataToBeBypassed) {\n\tlet result = [];\n\tif (\n\t\tmetadataNamesByType.has(profileMetadata) &&\n\t\tthis.isValidMetadata(ignoredMetadata, profileMetadata, selectedMetadatas, nestedMetadataToBeBypassed)\n\t) {\n\t\tconst profileNames = metadataNamesByType.get(profileMetadata);\n\t\tmetadataNamesByType.delete(profileMetadata);\n\t\tresult = [\n\t\t\t...result,\n\t\t\t...this.getMetadataItemForRetrieval(profileNames, profileMetadata, profileNames.length, apiVersion, undefined, selectedMetadatas)\n\t\t];\n\t}\n\treturn result;\n}\n\nfunction getMetadataItemForRetrieval(metadataNames, metadataType, maxAllowedItemsPerType, apiVersion, directory, selectedMetadatas) {\n\tlet result = [];\n\tif (!folderedMetadata.includes(metadataType.toLowerCase())) {\n\t\tconst metadatas = [];\n\t\twhile (metadataNames.length > maxAllowedItemsPerType) {\n\t\t\tmetadatas.push(metadataNames.splice(0, maxAllowedItemsPerType));\n\t\t}\n\t\tmetadatas.push(metadataNames);\n\t\tmetadatas.forEach(metadata => {\n\t\t\tresult.push({\n\t\t\t\tmetadataType,\n\t\t\t\tmetadataNames: metadata,\n\t\t\t\tretryCount: 0,\n\t\t\t\tmanifestFilePath:\n\t\t\t\t\tmetadataType.toLowerCase() === 'profile'\n\t\t\t\t\t\t? ''\n\t\t\t\t\t\t: getPackageXMLfilePath(metadata, metadataType, apiVersion, directory, selectedMetadatas),\n\t\t\t\toutputDirectory: this.getOutputDirectory(metadataType.toLowerCase()),\n\t\t\t\troot: directoryByMetadataType.has(metadataType.toLowerCase())\n\t\t\t\t\t? directoryByMetadataType.get(metadataType.toLowerCase()).root\n\t\t\t\t\t: undefined,\n\t\t\t\trelativeFilePath: directoryByMetadataType.has(metadataType.toLowerCase())\n\t\t\t\t\t? directoryByMetadataType.get(metadataType.toLowerCase()).relativeFilePath\n\t\t\t\t\t: undefined\n\t\t\t});\n\t\t});\n\t} else {\n\t\tresult = this.getMetadataItemForFolderedMetadata(\n\t\t\tmetadataNames,\n\t\t\tmetadataType,\n\t\t\tmaxAllowedItemsPerType,\n\t\t\tapiVersion,\n\t\t\tdirectory,\n\t\t\tselectedMetadatas\n\t\t);\n\t}\n\treturn result;\n}\n\nfunction getMetadataItemsForRetrieval(\n\tmetadataNamesByType,\n\tselectedMetadatas,\n\tapiVersion,\n\tdirectory,\n\tignoredMetadata,\n\tmetadataChunkSize,\n\tdefaultMetadataChunkSize,\n\tnestedMetadataToBeBypassed\n) {\n\tlet result = [];\n\tfor (const [metadataType, metadataNames] of metadataNamesByType.entries()) {\n\t\tconst metadataTypeLower = metadataType?.toLowerCase();\n\t\t// Do not create standalone chunks for:\n\t\tif (\n\t\t\tmetadataTypeLower === TRANSLATION_METADATA_TYPES.TRANSLATIONS ||\n\t\t\tmetadataTypeLower === TRANSLATION_METADATA_TYPES.CUSTOM_OBJECT_TRANSLATION ||\n\t\t\tmetadataTypeLower === TRANSLATION_METADATA_TYPES.CUSTOM_FIELD_TRANSLATION\n\t\t) {\n\t\t\tcontinue;\n\t\t}\n\t\tif (this.isValidMetadata(ignoredMetadata, metadataType, selectedMetadatas, nestedMetadataToBeBypassed)) {\n\t\t\tresult = [\n\t\t\t\t...result,\n\t\t\t\t...this.getMetadataItemForRetrieval(\n\t\t\t\t\tmetadataNames,\n\t\t\t\t\tmetadataType,\n\t\t\t\t\tthis.getMetadataChunkSize(metadataType, metadataChunkSize, defaultMetadataChunkSize),\n\t\t\t\t\tapiVersion,\n\t\t\t\t\tdirectory,\n\t\t\t\t\tselectedMetadatas\n\t\t\t\t)\n\t\t\t];\n\t\t}\n\t}\n\treturn result;\n}\n\nfunction getOutputDirectory(metadataType) {\n\tconst directoryPath = directoryByMetadataType.get(metadataType);\n\tif (!directoryPath || !directoryPath.outputDirectory) {\n\t\treturn '';\n\t}\n\tdirectoryPath.suffix += 1;\n\tdirectoryByMetadataType.set(metadataType, directoryPath);\n\treturn directoryPath.outputDirectory.replace('{0}', directoryPath.suffix);\n}\n\nfunction getMetadataChunkSize(metadata, metadataChunkSize, defaultMetadataChunkSize) {\n\tconst metadataName = metadata?.toLowerCase();\n\tconst metadataChunkObject = {};\n\tObject.keys(metadataChunkSize).forEach(function (key) {\n\t\tconst value = metadataChunkSize[key];\n\t\tmetadataChunkObject[key.toLowerCase()] = value;\n\t});\n\n\tconst chunkSize = metadataChunkObject[metadataName]\n\t\t? metadataChunkObject[metadataName]\n\t\t: defaultMetadataChunkSizeMap[metadataName]\n\t\t? defaultMetadataChunkSizeMap[metadataName]\n\t\t: defaultMetadataChunkSize;\n\tthis.asyncCopadoLogMessage(`Chunk size to be used for ${metadata}: ${chunkSize}`);\n\treturn chunkSize;\n}\n\nasync function setUpWorkingDirectory(workingDirectory) {\n\tawait this.executeCommand(`\n    \tmkdir -p '${workingDirectory}'\n    `);\n}\n\nfunction switchToWorkingDirectory(workingDirectory) {\n\tprocess.chdir(workingDirectory);\n}\n\nasync function fetchRemoteGitBranch(branch) {\n\tawait this.executeCommand(`\n        copado-git-get --depth '1' '${branch}'\n    `);\n}\n\nasync function configureGit(gitEmail, gitName) {\n\tconst command = `\n        git config --local user.email \"${gitEmail}\" || exit 1\n        git config --local user.name \"${gitName}\" || exit 1\n        git config --global diff.renames false || exit 1\n        git config --global status.renames false\n        `;\n\tawait this.executeCommand(`${command}`);\n}\n\nasync function configureSFDXCli(sourceApiVersion, sourceEndPoint, sourceSessionId) {\n\tconst baseUrl = this.getInstanceUrl(sourceEndPoint);\n\tconst command = `\n    SF_ACCESS_TOKEN=${sourceSessionId} sf org login access-token --instance-url ${baseUrl} --set-default --no-prompt || exit 1\n    sf config set org-api-version=${sourceApiVersion}`;\n\tawait this.executeCommand(command);\n}\n\nasync function disableSourceTracking() {\n\tconst command = `sf org disable tracking`;\n\tawait this.executeCommand(command);\n}\n\nasync function runMetadataRetrieval(maxAllowedProcesses, metadatas, profiles, directory) {\n\tlet result, errorMessage, pool;\n\ttry {\n\t\tthis.startWatch(RESULT_INFO.CATEGORY.SFDX_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.METADATA_RETRIEVAL, processes);\n\t\tpool = new this.SpawnPool(maxAllowedProcesses, metadatas, profiles);\n\t\tawait Promise.all(pool.execute());\n\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.METADATA_RETRIEVAL, processes);\n\t} catch (error) {\n\t\terrorMessage = error?.toString();\n\t} finally {\n\t\tresult = { errors: pool.getErrors(), sfCommandLogs: pool.getSfCommandLogs(), mergedTranslations: pool.getMergedTranslationFiles() };\n\t\tawait this.uploadExecutionDetails(result.errors, result.sfCommandLogs, directory);\n\t\tif (errorMessage) {\n\t\t\tawait this.executeCommand(this.getErrorCommand(errorMessage));\n\t\t}\n\t}\n\treturn result;\n}\n\n/**\n * Writes merged translation files from accumulated content across all retrieve chunks.\n * Each file gets all unique child elements combined under a single <Translations> root.\n * @param {Map<string, Set<string>>} mergedTranslations - filePath -> Set of XML child element strings\n */\nfunction writeMergedTranslationFiles(mergedTranslations) {\n\tif (!mergedTranslations || !mergedTranslations.size) {\n\t\treturn;\n\t}\n\tfor (const [filePath, childElements] of mergedTranslations) {\n\t\tif (!childElements.size) continue;\n\t\tmkdirSync(parse(filePath).dir, { recursive: true });\n\t\tconst mergedXml = [\n\t\t\t'<?xml version=\"1.0\" encoding=\"UTF-8\"?>',\n\t\t\t'<Translations xmlns=\"http://soap.sforce.com/2006/04/metadata\">',\n\t\t\t...Array.from(childElements).map(el => '    ' + el),\n\t\t\t'</Translations>',\n\t\t\t''\n\t\t].join('\\n');\n\t\twriteFileSync(filePath, mergedXml);\n\t}\n}\n\nfunction getPackageXMLfilePath(metadataNames, metadataType, apiVersion, directory, selectedMetadatas) {\n\tconst manifest = [];\n\tmanifest.push('<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\" ?>\\n');\n\tmanifest.push('<Package xmlns=\"http://soap.sforce.com/2006/04/metadata\">\\n');\n\n\t// Add the main metadata type with explicit members\n\tmanifest.push('\\t<types>\\n');\n\tmetadataNames.forEach(metadataName => {\n\t\tmanifest.push(`\\t\\t<members>${metadataName}</members>\\n`);\n\t});\n\tmanifest.push(`\\t\\t<name>${metadataType}</name>\\n`);\n\tmanifest.push('\\t</types>\\n');\n\n\t// Determine which translation types to add based on the metadata type being retrieved\n\tconst translationTypesToAdd = getTranslationTypesForChunk(metadataType, selectedMetadatas);\n\ttranslationTypesToAdd.forEach(translationType => {\n\t\tmanifest.push('\\t<types>\\n');\n\t\tmanifest.push('\\t\\t<members>*</members>\\n');\n\t\tmanifest.push(`\\t\\t<name>${translationType}</name>\\n`);\n\t\tmanifest.push('\\t</types>\\n');\n\t});\n\n\tmanifest.push(`\\t<version>${apiVersion}</version>\\n`);\n\tmanifest.push('</Package>\\n');\n\tconst path = directory + '/' + Math.random() + '.xml';\n\tconst manifestContent = manifest.join(' ');\n\twriteFileSync(path, manifestContent);\n\treturn path;\n}\n\n/**\n * Determines which translation types should be added to a chunk based on the metadata type being retrieved.\n * @param {string} metadataType - The metadata type being retrieved in this chunk\n * @param {string[]} selectedMetadatas - Array of selected metadata types (lowercase)\n * @returns {string[]} - Array of translation API type names to add with wildcard\n */\nfunction getTranslationTypesForChunk(metadataType, selectedMetadatas) {\n\tconst result = [];\n\tif (!selectedMetadatas?.length) {\n\t\treturn result;\n\t}\n\n\tconst metadataTypeLower = metadataType?.toLowerCase();\n\n\t// CustomObject -> add CustomObjectTranslation and/or CustomFieldTranslation\n\tif (metadataTypeLower === TRANSLATION_METADATA_TYPES.CUSTOM_OBJECT) {\n\t\tif (selectedMetadatas.includes(TRANSLATION_METADATA_TYPES.CUSTOM_OBJECT_TRANSLATION)) {\n\t\t\tresult.push(TRANSLATION_METADATA_API_TYPES[TRANSLATION_METADATA_TYPES.CUSTOM_OBJECT_TRANSLATION]);\n\t\t\tlogger(`Adding CustomObjectTranslation (wildcard) to chunk for ${metadataType}`);\n\t\t}\n\t\tif (selectedMetadatas.includes(TRANSLATION_METADATA_TYPES.CUSTOM_FIELD_TRANSLATION)) {\n\t\t\tresult.push(TRANSLATION_METADATA_API_TYPES[TRANSLATION_METADATA_TYPES.CUSTOM_FIELD_TRANSLATION]);\n\t\t\tlogger(`Adding CustomFieldTranslation (wildcard) to chunk for ${metadataType}`);\n\t\t}\n\t}\n\t// Add Translations wildcard for metadata types that have translatable content.\n\telse if (METADATA_TYPES_WITH_TRANSLATIONS.has(metadataTypeLower)) {\n\t\tif (selectedMetadatas.includes(TRANSLATION_METADATA_TYPES.TRANSLATIONS)) {\n\t\t\tresult.push(TRANSLATION_METADATA_API_TYPES[TRANSLATION_METADATA_TYPES.TRANSLATIONS]);\n\t\t\tlogger(`Adding Translations (wildcard) to chunk for ${metadataType}`);\n\t\t}\n\t}\n\n\treturn result;\n}\n\nasync function pushChangesToRemoteBranch(branchName, commitMessage) {\n\tthis.asyncCopadoLogMessage(`Committing ${commitMessage} in ${branchName}`);\n\tlogger('Commit process started');\n\tawait this.commitGit(commitMessage);\n\tthis.startWatch(RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_PUSH, processes);\n\tconst command = `copado-git-get -g \"git push origin ${branchName}\"`;\n\tawait this.executeCommand(command);\n\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.GIT_PUSH, processes);\n\tlogger('Commit process ended');\n}\n\nasync function getCommitId() {\n\treturn await this.executeCommand(`git rev-parse HEAD`);\n}\n\nasync function runVarReplace(additionalInfoForSnapshot, environmentVariables, targetDirectory) {\n\tif (additionalInfoForSnapshot.applyEnvVars && environmentVariables && JSON.parse(environmentVariables)?.length) {\n\t\tthis.asyncCopadoLogMessage('Running Var replace');\n\t\tconst command = `\n            varreplace '${environmentVariables}' '${targetDirectory}' --valuename=true\n\t\t`;\n\t\tawait this.executeCommand(command);\n\t}\n}\n\nasync function runFindAndReplace(additionalInfoForSnapshot, findAndReplaceFileId, branch, tempDirectory, targetDirectory, copadoYml) {\n\tif (additionalInfoForSnapshot.ymlReplacement && findAndReplaceFileId) {\n\t\tthis.asyncCopadoLogMessage('Running YML replace');\n\t\tthis.startWatch(RESULT_INFO.CATEGORY.COPADO_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.DOWNLOAD_FILES, processes);\n\t\tconst PATH_TO_YAML = `${tempDirectory}/${copadoYml}`;\n\t\tconst command = `\n        \tcopado --downloadfiles '${findAndReplaceFileId}' --downloaddir \"${tempDirectory}/\"`;\n\t\tawait this.executeCommand(command);\n\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.DOWNLOAD_FILES, processes);\n\t\tif (!existsSync(PATH_TO_YAML)) {\n\t\t\tthrow 'Could not find the Copado.yml file';\n\t\t}\n\t\tthis.startWatch(RESULT_INFO.CATEGORY.FILE_SYSTEM, RESULT_INFO.ADDITIONAL_INFORMATION.GLOBAL_FIND_AND_REPLACE, processes);\n\t\tconst findAndReplace = `yamlreplace \"${PATH_TO_YAML}\" \"${targetDirectory}\" -b \"${branch}\"`;\n\t\tawait this.executeCommand(findAndReplace);\n\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.GLOBAL_FIND_AND_REPLACE, processes);\n\t}\n}\n\nasync function uploadExecutionDetails(errors, sfCommandLogs, tempDirectory) {\n\tlet command = '';\n\n\tif (Object.keys(errors).length) {\n\t\tconst errorFilePath = `${tempDirectory}/RetrievalError.json`;\n\n\t\twriteFileSync(errorFilePath, JSON.stringify(errors));\n\t\tcommand += `copado --uploadfile \"${errorFilePath}\" --name \"Retrieval Error.json\" || true`;\n\t}\n\n\tif (Object.keys(sfCommandLogs).length) {\n\t\tconst sfCommandLogFilePath = `${tempDirectory}/SalesforceRetrieveResult.json`;\n\t\twriteFileSync(sfCommandLogFilePath, JSON.stringify(sfCommandLogs));\n\t\tcommand += `\n            copado --uploadfile \"${sfCommandLogFilePath}\" --name \"Salesforce Retrieve Result.json\" || true\n        `;\n\t}\n\n\tif (command) {\n\t\tawait this.executeCommand(command);\n\t}\n}\n\nasync function exitProcess(message, commitId, status) {\n\tconst resultData = { message, commitId, status };\n\n\tconst command = `copado -p \"${message}\" --result-data '${JSON.stringify(resultData)}'`;\n\tawait this.executeCommand(command);\n\tprocess.exit(0);\n}\n\nasync function updateResultStatus(errors, commitId, status) {\n\tlet message = '';\n\tconst hasRetrievalError = errors && Object.keys(errors).length;\n\n\tif (hasRetrievalError) {\n\t\tif (commitId) {\n\t\t\tmessage =\n\t\t\t\t'Snapshot execution successful, but some metadata types could not be retrieved. Please view the Retrieval Error.json for details.';\n\t\t} else {\n\t\t\tmessage =\n\t\t\t\t'There are no changes to be committed. Some metadata types could not be retrieved. Please view the Retrieval Error.json for details';\n\t\t}\n\t} else if (commitId) {\n\t\tmessage = 'Git snapshot completed successfully';\n\t} else {\n\t\tmessage = 'There are no changes to be committed';\n\t}\n\n\tthis.printMetrics();\n\tawait this.exitProcess(message, commitId, status);\n}\n\nfunction executeCommand(command, category, additionalInfo, hasJsonResponse, disableLog, disableMetrics) {\n\tthis.logger(`==> ${command}`);\n\treturn new Promise((resolve, reject) => {\n\t\tlet output = '',\n\t\t\terror = '';\n\n\t\tif (!disableMetrics) {\n\t\t\tthis.startWatch(category, additionalInfo, processes);\n\t\t}\n\t\tconst childProcess = child_process.spawn(command, [], { shell: true });\n\n\t\tchildProcess.stdout.on('data', data => {\n\t\t\tconst outputStream = data?.toString();\n\t\t\toutput += outputStream;\n\t\t\tif (!disableLog && outputStream) {\n\t\t\t\tthis.logger(outputStream);\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.stderr.on('data', data => {\n\t\t\tconst errorStream = data?.toString();\n\t\t\tif (errorStream) {\n\t\t\t\tthis.logger(errorStream);\n\t\t\t\terror += errorStream;\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.on('close', code => {\n\t\t\tif (code !== 0) {\n\t\t\t\tthis.logger(`Code: ${code}`);\n\t\t\t\tlet errorMessage = '';\n\t\t\t\tif (hasJsonResponse) {\n\t\t\t\t\ttry {\n\t\t\t\t\t\tresolve(JSON.parse(output));\n\t\t\t\t\t} catch (error) {\n\t\t\t\t\t\terrorMessage = error;\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\terrorMessage = error;\n\t\t\t\t}\n\t\t\t\terrorMessage = errorMessage ? errorMessage : `Error executing the command ${command.trim()}`;\n\n\t\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\t\terrorMessage\n\t\t\t\t\t\t.split('\\n')\n\t\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t\t.join(' ')\n\t\t\t\t);\n\t\t\t\tif (!disableMetrics) {\n\t\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t\t}\n\t\t\t\treject(truncatedError);\n\t\t\t}\n\t\t\tif (!disableMetrics) {\n\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t}\n\t\t\tresolve(hasJsonResponse ? JSON.parse(output) : output);\n\t\t});\n\n\t\tchildProcess.on('error', error => {\n\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\terror\n\t\t\t\t\t.split('\\n')\n\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t.join(' ')\n\t\t\t);\n\t\t\tif (!disableMetrics) {\n\t\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t\t}\n\t\t\treject(truncatedError);\n\t\t});\n\t\tif (!disableMetrics) {\n\t\t\tthis.endWatch(additionalInfo, processes);\n\t\t}\n\t});\n}\n\nfunction startWatch(processType, processName, processes) {\n\tif (!processName || !processType) {\n\t\treturn;\n\t}\n\tconst startTime = process.hrtime();\n\tif (!totalTimeByType[processType]) {\n\t\ttotalTimeByType[processType] = 0;\n\t}\n\tprocesses.push({ name: processName, type: processType, startTime, endTime: null, elapsedTime: null });\n}\n\nfunction endWatch(processType, processes) {\n\tif (!processType) {\n\t\treturn;\n\t}\n\tconst processIndex = processes.length;\n\tif (!processIndex && processes[processIndex - 1].type !== processType) {\n\t\tconsole.error(`Process '${processType}' not started.`);\n\t\treturn;\n\t}\n\tconst endTime = process.hrtime();\n\tconst elapsedTime = process.hrtime(processes[processIndex - 1].startTime);\n\tprocesses[processIndex - 1].endTime = endTime;\n\tprocesses[processIndex - 1].elapsedTime = elapsedTime[0] * 1e9 + elapsedTime[1];\n}\n\nfunction printMetrics() {\n\tlet ux = new Ux();\n\tthis.logger('\\n');\n\tux.styledHeader('   ====================      OVERALL METRICS      ====================   ');\n\tconst resultData = [];\n\tprocesses.forEach(process => {\n\t\t// store data\n\t\tresultData.push({\n\t\t\tprocessType: '| ' + process.type,\n\t\t\tprocessName: '| ' + process.name,\n\t\t\t'startTime(UTC)': process.startTime ? '| ' + this.formatTime(process.startTime) : '| ' + 'N/A',\n\t\t\t'endTime(UTC)': process.endTime ? '| ' + this.formatTime(process.endTime) : '| ' + 'N/A',\n\t\t\telapseTime: process.elapsedTime ? '| ' + `${(process.elapsedTime / 1e9).toFixed(2)} s` + ' |' : '| ' + 'N/A' + ' |'\n\t\t});\n\t\t// Aggregate total time by type\n\t\tif (process.elapsedTime) {\n\t\t\tif (!totalTimeByType[process.type]) {\n\t\t\t\ttotalTimeByType[process.type] = 0;\n\t\t\t}\n\t\t\ttotalTimeByType[process.type] += process.elapsedTime;\n\t\t}\n\t});\n\n\tux.table(resultData, { processType: {}, processName: {}, 'startTime(UTC)': {}, 'endTime(UTC)': {}, elapseTime: {} });\n\tthis.logger('\\n' + '   ====================       EXECUTION SUMMARY      ====================   ');\n\t// Print total aggregate time by type\n\tObject.entries(totalTimeByType).forEach(([type, totalTime]) => {\n\t\tthis.logger(`${type} Total Time: ${(totalTime / 1e9).toFixed(2)} seconds`);\n\t});\n\tthis.logger('   ====================       EXECUTION SUMMARY      ====================   ' + '\\n');\n}\n\nfunction formatTime(time) {\n\tconst date = new Date(time[0] * 1000 + time[1] / 1e6);\n\tconst hours = date.getUTCHours().toString().padStart(2, '0');\n\tconst minutes = date.getUTCMinutes().toString().padStart(2, '0');\n\tconst seconds = date.getUTCSeconds().toString().padStart(2, '0');\n\tconst milliseconds = date.getUTCMilliseconds().toString().padStart(3, '0');\n\treturn `${hours}:${minutes}:${seconds}.${milliseconds}`;\n}\n\nfunction logger(text) {\n\tconsole.log(text);\n}\n\nfunction getErrorCommand(error) {\n\tconst suffix = 'Please check the logs for details.';\n\tconst errorMessage = JSON.stringify(error?.toString()?.trim()?.substring(0, 32760) + '. ' + suffix);\n\treturn `{ copado -p 'Error' -e ${errorMessage}; }`;\n}\n\nfunction getMaxAllowedProcesses(neededCpus) {\n\tconst totalCpus = cpus().length;\n\tif (totalCpus === 1) {\n\t\treturn 1;\n\t}\n\tconst maxAvailableCpus = totalCpus - 1;\n\tif (neededCpus < maxAvailableCpus) {\n\t\treturn neededCpus;\n\t}\n\tlogger(`Due to system limitation we will be using ${maxAvailableCpus} child process for metadata retrieval`);\n\treturn maxAvailableCpus;\n}\n\nfunction createDefaultDirectory() {\n\tconst sfdxProjectJsonPath = `${TARGET_DIRECTORY}/sfdx-project.json`;\n\tconst fileContent = this.readFromPath(sfdxProjectJsonPath);\n\tconst defaultPackageDirectory = fileContent.packageDirectories.find(packageDirectory => packageDirectory.default == true);\n\tconst defaultDirectory = defaultPackageDirectory.path;\n\tdefaultPackageDirectoryPath = defaultDirectory;\n\tif (!existsSync(defaultDirectory)) {\n\t\tmkdirSync(defaultDirectory);\n\t}\n}\n\nclass SpawnPool {\n\tmaxAllowedProcesses;\n\ttotalRunningProcesses;\n\tmetadatas;\n\tprofiles;\n\terrors;\n\tsfCommandLogs;\n\n\tconstructor(maxAllowedProcesses, metadatas, profiles) {\n\t\tthis.maxAllowedProcesses = maxAllowedProcesses;\n\t\tthis.totalRunningProcesses = 0;\n\t\tthis.metadatas = metadatas;\n\t\tthis.profiles = profiles;\n\t\tthis.errors = {};\n\t\tthis.sfCommandLogs = {};\n\t\tthis.translationContents = new Map(); // filePath -> Set of XML child element strings\n\t}\n\n\texecute() {\n\t\tconst promises = [];\n\t\twhile (this.totalRunningProcesses < this.maxAllowedProcesses && (this.metadatas.length || this.profiles.length)) {\n\t\t\tthis.totalRunningProcesses++;\n\t\t\tif (this.totalRunningProcesses === 1 && this.profiles.length) {\n\t\t\t\tpromises.push(\n\t\t\t\t\tnew Promise((resolve, reject) => {\n\t\t\t\t\t\tthis.retrieveFullProfile(this.profiles.shift(), resolve, reject);\n\t\t\t\t\t})\n\t\t\t\t);\n\t\t\t} else {\n\t\t\t\tpromises.push(\n\t\t\t\t\tnew Promise((resolve, reject) => {\n\t\t\t\t\t\tthis.handleNextExecution(resolve, reject);\n\t\t\t\t\t})\n\t\t\t\t);\n\t\t\t}\n\t\t}\n\t\tlogger(`Total promises : ${promises.length}`);\n\t\treturn promises;\n\t}\n\n\t// Creates a unique backup directory for this chunk's translation files and returns\n\t// the shell commands to run after the retrieve.\n\t// For chunks without a custom outputDirectory, an isolated temp output dir is used\n\t// so parallel retrieves don't overwrite each other's translation files.\n\tbuildTranslationBackupCommands(metadata) {\n\t\tconst chunkId = metadata.metadataType + '_' + Math.random().toString(36).substring(7);\n\t\tconst backupDir = `${TEMP_DIRECTORY}/translation_backups/${chunkId}`;\n\t\tmetadata.translationBackupDir = backupDir;\n\n\t\tif (metadata.outputDirectory) {\n\t\t\tconst translationsSrcDir = `${metadata.root}/${metadata.outputDirectory}translations`;\n\t\t\treturn `mkdir -p \"${backupDir}\" >/dev/null 2>&1\n            cp \"${translationsSrcDir}/\"*.translation-meta.xml \"${backupDir}/\" >/dev/null 2>&1 || true`;\n\t\t}\n\n\t\t// Use an isolated output dir inside the current SFDX project so this chunk's\n\t\t// retrieve writes files to its own directory, preventing race conditions\n\t\t// with parallel retrieves while still satisfying sf's requirement that\n\t\t// --output-dir be inside the project root.\n\t\tconst chunkOutputDir = `chunk_output/${chunkId}`;\n\t\tmetadata.chunkOutputDir = chunkOutputDir;\n\t\tconst defaultSourceDir = `${TARGET_DIRECTORY}/${defaultPackageDirectoryPath}/main/default`;\n\n\t\treturn `cp -r \"${chunkOutputDir}/\"* \"${defaultSourceDir}/\" >/dev/null 2>&1`;\n\t}\n\n\texecuteProcess(metadata, resolve, reject) {\n\t\tlet translationBackupCommands = '';\n\t\tif (METADATA_TYPES_WITH_TRANSLATIONS.has(metadata.metadataType)) {\n\t\t\ttranslationBackupCommands = this.buildTranslationBackupCommands(metadata);\n\t\t}\n\n\t\tlet outputDirFlag;\n\t\tif (metadata.outputDirectory) {\n\t\t\toutputDirFlag = '--output-dir ' + metadata.outputDirectory;\n\t\t} else if (metadata.chunkOutputDir) {\n\t\t\toutputDirFlag = '--output-dir \"' + metadata.chunkOutputDir + '\"';\n\t\t} else {\n\t\t\toutputDirFlag = '';\n\t\t}\n\n\t\tlet command = `\n            copado -p 'Retrieving Metadata : ${metadata.metadataNames.length} ${metadata.metadataType}(s)'\n            sf project retrieve start --manifest \"${metadata.manifestFilePath}\" --ignore-conflicts --wait 60 --json ${outputDirFlag}\n            ${translationBackupCommands}`;\n\t\tlogger(`Metadata retrieval starting for ${metadata.metadataType} - ${metadata.manifestFilePath}`);\n\t\tlogger(command);\n\t\tconst options = { shell: true };\n\t\toptions.cwd = directoryByMetadataType.get(metadata.metadataType.toLowerCase())?.root ?? undefined;\n\t\tconst childProcess = spawn(command, [], options);\n\t\tlet stdoutData = '';\n\t\tlet stderrData = '';\n\t\tlet errorData;\n\n\t\tchildProcess.stdout.on('data', data => {\n\t\t\tstdoutData += data?.toString();\n\t\t\tchildProcess.stdout.resume();\n\t\t});\n\n\t\tchildProcess.stderr.on('data', data => {\n\t\t\tstderrData += data.toString();\n\t\t\tchildProcess.stderr.resume();\n\t\t});\n\n\t\tchildProcess.on('error', error => {\n\t\t\terrorData = error;\n\t\t\tchildProcess.error.resume();\n\t\t});\n\n\t\tchildProcess.on('close', code => {\n\t\t\tconst response = { code, stdoutData, stderrData, errorData };\n\t\t\tthis.handleExecutionResultForMetadata(response, metadata, resolve, reject);\n\t\t\tlogger(`Metadata retrieval completed for ${metadata.metadataType} - ${metadata.manifestFilePath}`);\n\t\t\tlogger(`Remaining Retrieval for metadata : ${this.metadatas.length}`);\n\t\t});\n\t}\n\n\thandleExecutionResultForMetadata(response, metadata, resolve, reject) {\n\t\tconst data = getParsedData(response.stdoutData);\n\t\tconst error = this.getErrorsFromExecutionResult(data);\n\t\tthis.sfCommandLogs[`${metadata.metadataType} : ${metadata.metadataNames.toString()}`] = data;\n\t\t// Capture this chunk's backed-up translation files so we can merge all chunks' translations later\n\t\tthis.accumulateTranslationFileContent(metadata);\n\t\tthis.validateUnhandledException(data, reject);\n\t\tif (data?.result?.errorStatusCode === 'LIMIT_EXCEEDED' && metadata.metadataNames?.length > 1) {\n\t\t\tlogger(`LIMIT_EXCEEDED for ${metadata.metadataType}, dividing the metadata in chunks`);\n\t\t\tthis.metadatas = [\n\t\t\t\t...this.metadatas,\n\t\t\t\t...getMetadataItemForRetrieval(\n\t\t\t\t\tmetadata.metadataNames,\n\t\t\t\t\tmetadata.metadataType,\n\t\t\t\t\tparseInt(metadata.metadataNames.length / 2),\n\t\t\t\t\tapiVersion,\n\t\t\t\t\tTEMP_DIRECTORY\n\t\t\t\t)\n\t\t\t];\n\t\t} else if (data?.result?.success === false || response.code === 1 || response.errorData || error) {\n\t\t\tif (metadata.retryCount < retryLimit) {\n\t\t\t\tlogger(`Error occured for ${metadata.metadataType}, retrying retrieval`);\n\t\t\t\tthis.addToMetadata(metadata);\n\t\t\t}\n\t\t\tlogger(\n\t\t\t\t`Error occured for ${metadata.metadataType}, handling error - ${\n\t\t\t\t\tdata?.result?.errorMessage || data?.message || response.errorData || error\n\t\t\t\t}`\n\t\t\t);\n\t\t\tthis.handleErrors(metadata, `${data?.result?.errorMessage || data?.message || response.errorData || error}`);\n\t\t}\n\t\tif (directoryByMetadataType.has(metadata.metadataType.toLowerCase())) {\n\t\t\tthis.saveRetrievedMetadataAndExecute(metadata);\n\t\t}\n\t\tif (this.metadatas.length) {\n\t\t\tthis.executeProcess(this.metadatas.shift(), resolve, reject);\n\t\t} else {\n\t\t\tthis.handleNextExecution(resolve, reject);\n\t\t}\n\t}\n\n\tsaveRetrievedMetadataAndExecute(metadata) {\n\t\tconst metadataType = metadata.metadataType.toLowerCase();\n\t\tconst metadatasInNonPackageDirectory = metadatasInNonPackageDirectoryByType.has(metadataType)\n\t\t\t? metadatasInNonPackageDirectoryByType.get(metadataType)\n\t\t\t: [];\n\t\tmetadatasInNonPackageDirectory.push(metadata);\n\t\tmetadatasInNonPackageDirectoryByType.set(metadataType, metadatasInNonPackageDirectory);\n\t}\n\n\tvalidateUnhandledException(response, reject) {\n\t\tif (response.status === 1 && response.name === 'UnexpectedForceIgnore') {\n\t\t\treject(response.message);\n\t\t}\n\t}\n\n\tgetErrorsFromExecutionResult(response) {\n\t\tconst errors = [];\n\t\tresponse?.result?.files?.forEach(file => {\n\t\t\tif (file.state === 'Failed' && file.error) {\n\t\t\t\terrors.push(file.error);\n\t\t\t}\n\t\t});\n\t\treturn errors.length ? errors.toString() : null;\n\t}\n\n\taddToMetadata(metadata) {\n\t\tmetadata.retryCount += 1;\n\t\tthis.metadatas.push(metadata);\n\t}\n\n\taddToProfile(profile) {\n\t\tprofile.retryCount += 1;\n\t\tthis.profiles.push(profile);\n\t}\n\n\thandleErrors(metadata, error) {\n\t\tconst key = `Error occured while retrieving ${metadata.metadataType} (${metadata.metadataNames.toString()})`;\n\t\tif (!this.errors[key]) {\n\t\t\tthis.errors[key] = [];\n\t\t}\n\t\tthis.errors[key].push(error);\n\t}\n\n\thandleNextExecution(resolve, reject) {\n\t\tlet currentProcessableMetadata;\n\t\tif (this.metadatas.length) {\n\t\t\tcurrentProcessableMetadata = this.metadatas.shift();\n\t\t}\n\t\tif (currentProcessableMetadata) {\n\t\t\tthis.executeProcess(currentProcessableMetadata, resolve, reject);\n\t\t} else {\n\t\t\tlogger('Thread successfully completed');\n\t\t\tresolve('Thread successfully completed');\n\t\t}\n\t}\n\n\tgetErrors() {\n\t\treturn this.errors;\n\t}\n\n\tgetSfCommandLogs() {\n\t\treturn this.sfCommandLogs;\n\t}\n\n\taccumulateTranslationFileContent(metadata) {\n\t\t// Read from the per-chunk backup directory (race-condition free).\n\t\t// The backup was created inside the child process shell command right after the retrieve,\n\t\t// so it contains exactly what the chunk's retrieve produced.\n\t\tconst backupDir = metadata.translationBackupDir;\n\t\tif (!backupDir || !existsSync(backupDir)) {\n\t\t\treturn;\n\t\t}\n\n\t\tconst canonicalTranslationsDir = `${TARGET_DIRECTORY}/${defaultPackageDirectoryPath}/main/default/translations`;\n\n\t\t// Use backreference to correctly capture full top-level XML elements\n\t\t// e.g. <customLabels>...<label>...</label>...<name>...</name>...</customLabels>\n\t\tconst childPattern = /<((?!Translations)[a-zA-Z]+)>[\\s\\S]*?<\\/\\1>/g;\n\n\t\tconst files = readdirSync(backupDir).filter(f => f.endsWith('.translation-meta.xml'));\n\t\tfor (const fileName of files) {\n\t\t\tconst filePath = `${backupDir}/${fileName}`;\n\t\t\t// Always accumulate under the canonical path so all chunks merge into one file\n\t\t\tconst canonicalPath = `${canonicalTranslationsDir}/${fileName}`;\n\t\t\ttry {\n\t\t\t\tconst content = readFileSync(filePath, 'utf-8');\n\t\t\t\tconst children = content.match(childPattern);\n\t\t\t\tif (children && children.length) {\n\t\t\t\t\tif (!this.translationContents.has(canonicalPath)) {\n\t\t\t\t\t\tthis.translationContents.set(canonicalPath, new Set());\n\t\t\t\t\t}\n\t\t\t\t\tconst set = this.translationContents.get(canonicalPath);\n\t\t\t\t\tfor (const child of children) {\n\t\t\t\t\t\tset.add(child.trim());\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} catch (err) {\n\t\t\t\tlogger(`Error reading translation backup ${filePath}: ${err.message}`);\n\t\t\t}\n\t\t}\n\t}\n\n\tgetMergedTranslationFiles() {\n\t\treturn this.translationContents;\n\t}\n\n\tretrieveFullProfile(profiles, resolve, reject) {\n\t\tlogger(`Metadata retrieval starting for profile - ${profiles.metadataNames.length}`);\n\t\tconst request = this.getMetadataReconcilerRequest(profiles?.metadataNames);\n\t\tnew Retriever()\n\t\t\t.run(request)\n\t\t\t?.then(() => {\n\t\t\t\tconst OUTPUT_JSON_FILE_PATH = `${TEMP_DIRECTORY}/output.json`;\n\t\t\t\tconst data = getParsedData(readFileSync(OUTPUT_JSON_FILE_PATH, 'utf-8'));\n\t\t\t\tthis.sfCommandLogs[`${profiles.metadataType} : ${profiles.metadataNames.toString()}`] = data;\n\t\t\t\tlogger(`Metadata retrieval completed for profile (${profiles.metadataNames.toString()})`);\n\t\t\t})\n\t\t\t.catch(error => {\n\t\t\t\tconst errorMessage = error.message || error?.toString() || 'Unknown Error occurred';\n\t\t\t\tif (errorMessage) {\n\t\t\t\t\tlogger(`Metadata retrieval failed for profile (${profiles.metadataNames.toString()}) - ${errorMessage}`);\n\t\t\t\t\tif (profiles.retryCount < retryLimit) {\n\t\t\t\t\t\tlogger('Metadata retrieval failed for profile, retrying retrieval');\n\t\t\t\t\t\tthis.addToProfile(profiles);\n\t\t\t\t\t}\n\t\t\t\t\tthis.handleErrors(profiles, errorMessage);\n\t\t\t\t}\n\t\t\t})\n\t\t\t.finally(() => {\n\t\t\t\tif (this.profiles?.length) {\n\t\t\t\t\tthis.retrieveFullProfile(this.profiles.shift(), resolve, reject);\n\t\t\t\t} else {\n\t\t\t\t\tthis.handleNextExecution(resolve, reject);\n\t\t\t\t}\n\t\t\t});\n\t}\n\n\tgetMetadataReconcilerRequest(profiles) {\n\t\tconst request = new CopaReconcilerInput();\n\t\trequest.repositoryPath = TARGET_DIRECTORY;\n\t\trequest.accessToken = sourceSessionId;\n\t\trequest.instanceUrl = sourceEndpoint?.substring(0, sourceEndpoint?.indexOf('/', sourceEndpoint?.indexOf('/') + 2));\n\t\trequest.jsonOutputPath = TEMP_DIRECTORY;\n\t\trequest.profiles = profiles;\n\t\trequest.operation = Operation.FULL_PROFILE;\n\t\treturn request;\n\t}\n}\n\nasync function updateSourceApiVersion(sfdxProjectJsonPath, sourceApiVersion) {\n\tlet fileContent = this.readFromPath(sfdxProjectJsonPath);\n\tif (fileContent.sourceApiVersion !== sourceApiVersion) {\n\t\tconst commitMessage = `Updated sourceApiVersion from ${fileContent.sourceApiVersion} to ${sourceApiVersion} in sfdx-project.json to align the commit, promote and deploy operations with the latest supported api version of Copado`;\n\t\tfileContent.sourceApiVersion = sourceApiVersion;\n\t\twriteFileSync(sfdxProjectJsonPath, JSON.stringify(fileContent, null, 2));\n\t\tawait this.commitGit(commitMessage);\n\t}\n}\n\nfunction readFromPath(filePath) {\n\tif (!existsSync(filePath)) {\n\t\tthrow `Could not find file at path: ${filePath}`;\n\t}\n\tconst data = readFileSync(filePath, 'utf-8');\n\tlet result;\n\ttry {\n\t\tresult = JSON.parse(data);\n\t} catch (err) {\n\t\tthrow `Content at ${filePath} is not a valid JSON`;\n\t}\n\treturn result;\n}\n\nasync function commitGit(commitMessage) {\n\tthis.startWatch(RESULT_INFO.CATEGORY.GIT_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_COMMIT, processes);\n\tawait this.executeCommand(`\n        git add . || exit 1\n        git commit -m \"${commitMessage}\" || true`);\n\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.GIT_COMMIT, processes);\n}\n\nfunction getInstanceUrl(instanceUrl) {\n\treturn instanceUrl?.substring(0, instanceUrl?.indexOf('/', instanceUrl?.indexOf('/') + 2));\n}\n\nfunction getNestedMetadataInSnasphotScope(selectedMetadatas, nestedMetadataToBeBypassed) {\n\tconst result = nestedMetadataToBeBypassed.filter(metadata => selectedMetadatas.includes(metadata));\n\treturn result;\n}\n\nfunction getMetadataItemForFolderedMetadata(metadataNames, metadataType, maxAllowedItemsPerType, apiVersion, directory, selectedMetadatas) {\n\tconst result = [];\n\tlet folderedMetadataNames = new Set();\n\tmetadataNames?.forEach(metadataName => {\n\t\tif (folderedMetadataNames.size >= maxAllowedItemsPerType) {\n\t\t\tresult.push(this.getMetadataItemDetails(metadataType, [...folderedMetadataNames], apiVersion, directory, selectedMetadatas));\n\t\t\tfolderedMetadataNames = new Set();\n\t\t}\n\t\tfolderedMetadataNames = new Set([...folderedMetadataNames, ...this.getMetadataNameForFolderedMetadata(metadataName)]);\n\t});\n\tif (folderedMetadataNames.size) {\n\t\tresult.push(this.getMetadataItemDetails(metadataType, [...folderedMetadataNames], apiVersion, directory, selectedMetadatas));\n\t}\n\treturn result;\n}\n\nfunction getMetadataNameForFolderedMetadata(name) {\n\tconst result = new Set();\n\tconst items = name?.split('/');\n\tlet folderName = '';\n\titems?.forEach((item, index) => {\n\t\tif (index < items.length - 1) {\n\t\t\tfolderName += folderName ? `/${item}` : item;\n\t\t\tresult.add(folderName);\n\t\t}\n\t});\n\tresult.add(name);\n\treturn result;\n}\n\nfunction getMetadataItemDetails(metadataType, metadataNames, apiVersion, directory, selectedMetadatas) {\n\tconst result = {\n\t\tmetadataType,\n\t\tmetadataNames,\n\t\tretryCount: 0,\n\t\tmanifestFilePath:\n\t\t\tmetadataType.toLowerCase() === 'profile'\n\t\t\t\t? ''\n\t\t\t\t: this.getPackageXMLfilePath(metadataNames, metadataType, apiVersion, directory, selectedMetadatas)\n\t};\n\treturn result;\n}\n\nasync function getFilePathForCustomLabelsInTargetRepository(jsonAdditionalInfo) {\n\tif (!jsonAdditionalInfo.trim() || JSON.parse(jsonAdditionalInfo)?.filePath?.length == 0) {\n\t\tconst changeJsonWithCustomLabel = [\n\t\t\t{\n\t\t\t\tt: 'CustomLabels',\n\t\t\t\tn: 'CustomLabels',\n\t\t\t\tc: 'SFDX',\n\t\t\t\tm: '',\n\t\t\t\ta: 'Add'\n\t\t\t}\n\t\t];\n\t\tconst changesFilePath = `${TEMP_DIRECTORY}/change.json`;\n\t\twriteFileSync(changesFilePath, JSON.stringify(changeJsonWithCustomLabel, null, 2));\n\t\tthis.startWatch(RESULT_INFO.CATEGORY.FILE_SYSTEM, RESULT_INFO.ADDITIONAL_INFORMATION.ENRICHER_SERVICE, processes);\n\t\tawait this.executeCommand(`enricher -p \"${changesFilePath}\" --repo \"${TARGET_DIRECTORY}/\"`);\n\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.ENRICHER_SERVICE, processes);\n\n\t\tconst enrichedChanges = this.readFromPath(changesFilePath);\n\t\treturn enrichedChanges[0].j;\n\t}\n\treturn jsonAdditionalInfo;\n}\n\nasync function copyFilesToTargetDirectory() {\n\tfor (const [metadataType, metadatas] of metadatasInNonPackageDirectoryByType) {\n\t\tlet customLabelsJsonAdditionalInfo = '';\n\t\twhile (metadatas.length > 0) {\n\t\t\tconst metadata = metadatas.shift();\n\t\t\tprocess.env.CUSTOM_LABEL_RETRIEVE_PROJECT_DIRECTORY = metadata.outputDirectory?.split('/')[0];\n\t\t\tprocess.env.CUSTOM_LABEL_RETRIEVE_FILE_PATH = 'main/default/' + metadata.relativeFilePath;\n\t\t\tconst directory = `${metadata.root}/${metadata.outputDirectory}`;\n\t\t\tconst labelsFilePath = `${directory}${metadata.relativeFilePath}`;\n\t\t\tif (existsSync(directory)) {\n\t\t\t\tif (!existsSync(labelsFilePath)) {\n\t\t\t\t\tlogger(\n\t\t\t\t\t\t`Skipping metadata-processor for ${\n\t\t\t\t\t\t\tmetadata.outputDirectory?.split('/')[0]\n\t\t\t\t\t\t}: CustomLabels file not found at ${labelsFilePath}.`\n\t\t\t\t\t);\n\t\t\t\t\tcontinue;\n\t\t\t\t}\n\t\t\t\t// Stage changes so that the metadata-processor doesn't discard the untracked files copied to the target directory\n\t\t\t\tawait this.executeCommand(`git add . || true`);\n\t\t\t\tcustomLabelsJsonAdditionalInfo = await this.getFilePathForCustomLabelsInTargetRepository(customLabelsJsonAdditionalInfo);\n\n\t\t\t\tconst changesFilePath = this.getChangeJsonForCustomLabels(metadata, customLabelsJsonAdditionalInfo);\n\t\t\t\tthis.startWatch(RESULT_INFO.CATEGORY.METADATA_EXECUTION, RESULT_INFO.ADDITIONAL_INFORMATION.METADATA_PROCESSOR, processes);\n\t\t\t\tawait this.executeCommand(`\n                    metadata-processor \"${changesFilePath}\" \"${TARGET_DIRECTORY}\" -o COMMIT --handleLabels`);\n\t\t\t\tthis.endWatch(RESULT_INFO.ADDITIONAL_INFORMATION.METADATA_PROCESSOR, processes);\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunction getChangeJsonForCustomLabels(metadata, filePath) {\n\tconst changeJson = metadata.metadataNames.map(metadataName => {\n\t\treturn {\n\t\t\tt: 'CustomLabel',\n\t\t\tn: metadataName,\n\t\t\tc: 'SFDX',\n\t\t\tm: '',\n\t\t\tj: filePath,\n\t\t\ta: 'Add'\n\t\t};\n\t});\n\tconst fileName = `${TEMP_DIRECTORY}/${metadata.outputDirectory?.split('/')[0]}.json`;\n\twriteFileSync(fileName, JSON.stringify(changeJson, null, 2));\n\treturn fileName;\n}\n\nasync function createSFProjectInNonPackageRetrievePaths(apiVersion) {\n\tfor (const [metadataType, directoryDetails] of directoryByMetadataType) {\n\t\tmkdirSync(directoryDetails.root, { recursive: true });\n\t\tconst parsedPath = parse(directoryDetails.root);\n\t\tprocess.chdir(parsedPath.dir);\n\t\tawait this.executeCommand(\n\t\t\t`sf project generate --name ${parsedPath.name} --default-package-dir \"force-app\" --template \"empty\" --api-version \"${apiVersion}\"`\n\t\t);\n\t\tprocess.chdir(directoryDetails.root);\n\t\tawait this.configureSFDXCli(apiVersion, sourceEndpoint, sourceSessionId);\n\t}\n}\n\nmodule.exports.asyncCopadoLogMessage = asyncCopadoLogMessage;\nmodule.exports.getPath = getPath;\nmodule.exports.getApiVersion = getApiVersion;\nmodule.exports.getParsedData = getParsedData;\nmodule.exports.execute = execute;\nmodule.exports.getMetadataNamesByType = getMetadataNamesByType;\nmodule.exports.getMetaDataFileContent = getMetaDataFileContent;\nmodule.exports.isValidMetadata = isValidMetadata;\nmodule.exports.getProfilesForRetrieval = getProfilesForRetrieval;\nmodule.exports.getMetadataItemForRetrieval = getMetadataItemForRetrieval;\nmodule.exports.getMetadataItemsForRetrieval = getMetadataItemsForRetrieval;\nmodule.exports.setUpWorkingDirectory = setUpWorkingDirectory;\nmodule.exports.switchToWorkingDirectory = switchToWorkingDirectory;\nmodule.exports.fetchRemoteGitBranch = fetchRemoteGitBranch;\nmodule.exports.configureGit = configureGit;\nmodule.exports.configureSFDXCli = configureSFDXCli;\nmodule.exports.disableSourceTracking = disableSourceTracking;\nmodule.exports.runMetadataRetrieval = runMetadataRetrieval;\nmodule.exports.getPackageXMLfilePath = getPackageXMLfilePath;\nmodule.exports.pushChangesToRemoteBranch = pushChangesToRemoteBranch;\nmodule.exports.uploadExecutionDetails = uploadExecutionDetails;\nmodule.exports.runVarReplace = runVarReplace;\nmodule.exports.runFindAndReplace = runFindAndReplace;\nmodule.exports.exitProcess = exitProcess;\nmodule.exports.updateResultStatus = updateResultStatus;\nmodule.exports.logger = logger;\nmodule.exports.executeCommand = executeCommand;\nmodule.exports.getErrorCommand = getErrorCommand;\nmodule.exports.getMaxAllowedProcesses = getMaxAllowedProcesses;\nmodule.exports.getSelectedMetadatas = getSelectedMetadatas;\nmodule.exports.getMetadataChunkSize = getMetadataChunkSize;\nmodule.exports.getCommitId = getCommitId;\nmodule.exports.updateSourceApiVersion = updateSourceApiVersion;\nmodule.exports.readFromPath = readFromPath;\nmodule.exports.commitGit = commitGit;\nmodule.exports.SpawnPool = SpawnPool;\nmodule.exports.copyVlocityFiles = copyVlocityFiles;\nmodule.exports.getInstanceUrl = getInstanceUrl;\nmodule.exports.getNestedMetadataInSnasphotScope = getNestedMetadataInSnasphotScope;\nmodule.exports.getTranslationTypesForChunk = getTranslationTypesForChunk;\nmodule.exports.getMetadataItemForFolderedMetadata = getMetadataItemForFolderedMetadata;\nmodule.exports.getMetadataNameForFolderedMetadata = getMetadataNameForFolderedMetadata;\nmodule.exports.getMetadataItemDetails = getMetadataItemDetails;\nmodule.exports.getOutputDirectory = getOutputDirectory;\nmodule.exports.copyFilesToTargetDirectory = copyFilesToTargetDirectory;\nmodule.exports.getChangeJsonForCustomLabels = getChangeJsonForCustomLabels;\nmodule.exports.getFilePathForCustomLabelsInTargetRepository = getFilePathForCustomLabelsInTargetRepository;\nmodule.exports.createSFProjectInNonPackageRetrievePaths = createSFProjectInNonPackageRetrievePaths;\nmodule.exports.printMetrics = printMetrics;\nmodule.exports.startWatch = startWatch;\nmodule.exports.endWatch = endWatch;\nmodule.exports.formatTime = formatTime;\nmodule.exports.createDefaultDirectory = createDefaultDirectory;\n\n!isTest && this.execute();",
