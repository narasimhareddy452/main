                    "copado__ApexClass__c": "cmcSf.SelectiveCommitSetupCallback",
                    "copado__API_Name__c": "SFDX_Selective_Commit_Bundle_Setup",
                    "copado__Callback_Type__c": "ApexClass",
                    "copado__Image_Name__c": "copado-multicloud-dx:v6",
                    "copado__Options__c": "[ ]",
                    "copado__Parameters__c": "[ {\n  \"required\" : true,\n  \"name\" : \"baseBranch\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.baseBranch}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"featureBranch\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.featureBranch}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"metadataTypeAndName\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.metadataTypeAndName}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"userStoryId\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.userStoryId}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"git_json\",\n  \"defaultValue\" : \"{$Context.Repository.Credential}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"sourceSessionId\",\n  \"defaultValue\" : \"{$Source.Credential.SessionId}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"sourceEndpoint\",\n  \"defaultValue\" : \"{$Source.Credential.Endpoint}\"\n}, {\n  \"name\" : \"overriddenApiVersion\",\n  \"defaultValue\" : \"\"\n}, {\n  \"name\" : \"filePrefix\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.filePrefix}\"\n} ]",
                    "copado__Script__c": "#!/usr/bin/env node\n'use strict';\n\nconst child_process = require('child_process'),\n\t{ copyFileSync, existsSync, writeFileSync, readFileSync } = require('fs'),\n\tprocess = require('process'),\n\t{\n\t\tfeatureBranch,\n\t\tbaseBranch,\n\t\tfilePrefix,\n\t\tsourceSessionId,\n\t\tmetadataTypeAndName,\n\t\tsourceEndpoint,\n\t\tuserStoryId,\n\t\toverriddenApiVersion,\n\t\tAPI_VERSION,\n\t\tisTest\n\t} = process.env,\n\tTEMP_DIRECTORY = getPath('/tmp'),\n\tAPP_DIRECTORY = getPath('/app'),\n\tREPOSITORY_DIRECTORY = `${APP_DIRECTORY}/repository`,\n\tSUPPORTED_BUNDLES = ['wavetemplatebundle', 'lightningcomponentbundle', 'experiencebundle', 'auradefinitionbundle'],\n\tFILE_VERSION_IDENTIFIERS = { SOURCE: '_source', BASE: '_base', FEATURE: '_feature', STRUCTURE: '_structure' },\n\tCOPADO_INFO_PREFIX = 'CopadoFunction INFO';\n\nasync function execute() {\n\ttry {\n\t\t//check if metadataTypeAndName's type is in supported bundles list\n\t\tconst metadata = metadataTypeAndName.split(':');\n\t\tconst metadataType = metadata[0];\n\t\tconst metadataName = metadata[1];\n\n\t\tconst isSupportedBundle = this.isSupportedBundleForSelectiveCommit(metadataType);\n\n\t\tif (!isSupportedBundle) {\n\t\t\tthis.asyncCopadoLogMessage('Bundle not supported');\n\t\t\tthrow new Error('Component Bundle not supported for Selective Commit Operation');\n\t\t}\n\n\t\tthis.changeWorkingDirectory(APP_DIRECTORY);\n\t\tawait this.createDirectory(REPOSITORY_DIRECTORY);\n\t\tthis.changeWorkingDirectory(REPOSITORY_DIRECTORY);\n\n\t\tawait this.fetchRemoteBranch(baseBranch, 1);\n\n\t\tconst apiVersion = this.getApiVersion(overriddenApiVersion, API_VERSION);\n\t\tthis.validateSfdxProjectJson(baseBranch, apiVersion);\n\t\tconst sourceOrgBaseUrl = this.getOrgBaseUrl(sourceEndpoint);\n\t\tawait this.configureSfdxCli(apiVersion, sourceOrgBaseUrl);\n\t\tconst retrieveResponse = await this.retrieveBundleFromSourceOrg(sourceSessionId, metadataName, metadataType);\n\n\t\tconst bundleFilePaths = this.getFilePathsForBundle({ type: metadataType, name: metadataName }, retrieveResponse, REPOSITORY_DIRECTORY);\n\t\tconst hashedBundleFilePaths = this.generateFileHashesFromFilePaths(bundleFilePaths, metadataName);\n\t\tconst bundleStructure = this.generateStructureforBundle(filePrefix, retrieveResponse, hashedBundleFilePaths, {\n\t\t\ttype: metadataType,\n\t\t\tname: metadataName\n\t\t});\n\n\t\tconst promisesToUploadFilesForSourceOrg = this.getFileUploadPromisesForSourceOrg(userStoryId, hashedBundleFilePaths);\n\t\tconst promisesToUploadFilesForBaseBranch = await this.getFileUploadPromisesForBaseBranch(userStoryId, hashedBundleFilePaths);\n\t\tconst promisesToUploadFilesForFeatureBranch = await this.getFileUploadPromisesForFeatureBranch(\n\t\t\tuserStoryId,\n\t\t\thashedBundleFilePaths,\n\t\t\tfeatureBranch\n\t\t);\n\t\tawait Promise.all([...promisesToUploadFilesForSourceOrg, ...promisesToUploadFilesForBaseBranch, ...promisesToUploadFilesForFeatureBranch]);\n\n\t\tawait this.uploadFile(\n\t\t\t`${TEMP_DIRECTORY}/${filePrefix}${FILE_VERSION_IDENTIFIERS.STRUCTURE}`,\n\t\t\tuserStoryId,\n\t\t\tbundleStructure,\n\t\t\t`${filePrefix}${FILE_VERSION_IDENTIFIERS.STRUCTURE}`\n\t\t);\n\t} catch (error) {\n\t\tawait this.executeCommand(this.getErrorCommand(error));\n\t\tif (!isTest) {\n\t\t\tprocess.exit(1);\n\t\t}\n\t}\n}\n\nfunction isSupportedBundleForSelectiveCommit(type) {\n\treturn SUPPORTED_BUNDLES.includes(type.toLowerCase());\n}\n\nasync function configureSfdxCli(apiVersion, sourceOrgBaseUrl) {\n\tthis.asyncCopadoLogMessage('Configuring sf cli');\n\tconst command = `\n\t\tsf config set org-instance-url=${sourceOrgBaseUrl} || exit 1\n    \tsf config set org-api-version=${apiVersion}\n\t`;\n\tawait this.executeCommand(command);\n}\n\nfunction getApiVersion(overriddenApiVersion, apiVersion) {\n\tconst finalApiVersion = overriddenApiVersion || apiVersion;\n\tconst regularExpressionForValidApiVersion = /\\d\\d\\.0/;\n\tif (!regularExpressionForValidApiVersion.test(finalApiVersion)) {\n\t\tthrow new Error(`Invalid API Version: ${finalApiVersion}`);\n\t}\n\treturn finalApiVersion;\n}\n\nfunction validateSfdxProjectJson(branch, apiVersion) {\n\tthis.asyncCopadoLogMessage('Validating project json');\n\tconst sfdxProjectJsonPath = 'sfdx-project.json';\n\tif (existsSync(sfdxProjectJsonPath)) {\n\t\tlet fileContent = this.readFromPath(sfdxProjectJsonPath);\n\t\tif (fileContent.sourceApiVersion !== apiVersion) {\n\t\t\tfileContent.sourceApiVersion = apiVersion;\n\t\t\twriteFileSync(sfdxProjectJsonPath, JSON.stringify(fileContent, null, 2));\n\t\t}\n\t} else {\n\t\tthrow new Error(`Invalid configuration in ${branch}, sfdx-project.json is invalid or missing at project root.`);\n\t}\n}\n\nfunction getOrgBaseUrl(orgEndPoint) {\n\tconst orgBaseUrl = orgEndPoint?.substring(0, orgEndPoint?.indexOf('/', orgEndPoint?.indexOf('/') + 2));\n\treturn orgBaseUrl;\n}\n\nasync function retrieveBundleFromSourceOrg(sourceSessionId, name, type) {\n\tconst command = `sf project retrieve start --target-org \"${sourceSessionId}\" --metadata ${type}:${name} --ignore-conflicts --json`;\n\tconst response = await this.executeCommand(command, true, true);\n\treturn response;\n}\n\nfunction generateStructureforBundle(filePrefix, retrieveResponse, hashedBundleFilePaths, metadataTypeAndName) {\n\tlet structure = {};\n\tconst fileStructure = this.getFileStructureInformation(metadataTypeAndName?.name, hashedBundleFilePaths);\n\tconst { lastModifiedBy, lastModifiedDate } = this.getLastModifiedInformation(\n\t\tretrieveResponse,\n\t\tmetadataTypeAndName?.type,\n\t\tmetadataTypeAndName?.name\n\t);\n\n\tstructure.hash = filePrefix;\n\tstructure.bundleType = metadataTypeAndName?.type;\n\tstructure.bundleName = metadataTypeAndName?.name;\n\tstructure.lastModifiedBy = lastModifiedBy;\n\tstructure.lastModifiedDate = lastModifiedDate ? this.formatDate(lastModifiedDate) : '';\n\tstructure.fileStructure = fileStructure;\n\tstructure.refreshedDate = this.formatDate(Date.now());\n\n\treturn structure;\n}\n\nfunction getLastModifiedInformation(retrieveResponse, metadataType, metadataName) {\n\tlet lastModifiedBy = '',\n\t\tlastModifiedDate = '';\n\tconst fileProperties = retrieveResponse?.result?.fileProperties;\n\tfor (const fileProperty of fileProperties) {\n\t\tif (fileProperty?.type === metadataType && fileProperty?.fullName.split('/')[0] === metadataName) {\n\t\t\tlastModifiedBy = fileProperty?.lastModifiedByName;\n\t\t\tlastModifiedDate = fileProperty?.lastModifiedDate;\n\t\t\tbreak;\n\t\t}\n\t}\n\treturn { lastModifiedBy, lastModifiedDate };\n}\n\nfunction getFileStructureInformation(metadataName, hashedBundleFilePaths) {\n\tconst fileStructure = [];\n\tObject.keys(hashedBundleFilePaths).forEach(fileHash => {\n\t\tlet indexOfBundle = hashedBundleFilePaths[fileHash].indexOf(metadataName);\n\t\tlet directories = hashedBundleFilePaths[fileHash].substring(indexOfBundle);\n\t\tdirectories = directories.split('/');\n\n\t\tlet node;\n\t\tif(directories.length > 1) {\n\t\t\tnode = this.buildStructure(fileStructure, directories.slice(1), fileHash, hashedBundleFilePaths[fileHash]);\n\t\t} else {\n\t\t\tconst extension = directories[0].indexOf('.');\n\t\t\tnode = {\n\t\t\t\tisFolder: false,\n\t\t\t\tname: directories[0],\n\t\t\t\ttype: directories[0].substring(extension + 1),\n\t\t\t\thash: fileHash,\n\t\t\t\tfullPath: hashedBundleFilePaths[fileHash]\n\t\t\t};\n\t\t}\n\t\tif (node) {\n\t\t\tfileStructure.push(node);\n\t\t}\n\t});\n\n\treturn fileStructure;\n}\n\nfunction buildStructure(fileStructure, directories, fileHash, fullPath) {\n\tlet current = directories[0];\n\n\tconst isFolder = directories.length > 1;\n\tconst existingPath = fileStructure.find(path => path.name == current);\n\n\tif (existingPath && isFolder) {\n\t\tif (existingPath?._children.length > 0) {\n\t\t\tlet child = buildStructure(existingPath._children, directories.slice(1), fileHash, fullPath);\n\t\t\tif (child) {\n\t\t\t\texistingPath._children.push(child);\n\t\t\t}\n\t\t}\n\t} else {\n\t\tif (isFolder) {\n\t\t\tlet child = buildStructure(fileStructure, directories.slice(1), fileHash, fullPath);\n\t\t\tif (child) {\n\t\t\t\tlet parent = { isFolder: true, name: current, _children: [] };\n\t\t\t\tparent._children.push(child);\n\t\t\t\treturn parent;\n\t\t\t}\n\t\t} else {\n\t\t\tconst extension = current.indexOf('.');\n\t\t\treturn { isFolder: false, name: current, type: current.substring(extension + 1), hash: fileHash, fullPath };\n\t\t}\n\t}\n}\n\nfunction getFilePathsForBundle(metadataTypeAndName, retrieveResponse, repositoryPath) {\n\tthis.asyncCopadoLogMessage('Finding metadata file path');\n\tlet result = [];\n\tif (retrieveResponse.status) {\n\t\tthrow new Error(retrieveResponse?.message);\n\t} else if (retrieveResponse?.result?.messages.length > 0) {\n\t\tthrow new Error(retrieveResponse?.result?.messages[0].problem);\n\t}\n\n\tretrieveResponse?.result?.files.forEach(data => {\n\t\tif (data.fullName == metadataTypeAndName?.name && data.type == metadataTypeAndName?.type) {\n\t\t\tif (data.state === 'Failed' && data.error) {\n\t\t\t\tthrow new Error(data.error);\n\t\t\t}\n\t\t\tresult.push(data?.filePath.substring(repositoryPath.length + 1));\n\t\t}\n\t});\n\n\tif (!result) {\n\t\tthrow new Error('No metadata file path found');\n\t}\n\treturn result;\n}\n\nfunction getFileUploadPromisesForSourceOrg(userStoryId, hashedBundleFilePaths) {\n\tthis.asyncCopadoLogMessage('Finding and uploading metadata content from Source Org');\n\treturn this.getFileUploadPromises(userStoryId, hashedBundleFilePaths, FILE_VERSION_IDENTIFIERS.SOURCE);\n}\n\nasync function getFileUploadPromisesForBaseBranch(userStoryId, hashedBundleFilePaths) {\n\tthis.asyncCopadoLogMessage('Finding and uploading metadata content from Base branch');\n\tawait this.gitReset();\n\treturn this.getFileUploadPromises(userStoryId, hashedBundleFilePaths, FILE_VERSION_IDENTIFIERS.BASE);\n}\n\nasync function getFileUploadPromisesForFeatureBranch(userStoryId, hashedBundleFilePaths, featureBranch) {\n\tthis.asyncCopadoLogMessage('Finding and uploading metadata content from Feature branch');\n\t// Error handling in place for the scenario when feature branch doesn't exist\n\ttry {\n\t\tawait this.fetchAndCheckoutGitBranch(featureBranch, 1);\n\t} catch (error) {\n\t\tthis.logger(error);\n\t\treturn [Promise.resolve()];\n\t}\n\n\treturn this.getFileUploadPromises(userStoryId, hashedBundleFilePaths, FILE_VERSION_IDENTIFIERS.FEATURE);\n}\n\nfunction getFileUploadPromises(userStoryId, hashedBundleFilePaths, suffix) {\n\tconst result = [];\n\n\tObject.keys(hashedBundleFilePaths).forEach(fileHash => {\n\t\tif (existsSync(hashedBundleFilePaths[fileHash])) {\n\t\t\tconst fileName = `${filePrefix}_${fileHash}${suffix}`;\n\t\t\tconst hashedFileNameWithSuffix = `${TEMP_DIRECTORY}/${fileName}`;\n\t\t\tcopyFileSync(hashedBundleFilePaths[fileHash], hashedFileNameWithSuffix);\n\t\t\tconst command = `copado --uploadfile \"${hashedFileNameWithSuffix}\" --name \"${fileName}\" --parentid \"${userStoryId}\"`;\n\t\t\tresult.push(this.executeCommand(command));\n\t\t} else {\n\t\t\tresult.push(Promise.resolve());\n\t\t}\n\t});\n\treturn result;\n}\n\nasync function gitReset() {\n\tconst command = `\n\t\tgit reset --hard || exit 1\n\t\tgit clean -fd\n\t`;\n\tawait this.executeCommand(command);\n}\n\nasync function createDirectory(directory) {\n\tthis.asyncCopadoLogMessage('Set up working directory');\n\tconst command = `mkdir -p ${directory}`;\n\tawait this.executeCommand(command);\n}\n\nasync function fetchRemoteBranch(branch, gitDepth) {\n\tthis.asyncCopadoLogMessage(`Fetching ${branch} branch`);\n\tconst command = `copado-git-get --depth \"${gitDepth}\" \"${branch}\"`;\n\tawait this.executeCommand(command);\n}\n\nasync function fetchAndCheckoutGitBranch(branch, gitDepth) {\n\tthis.asyncCopadoLogMessage(`Fetching ${branch} branch`);\n\tconst command = `git fetch origin ${branch} --depth ${gitDepth} && git checkout ${branch}`;\n\tawait this.executeCommand(command);\n}\n\nfunction generateFileHashesFromFilePaths(filePaths, metadataName) {\n\tlet results = {};\n\tfilePaths.forEach(filePath => {\n\t\tlet indexOfBundle = filePath.indexOf(metadataName);\n\t\tlet fileHash = this.generateFileHash(filePath.substring(indexOfBundle + metadataName.length + 1));\n\t\tresults[fileHash] = filePath;\n\t});\n\n\treturn results;\n}\n\nfunction generateFileHash(filePath) {\n\tconst textInBytes = new TextEncoder().encode(filePath);\n\tconst binString = Array.from(textInBytes, byte => String.fromCodePoint(byte)).join('');\n\treturn btoa(binString).slice(-80);\n}\n\nasync function uploadFile(filePath, parentId, data, fileName) {\n\tif (data) {\n\t\twriteFileSync(filePath, JSON.stringify(data));\n\t}\n\tconst command = `copado --uploadfile \"${filePath}\" ${fileName ? '--name ' + '\"' + fileName + '\"' : ''} --parentid \"${parentId}\"`;\n\tawait this.executeCommand(command);\n}\n\nfunction asyncCopadoLogMessage(message) {\n\tif (message) {\n\t\tthis.executeCommand(`copado -p \"${message}\"`);\n\t}\n}\n\nfunction executeCommand(command, hasJsonResponse, disableLog) {\n\tthis.logger(`==> ${command}`);\n\treturn new Promise((resolve, reject) => {\n\t\tlet output = '',\n\t\t\terror = '';\n\t\tconst childProcess = child_process.spawn(command, [], { shell: true });\n\n\t\tchildProcess.stdout.on('data', data => {\n\t\t\tconst outputStream = data?.toString();\n\t\t\toutput += outputStream;\n\t\t\tif (!disableLog && outputStream) {\n\t\t\t\tthis.logger(outputStream);\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.stderr.on('data', data => {\n\t\t\terror += data?.toString();\n\t\t});\n\n\t\tchildProcess.on('close', code => {\n\t\t\tif (code !== 0) {\n\t\t\t\tthis.logger(`Code: ${code}`);\n\t\t\t\tlet errorMessage = '';\n\t\t\t\tif (hasJsonResponse) {\n\t\t\t\t\ttry {\n\t\t\t\t\t\tresolve(JSON.parse(output));\n\t\t\t\t\t} catch (error) {\n\t\t\t\t\t\terrorMessage = error;\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\terrorMessage = error;\n\t\t\t\t}\n\t\t\t\terrorMessage = errorMessage ? errorMessage : `Error executing the command ${command}`;\n\n\t\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\t\terrorMessage\n\t\t\t\t\t\t.split('\\n')\n\t\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t\t.join(' ')\n\t\t\t\t);\n\t\t\t\treject(truncatedError);\n\t\t\t}\n\t\t\tresolve(hasJsonResponse ? JSON.parse(output) : output);\n\t\t});\n\n\t\tchildProcess.on('error', error => {\n\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\terror\n\t\t\t\t\t.split('\\n')\n\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t.join(' ')\n\t\t\t);\n\t\t\treject(truncatedError);\n\t\t});\n\t});\n}\n\nfunction getErrorCommand(error) {\n\tconst suffix = 'Please check the logs for details.';\n\treturn `copado -p \"Error\" -e ${JSON.stringify(error?.toString()?.trim()?.substring(0, 32760) + '; ' + suffix)}`;\n}\n\nfunction readFromPath(filePath) {\n\tif (!existsSync(filePath)) {\n\t\tthrow new Error(`Could not find file at path: ${filePath}`);\n\t}\n\tlet result;\n\tconst data = readFileSync(filePath, 'utf-8');\n\ttry {\n\t\tresult = JSON.parse(data);\n\t} catch (error) {\n\t\tthrow new Error(`Content at ${filePath} is not a valid JSON, ${error.toString()}`);\n\t}\n\treturn result;\n}\n\nfunction changeWorkingDirectory(directory) {\n\tprocess.chdir(directory);\n}\n\nfunction getPath(filePath) {\n\treturn isTest ? `${__dirname}/__tests__/__mockDirectory__${filePath}` : filePath;\n}\n\nfunction logger(message) {\n\tconsole.log(message);\n}\n\nfunction formatDate(timestamp) {\n\tconst date = new Date(timestamp);\n\n\tconst day = String(date.getDate()).padStart(2, '0');\n\tconst month = String(date.getMonth() + 1).padStart(2, '0');\n\tconst year = date.getFullYear();\n\n\tlet hours = String(date.getHours()).padStart(2, '0');\n\tconst minutes = date.getMinutes();\n\n\tconst period = hours >= 12 ? 'PM' : 'AM';\n\thours = hours % 12 || 12;\n\n\treturn `${day}/${month}/${year} ${hours}:${minutes}${period}`;\n}\n\nmodule.exports.execute = execute;\nmodule.exports.isSupportedBundleForSelectiveCommit = isSupportedBundleForSelectiveCommit;\nmodule.exports.configureSfdxCli = configureSfdxCli;\nmodule.exports.getApiVersion = getApiVersion;\nmodule.exports.validateSfdxProjectJson = validateSfdxProjectJson;\nmodule.exports.getOrgBaseUrl = getOrgBaseUrl;\nmodule.exports.retrieveBundleFromSourceOrg = retrieveBundleFromSourceOrg;\nmodule.exports.getFileUploadPromises = getFileUploadPromises;\nmodule.exports.getFilePathsForBundle = getFilePathsForBundle;\nmodule.exports.getFileUploadPromisesForSourceOrg = getFileUploadPromisesForSourceOrg;\nmodule.exports.getFileUploadPromisesForBaseBranch = getFileUploadPromisesForBaseBranch;\nmodule.exports.getFileUploadPromisesForFeatureBranch = getFileUploadPromisesForFeatureBranch;\nmodule.exports.gitReset = gitReset;\nmodule.exports.createDirectory = createDirectory;\nmodule.exports.fetchRemoteBranch = fetchRemoteBranch;\nmodule.exports.fetchAndCheckoutGitBranch = fetchAndCheckoutGitBranch;\nmodule.exports.generateFileHashesFromFilePaths = generateFileHashesFromFilePaths;\nmodule.exports.generateFileHash = generateFileHash;\nmodule.exports.generateStructureforBundle = generateStructureforBundle;\nmodule.exports.getLastModifiedInformation = getLastModifiedInformation;\nmodule.exports.getFileStructureInformation = getFileStructureInformation;\nmodule.exports.buildStructure = buildStructure;\nmodule.exports.uploadFile = uploadFile;\nmodule.exports.executeCommand = executeCommand;\nmodule.exports.getErrorCommand = getErrorCommand;\nmodule.exports.readFromPath = readFromPath;\nmodule.exports.changeWorkingDirectory = changeWorkingDirectory;\nmodule.exports.getPath = getPath;\nmodule.exports.logger = logger;\nmodule.exports.formatDate = formatDate;\nmodule.exports.asyncCopadoLogMessage = asyncCopadoLogMessage;\n\n!isTest && this.execute();",
                    "copado__Type__c": "Standard",
