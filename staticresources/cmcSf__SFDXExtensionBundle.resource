                    "copado__Image_Name__c": "copado-multicloud-vlocity:v1",
                    "copado__Options__c": "[ ]",
                    "copado__Parameters__c": "[ {\n  \"name\" : \"promotionBranch\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.promotionBranchName}\"\n}, {\n  \"name\" : \"targetBranch\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.destinationBranchName}\"\n}, {\n  \"name\" : \"destinationInstanceUrl\",\n  \"defaultValue\" : \"{$Destination.Credential.Endpoint}\"\n}, {\n  \"name\" : \"destinationSessionid\",\n  \"defaultValue\" : \"{$Destination.Credential.SessionId}\"\n}, {\n  \"name\" : \"validationId\",\n  \"defaultValue\" : \"{$Job.ExecutionParent.Promotion__r.cmcSf__Validate_Deploy_Request_Id__c}\"\n}, {\n  \"name\" : \"gitName\",\n  \"defaultValue\" : \"{$User.Name}\"\n}, {\n  \"name\" : \"gitEmail\",\n  \"defaultValue\" : \"{$User.Email}\"\n}, {\n  \"name\" : \"gitDepth\",\n  \"defaultValue\" : \"{$Pipeline.Property.gitDepth_deploy}\"\n}, {\n  \"name\" : \"hasVlocityChanges\",\n  \"defaultValue\" : \"{$Context.apex.cmcSf.HasVlocityChanges}\"\n}, {\n  \"name\" : \"isValidation\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.deploymentDryRun}\"\n}, {\n  \"name\" : \"vlocityDirectory\",\n  \"defaultValue\" : \"vlocity\"\n}, {\n  \"name\" : \"git_json\",\n  \"defaultValue\" : \"{$Context.Repository.Credential}\"\n}, {\n  \"name\" : \"repository_id\",\n  \"defaultValue\" : \"{$Pipeline.Git_Repository__r.Id}\"\n}, {\n  \"name\" : \"file_changes_id\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.fileWithSelectedChanges}\"\n}, {\n  \"name\" : \"file_name\",\n  \"defaultValue\" : \"Copado Deploy changes\"\n}, {\n  \"name\" : \"attachVlocityLogFile\",\n  \"defaultValue\" : \"{$Job.ExecutionParent.Promotion__r.cmcSf__Attach_Vlocity_Build_File__c}\"\n}, {\n  \"name\" : \"vlocitySettingsDocumentId\",\n  \"defaultValue\" : \"{$Context.apex.cmcSf.VlocitySettingsDestinationId}\"\n}, {\n  \"name\" : \"rollBackEnabled\",\n  \"defaultValue\" : \"{$Context.apex.cmcSf.IsRollBackEnabled}\"\n}, {\n  \"name\" : \"findAndReplaceRules\",\n  \"defaultValue\" : \"{$Context.apex.GlobalFindAndReplaceDestinationId}\"\n}, {\n  \"name\" : \"destinationEnv\",\n  \"defaultValue\" : \"{$Destination.apex.EnvironmentVariables}\"\n}, {\n  \"name\" : \"prevResult\",\n  \"defaultValue\" : \"{$Job.PrevStep.Result__r.Result_Data__c}\"\n}, {\n  \"name\" : \"promotionId\",\n  \"defaultValue\" : \"{$Job.ExecutionParent.Promotion__r.Id}\"\n}, {\n  \"name\" : \"userStoryBranches\",\n  \"defaultValue\" : \"{$Context.JobExecution__r.DataJson.userStoryBranches}\"\n}, {\n  \"required\" : true,\n  \"name\" : \"repositoryId\",\n  \"defaultValue\" : \"{$Pipeline.Git_Repository__r.Id}\"\n}, {\n  \"name\" : \"cleanPullRequestEnabled\",\n  \"defaultValue\" : \"{$Pipeline.Property.Enable_Clean_US_Pull_Request}\"\n}, {\n  \"name\" : \"promotionFindAndReplaceRules\",\n  \"defaultValue\" : \"{$Context.apex.PromotionFindAndReplaceFileId}\"\n} ]",
                    "copado__Result_Viewer_Component__c": "cmcSf:resultViewer",
                    "copado__Script__c": "#!/usr/bin/env node\n'use strict';\n\n/**\n* Performs deploy of selected user story metadata changes.\n* Returns (If ACTION success) destination branch with merged changes of the user story metadata\n* (If ACTION failed) Returns details with error status on the job execution\n\n\n* @param promotionBranch\n* @param targetBranch\n* @param destinationInstanceUrl\n* @param destinationSessionid\n* @param isValidation\n* @param gitName\n* @param gitEmail\n* @param vlocityDirectory\n* @param hasVlocityChanges\n* @param file_changes_id\n* @param file_name\n* @param promotionFindAndReplaceRules\n*/\n\nconst child_process = require('child_process'),\n\tfs = require('fs'),\n\tpath = require('path'),\n\t{ env } = require('process'),\n\t{\n\t\tdestinationSessionid,\n\t\tpromotionBranch,\n\t\ttargetBranch,\n\t\tdestinationInstanceUrl,\n\t\tgitDepth,\n\t\tisTest,\n\t\thasVlocityChanges,\n\t\tisValidation,\n\t\tvlocityDirectory,\n\t\tfile_changes_id,\n\t\tfile_name,\n\t\tattachVlocityLogFile,\n\t\tvlocitySettingsDocumentId,\n\t\trollBackEnabled,\n\t\tfindAndReplaceRules,\n\t\tdestinationEnv,\n\t\tprevResult,\n\t\tpromotionId,\n\t\tuserStoryBranches,\n\t\tcleanPullRequestEnabled,\n\t\tpromotionFindAndReplaceRules\n\t} = env,\n\turl = destinationInstanceUrl.substring(0, destinationInstanceUrl.indexOf('/', destinationInstanceUrl.indexOf('/') + 2)),\n\tAPP_DIRECTORY = getPath('/app'),\n\tjs_yaml = isTest ? require('js-yaml') : require('/usr/local/lib/node_modules/js-yaml'),\n\tTEMP_DIRECTORY = getPath('/tmp'),\n\tTARGET_DIRECTORY = `${APP_DIRECTORY}/repository`,\n\tENCODED_CHANGES_FILE = 'encoded_changes.json',\n\tJOB_FILE = 'jobfile.yaml',\n\tROLLBACK_RETRIEVAL_PATH = `${TEMP_DIRECTORY}/vlocityRollback`,\n\tDEPLOYMENT_RESULT_JSON = 'DeploymentResult.json',\n\tVALIDATION_RESULT_JSON = 'ValidationResult.json',\n\tROLLBACK_RETRIEVE_RESULT = 'RollbackRetrieveResult.json',\n\tDEPLOYMENT_RESULT_PATH = `${TEMP_DIRECTORY}/${DEPLOYMENT_RESULT_JSON}`,\n\tVALIDATION_RESULT_PATH = `${TEMP_DIRECTORY}/${VALIDATION_RESULT_JSON}`,\n\n\tACTIONS = {\n\t\tADD: 'add',\n\t\tRETRIEVE_ONLY: 'retrieveonly',\n\t\tFULL: 'full',\n\t\tDELETE: 'delete'\n\t},\n\tROLLBACK_ACTION = {\n\t\tUNCHANGED: 'Unchanged',\n\t\tDELETE: 'Delete',\n\t\tCREATE: 'Create',\n\t\tUPDATE: 'Update',\n\t\tDELETE_NOT_SUPPORTED: 'Delete (Not Supported)',\n\t\tCREATE_NOT_SUPPORTED: 'Create (Not Supported)'\n\t},\n\tGIT_DEPTH = getGitDepth(gitDepth),\n\tVLOCITY_BUILD_LOG = 'VlocityBuildLog.yaml',\n\tVLOCITY_SETTINGS_YAML_FILE = 'vlocity-settings',\n\tVLOCITY_TEMP = 'vlocity-temp',\n\tVLOCITY_ROLLBACK_JSON = `${TEMP_DIRECTORY}/CopadoVlocityRollbackChanges.json`,\n\tPROMOTION_US_MERGE_ORDER = `${TEMP_DIRECTORY}/promotion_us_merge_order.json`,\n\tCOPADO_INFO_PREFIX = 'CopadoFunction INFO',\n\tisRollBack = isRollBackEnabled(isValidation, rollBackEnabled),\n\tRESULT_INFO = {\n\t\tLEVEL: {\n\t\t\tINFO: 'INFO',\n\t\t\tERROR: 'ERROR',\n\t\t\tWARN: 'WARN'\n\t\t},\n\t\tCATEGORY: {\n\t\t\tUNKNOWN_EXCEPTION: 'Unknown Exception',\n\t\t\tCOPADO_INFO: 'Copado Info',\n\t\t\tCOPADO_SERVICE: 'Copado Service',\n\t\t\tVBT_CLI: 'VBT CLI',\n\t\t\tSF_CLI: 'SF CLI',\n\t\t\tGIT: 'Git',\n\t\t\tFILE_SYSTEM: 'File System',\n\t\t\tCOPADO_METADATA_INTELLIGENCE: 'Copado Metadata Intelligence'\n\t\t},\n\t\tADDITIONAL_INFORMATION: {\n\t\t\tCONSOLIDATED_RESULT: `Consolidated ${isValidation === 'true' ? 'Validation' : 'Deployment'} Result`,\n\t\t\tGIT_STATUS: 'Git Status',\n\t\t\tROLLBACK_BRANCH_CHECKOUT: 'Rollback Branch Checkout',\n\t\t\tGIT_COMMIT: 'Git Commit',\n\t\t\tGIT_CONFIG: 'Git Configuration',\n\t\t\tPROMOTION_BRANCH_CHECKOUT: 'Promotion Branch Checkout',\n\t\t\tTARGET_BRANCH_CHECKOUT: 'Target Branch Checkout',\n\t\t\tDEBUG_BRANCH_CHECKOUT: 'Debug Branch Checkout',\n\t\t\tPOPULATE_INFO_ON_RESULT: 'Populate Information on the result record',\n\t\t\tENV_VARIABLE_REPLACEMENT: 'Environment Variable Replacement',\n\t\t\tGLOBAL_FIND_AND_REPLACE: 'Global Find and Replace',\n\t\t\tPROMOTION_FIND_AND_REPLACE: 'Promotion Find and Replace',\n\t\t\tUPLOAD_FILES: 'Upload Files',\n\t\t\tDOWNLOAD_FILES: 'Download Files',\n\t\t\tVALIDATE_DATAPACKS: 'Validate Vlocity Deployment',\n\t\t\tVLOCITY_DEPLOYMENT: 'Datapacks Deployment',\n\t\t\tGIT_MERGE: 'Git Merge',\n\t\t\tGIT_PUSH: 'Git Push',\n\t\t\tGIT_ADD: 'Git Add',\n\t\t\tGIT_CLEAN: 'Git Clean',\n            SFDX_CONFIG: 'SFDX Configuration'\n\t\t}\n\t},\n\tresultViewerJson = [],\n\tCUSTOM_ERROR = {\n\t\tCOMMAND_EXECUTION_ERROR: 'CommandExecutionError'\n\t},\n\tRESULT_TABLE_COLUMNS = [\n\t\t{\n\t\t\tlabel: 'Level',\n\t\t\tfieldName: 'Level',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Level',\n\t\t\tinitialWidth: 80\n\t\t},\n\t\t{\n\t\t\tlabel: 'Category',\n\t\t\tfieldName: 'Category',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Category',\n\t\t\tinitialWidth: 120\n\t\t},\n\t\t{\n\t\t\tlabel: 'Additional Information',\n\t\t\tfieldName: 'AdditionalInformation',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Additional_Information',\n\t\t\tinitialWidth: 200\n\t\t},\n\t\t{\n\t\t\tlabel: 'Message',\n\t\t\tfieldName: 'Message',\n\t\t\ttype: 'text',\n\t\t\twrapText: true,\n\t\t\tcustomLabel: 'Message'\n\t\t}\n\t],\n\tRESULT_TABLE_HEADER = {\n\t\tlabel: 'Deployment Result',\n\t\tcustomLabel: 'Deployment_Result'\n\t},\n\tHEADER_ICON = 'standard:note';\n\nlet isSfMetadataPresent, isVlocityDataPackPresent, executionError;\n\n// EXECUTION\n\nasync function execute() {\n\tconst { targetBranch, gitEmail, gitName } = env;\n\ttry {\n\t\tawait this.displayVersions();\n\t\tthis.checkChangesWrtCategory(`${APP_DIRECTORY}/${ENCODED_CHANGES_FILE}`);\n\t\tconst { allChanges, addChanges } = await this.getVlocityChanges(file_name, file_changes_id);\n\n\t\t//TODO: Promotion and merge to be improved to run conditionally.\n\t\tawait this.fetchPromotionBranch(promotionBranch, GIT_DEPTH);\n\t\tawait this.configureGit(gitEmail, gitName);\n\n\t\tconst rollBackBranchName = this.getRollBackBranchName(promotionBranch);\n\t\tconst { retrieveResult, filePaths } = await this.executeRollBackLogic(addChanges, rollBackBranchName, findAndReplaceRules, promotionFindAndReplaceRules);\n\t\tthis.logger('retrieveResult' + JSON.stringify(retrieveResult));\n\n\t\tawait this.gitMergePromotionToTarget(promotionBranch, targetBranch, GIT_DEPTH);\n\t\tthis.writeJobFile(JOB_FILE, addChanges);\n\t\tawait this.updateJobFileFromSettings(vlocitySettingsDocumentId, JOB_FILE);\n\n\t\t// Apply Find and replace\n\t\tawait this.varReplace(destinationEnv, TARGET_DIRECTORY, false);\n\t\tawait this.yamlFindAndReplace(addChanges, TARGET_DIRECTORY, findAndReplaceRules, targetBranch);\n\t\tawait this.yamlFindAndReplace(addChanges, TARGET_DIRECTORY, promotionFindAndReplaceRules, targetBranch, this.getPromotionName(promotionBranch));\n\t\tawait this.configureSfCLI(TARGET_DIRECTORY);\n\t\tconst userName = await this.getUserName(TARGET_DIRECTORY);\n\t\tawait this.validateVlocityData(JOB_FILE);\n        await this.deployVlocity(JOB_FILE,  attachVlocityLogFile === 'true', userName);\n\n\t\tawait Promise.all([this.pushChangesToRemote(targetBranch), this.cleanDeploymentFiles()]);\n\t\tif (isRollBack) {\n\t\t\tawait Promise.all([\n\t\t\t\tthis.pushChangesToRemote(rollBackBranchName),\n\t\t\t\tthis.createCopadoRollbackChangesFile(allChanges, retrieveResult, filePaths)\n\t\t\t]);\n\t\t}\n\t\tthis.saveMergeOrderOnPromotion(userStoryBranches, promotionId);\n\n\t\t// Handle Clean Pull Request operations after successful deployment\n\t\tawait this.handleCleanPullRequestOperations();\n\t} catch (err) {\n\t\tthis.logger('Error stack: ', err.stack);\n\t\texecutionError = err.message || err?.toString() || 'Unknown Error occurred';\n\t\tif (!(err instanceof CommandExecutionError)) {\n\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, RESULT_INFO.CATEGORY.UNKNOWN_EXCEPTION, `See logs for more info`, executionError);\n\t\t}\n\t} finally {\n\t\tif (resultViewerJson?.length) {\n\t\t\tthis.uploadResultViewerJson(resultViewerJson, RESULT_TABLE_COLUMNS, RESULT_TABLE_HEADER, HEADER_ICON);\n\t\t}\n\t\tif (executionError) {\n\t\t\tawait this.executeCommand(\n\t\t\t\tthis.getErrorCmdString(executionError),\n\t\t\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.POPULATE_INFO_ON_RESULT\n\t\t\t);\n\t\t\tprocess.exit(1);\n\t\t}\n\t}\n}\n\n// SCRIPT FUNCTIONS\n\nfunction checkChangesWrtCategory(sfdxFilePath) {\n\tisSfMetadataPresent = fs.existsSync(sfdxFilePath);\n\tisVlocityDataPackPresent = hasVlocityChanges?.toLowerCase() === 'true';\n\n\tif (isSfMetadataPresent) {\n\t\tthis.logger('Salesforce changes found.');\n\t} else {\n\t\tthis.logger('Salesforce changes not found.');\n\t}\n\n\tif (isVlocityDataPackPresent) {\n\t\tthis.logger('Vlocity changes found.');\n\t} else {\n\t\tthis.logger('Vlocity changes not found.');\n\t\tthis.asyncCopadoLogMessage(`No Vlocity datapacks`);\n\t}\n\n\tif (!isVlocityDataPackPresent || isValidation === 'true') {\n\t\tthis.asyncCopadoLogMessage(`Exiting Vlocity Deployment Step`);\n\t\tif (resultViewerJson?.length) {\n\t\t\tthis.uploadResultViewerJson(resultViewerJson, RESULT_TABLE_COLUMNS, RESULT_TABLE_HEADER, HEADER_ICON);\n\t\t}\n\t\tprocess.exit(0);\n\t}\n}\n\nasync function getVlocityChanges(fileName, fileChangesId) {\n\tawait this.executeCommand(\n\t\t`copado --downloadfiles ${fileChangesId} --downloaddir /tmp/`,\n\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.DOWNLOAD_FILES\n\t);\n\tlet downloadedFileName;\n\tif (fs.existsSync(`/tmp/${fileName}`)) {\n\t\tdownloadedFileName = fileName;\n\t} else if (fs.existsSync(`/tmp/${fileName}.json`)) {\n\t\tdownloadedFileName = `${fileName}.json`;\n\t} else {\n\t\tthrow new Error('Error fetching Deployment Changes');\n\t}\n\tconst deploymentMetadata = this.readFromPath(`/tmp/${downloadedFileName}`);\n\treturn {\n        allChanges: deploymentMetadata.filter((element) => element.c === 'Vlocity'),\n        addChanges: deploymentMetadata.filter((element) => element.c === 'Vlocity' && element.a?.toLowerCase() === ACTIONS.ADD)\n\t};\n}\n\nfunction writeJobFile(jobFile, vlocityChanges) {\n\tconst jobFileParameters = this.defaultJobParameters(vlocityChanges);\n\tfs.writeFileSync(jobFile, js_yaml.dump(jobFileParameters), 'utf8');\n}\n\nfunction defaultJobParameters(vlocityDataPacks) {\n\treturn {\n\t\tprojectPath: `./${vlocityDirectory}`,\n\t\toauthConnection: true,\n\t\tautoUpdateSettings: true,\n\t\tmaxDepth: 0,\n\t\tseparateMatrixVersions: true,\n\t\tseparateCalculationProcedureVersions: true,\n\t\treactivateOmniScriptsWhenEmbeddedTemplateFound: true,\n        manifest: vlocityDataPacks.map((currentData) => {\n\t\t\treturn JSON.parse(currentData.j)?.vk;\n\t\t})\n\t};\n}\n\nasync function updateJobFileFromSettings(vlocitySettingsDocumentId, jobFileName) {\n\tif (vlocitySettingsDocumentId) {\n\t\tawait this.downloadFile(vlocitySettingsDocumentId, TEMP_DIRECTORY, VLOCITY_SETTINGS_YAML_FILE);\n\t\tconst vlocitySettings = js_yaml.load(fs.readFileSync(`${TEMP_DIRECTORY}/${VLOCITY_SETTINGS_YAML_FILE}`, 'utf-8'));\n\t\tlet settings = vlocitySettings?.deploy ? Object.keys(vlocitySettings.deploy) : [];\n\n\t\tif (settings.length) {\n\t\t\tconst jobYaml = js_yaml.load(fs.readFileSync(jobFileName, 'utf-8'));\n            settings.forEach((setting) => {\n\t\t\t\tif (setting !== 'manifest' && setting !== 'projectPath' && setting !== 'maxDepth') {\n\t\t\t\t\tjobYaml[setting] = vlocitySettings.deploy[setting];\n\t\t\t\t}\n\t\t\t});\n\t\t\tfs.writeFileSync(jobFileName, js_yaml.dump(jobYaml), 'utf8');\n\t\t\tthis.asyncCopadoLogMessage('Vlocity Settings would be applied');\n\t\t} else {\n\t\t\tthis.asyncCopadoLogMessage('Vlocity Settings not found');\n\t\t}\n\t}\n}\n\nasync function downloadFile(fileId, downloadDir) {\n\tthis.asyncCopadoLogMessage('Retrieve vlocity selections');\n\tawait this.executeCommand(\n\t\t`\n        copado --downloadfiles ${fileId} --downloaddir ${downloadDir}\n    `,\n\t\tRESULT_INFO.CATEGORY.COPADO_SERVICE,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.DOWNLOAD_FILES\n\t);\n}\n\nasync function validateVlocityData(jobFile) {\n\tthis.asyncCopadoLogMessage('Validating Vlocity DataPacks');\n\tconst validateVlocityDataPacks = `vlocity -sf.sessionId ${destinationSessionid} -sf.instanceUrl ${url} -job ${jobFile} validateLocalData --json-pretty`;\n\n\tconst response = await this.executeCommand(\n\t\tvalidateVlocityDataPacks,\n\t\tRESULT_INFO.CATEGORY.VBT_CLI,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.VALIDATE_DATAPACKS,\n\t\ttrue,\n\t\ttrue\n\t);\n\tfs.writeFileSync(VALIDATION_RESULT_PATH, JSON.stringify(response, null, 2));\n\tthis.uploadFile(VALIDATION_RESULT_PATH);\n\n    if(response?.status === 'error') {\n        this.logger(`There were some errors while validating Vlocity Datapacks, to check status go to result record of Vlocity Deploy step and find file attached with name ${VALIDATION_RESULT_JSON}`);\n\t}\n}\n\nasync function deployVlocity(jobFile, attachFile, username) {\n\tthis.asyncCopadoLogMessage('Deploying Vlocity DataPacks');\n\tconst deployVlocityCommand = `\n        vlocity -sf.sessionId ${destinationSessionid} -sf.instanceUrl ${url} -job ${jobFile} packDeploy --verbose ${username ? ('-sfdx.username ' + username) : ''} --json-pretty`;\n\n\tthis.logger('Deploy Command: ' + deployVlocityCommand);\n\tthis.logger('jobfile.yaml \\n' + fs.readFileSync(jobFile, 'utf-8'));\n\n\ttry {\n\t\tconst response = await this.executeCommand(\n\t\t\tdeployVlocityCommand,\n\t\t\tRESULT_INFO.CATEGORY.VBT_CLI,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.VLOCITY_DEPLOYMENT,\n\t\t\ttrue,\n\t\t\ttrue\n\t\t);\n\t\tthis.logger(\n\t\t\t`To check status of deployed Vlocity datapacks, go to result record of Vlocity Deploy step and find file attached with name ${DEPLOYMENT_RESULT_JSON}`\n\t\t);\n\n\t\tfs.writeFileSync(DEPLOYMENT_RESULT_PATH, JSON.stringify(response, null, 2));\n\t\tthis.uploadFile(DEPLOYMENT_RESULT_PATH);\n\n\t\tif (attachFile || response?.status === 'error') {\n\t\t\tthis.maskSensitiveInfo(VLOCITY_BUILD_LOG, [destinationSessionid]);\n\t\t\tthis.uploadFile(VLOCITY_BUILD_LOG);\n\t\t}\n\t\treturn this.evaluateResponse(response);\n\t} catch (error) {\n        if(fs.existsSync(VLOCITY_BUILD_LOG)) {\n\t\t\tthis.maskSensitiveInfo(VLOCITY_BUILD_LOG, [destinationSessionid]);\n\t\t\tthis.uploadFile(VLOCITY_BUILD_LOG);\n\t\t}\n\t\tthrow new Error(error);\n\t}\n    \n}\n\nfunction maskSensitiveInfo(filePath, sensitiveInfo) {\n\tlet fileContent = fs.readFileSync(filePath, 'utf-8'),\n\t\tupdatedContent;\n    sensitiveInfo.forEach((detail) => {\n\t\tupdatedContent = fileContent?.replaceAll(detail, '****');\n\t});\n\n\tif (updatedContent && fileContent !== updatedContent) {\n\t\tfs.writeFileSync(filePath, updatedContent, 'utf-8');\n\t}\n}\n\nasync function fetchPromotionBranch(promotion, gitDepth) {\n\tconsole.log('START Fetching promotion branch');\n\tfs.mkdirSync(TARGET_DIRECTORY, { recursive: true });\n\tprocess.chdir(TARGET_DIRECTORY);\n\tthis.asyncCopadoLogMessage(`Fetching ${promotion}`);\n\tawait this.executeCommand(\n\t\t`\n            copado-git-get \"${promotion}\" --depth \"${gitDepth}\"\n        `,\n\t\tRESULT_INFO.CATEGORY.GIT,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.PROMOTION_BRANCH_CHECKOUT\n\t);\n\tconsole.log('END Fetching promotion branch');\n}\n\nasync function configureGit(gitEmail, gitName) {\n\tconst configureGit = `\n        git config --local user.email \"${gitEmail}\" || exit 1\n        git config --local user.name \"${gitName}\" || exit 1\n        git config --global diff.renames false || exit 1\n        git config --global merge.renames false || exit 1\n        git config --global status.renames false || exit 1\n    `;\n\tawait this.executeCommand(`${configureGit}`, RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CONFIG);\n}\n\nfunction cleanDeploymentFiles() {\n\tconst cleanUp = `\n        git reset --hard\n    `;\n\treturn this.executeCommand(cleanUp, RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_CLEAN);\n}\n\nasync function gitMergePromotionToTarget(promotionBranch, targetBranch, gitDepth) {\n\tthis.asyncCopadoLogMessage(`Locally merging ${promotionBranch} into ${targetBranch}`);\n\tlet checkoutTargetBranch = `\n        git reset --hard || exit 2\n        ${this.fetchCheckoutBranch(targetBranch, gitDepth, false)}\n    `;\n\n\tawait this.executeCommand(checkoutTargetBranch, RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.TARGET_BRANCH_CHECKOUT);\n\n\ttry {\n\t\tconst merge = `git merge \"${promotionBranch}\" --no-commit -Xignore-space-change`;\n\t\tawait this.executeCommand(merge, RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_MERGE);\n\t} catch (error) {\n\t\tthis.evaluateMergeStatus();\n\t\tthrow error;\n\t}\n\tawait this.commitGit(`Merging ${promotionBranch} into ${targetBranch} after auto conflict resolution`);\n}\n\nasync function commitGit(commitMessage) {\n\tawait this.executeCommand(\n\t\t`\n        git add . ':!${VLOCITY_BUILD_LOG}' ':!${JOB_FILE}' ':!${VLOCITY_TEMP}/*' || exit 1\n        git commit -am \"${commitMessage}\" || true\n    `,\n\t\tRESULT_INFO.CATEGORY.GIT,\n\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_COMMIT\n\t);\n}\n\nasync function evaluateMergeStatus() {\n    const gitStatus = await this.executeCommand('git status --porcelain=v1 -uno', RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_STATUS),\n        porcelainStatus = gitStatus.split('\\n').map((str) => str.split(' ')?.[0]),\n        isConflict = porcelainStatus.length ? ['AA', 'UU', 'DD', 'UA', 'UD', 'DU', 'AU'].some((s) => porcelainStatus.includes(s)) : false;\n\tlet infoMessage;\n\n\tif (isConflict) {\n\t\tthis.populateResultViewer(\n\t\t\tRESULT_INFO.LEVEL.ERROR,\n\t\t\tRESULT_INFO.CATEGORY.GIT,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_STATUS,\n\t\t\t`Changes detected in target branch '${targetBranch}' after promotion branch '${promotionBranch}' was created, please recreate promotion branch out of the new target branch state.`\n\t\t);\n\t\tthrow new Error(\n\t\t\t`Changes detected in target branch '${targetBranch}' after promotion branch '${promotionBranch}' was created, please recreate promotion branch out of the new target branch state.`\n\t\t);\n\t} else if (!gitStatus) {\n\t\tinfoMessage = 'Already up to date';\n\t} else {\n\t\tinfoMessage = `Changes detected in target branch '${targetBranch}' after promotion branch '${promotionBranch}' was created.`;\n\t}\n\tinfoMessage && this.asyncCopadoLogMessage(infoMessage);\n}\n\nfunction pushChangesToRemote(remoteBranchName) {\n\tthis.asyncCopadoLogMessage(`Push changes into remote ${targetBranch} branch`);\n\tconst push = `copado-git-get -g \"git push origin ${remoteBranchName}\" || exit 1`;\n\tconst deploymentSuccessMessage =\n\t\t'Important Information: Be aware that the contents of your deployment were successfully deployed to the target org and have not been removed based on this error';\n\treturn this.executeCommand(push, RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_PUSH)?.catch(error => {\n\t\tthrow new Error(`${error} ${deploymentSuccessMessage}`);\n\t});\n}\n\nfunction getErrorCmdString(error) {\n\tconst suffix = 'Please check the logs for details.';\n\tconst refinedErrorMsg = maskSensitiveInformation(error, { '-sf.sessionId': '*****' });\n    const errorMessage = JSON.stringify(refinedErrorMsg + `; ${suffix}`).trim()?.substring(0, 32760);\n\treturn `copado -p \"Error\" -e ${errorMessage}`;\n}\n\nfunction executeCommand(command, category, additionalInfo, hasJsonResponse, disableLogs) {\n\tthis.logger(`===> ${command}`);\n\treturn new Promise((resolve, reject) => {\n\t\tlet output = '';\n\t\tlet error = '';\n\n\t\tconst childProcess = child_process.spawn(command, [], { shell: true });\n\n\t\tchildProcess.stdout.on('data', data => {\n\t\t\tconst outputStream = data?.toString();\n\t\t\tif (!disableLogs && outputStream) {\n\t\t\t\tthis.logger(outputStream);\n\t\t\t}\n\t\t\toutput += outputStream;\n\t\t});\n\n\t\tchildProcess.stderr.on('data', data => {\n\t\t\tconst errorStream = data?.toString();\n\t\t\tif (errorStream) {\n\t\t\t\tthis.logger(errorStream);\n\t\t\t\terror += errorStream;\n\t\t\t}\n\t\t});\n\n\t\tchildProcess.on('close', code => {\n\t\t\tconst parseJsonSafely = (text) => {\n\t\t\t\ttry {\n\t\t\t\t\t// Match first { and last }\n\t\t\t\t\tconst jsonMatch = text.match(/{[\\s\\S]*}/);\n\t\t\t\t\tif (jsonMatch) {\n\t\t\t\t\t\treturn JSON.parse(jsonMatch[0]);\n\t\t\t\t\t}\n\t\t\t\t} catch (e) {\n\t\t\t\t\t// Ignore parse error, return null\n\t\t\t\t}\n\t\t\t\treturn null;\n\t\t\t};\n\n\t\t\tif (code !== 0) {\n\t\t\t\tlet errorMessage = '';\n\t\t\t\tif (hasJsonResponse) {\n\t\t\t\t\ttry {\n\t\t\t\t\t\tconst jsonData = parseJsonSafely(output);\n\t\t\t\t\t\tif (jsonData) {\n\t\t\t\t\t\t\treturn resolve(jsonData);\n\t\t\t\t\t\t}\n\t\t\t\t\t} catch (error) {\n\t\t\t\t\t\terrorMessage = error;\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\terrorMessage = error;\n\t\t\t\t}\n\t\t\t\terrorMessage = errorMessage ? errorMessage : `Error executing the command ${command.trim()}`;\n\n\t\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, category, additionalInfo, errorMessage);\n\t\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\t\tmaskSensitiveInformation(errorMessage, { '-sf.sessionId': '*****' })\n\t\t\t\t\t\t.split('\\n')\n\t\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t\t.join(' ')\n\t\t\t\t);\n\t\t\t\treject(new CommandExecutionError(truncatedError));\n\t\t\t}\n\n\t\t\tif (hasJsonResponse) {\n\t\t\t\tconst jsonData = parseJsonSafely(output);\n\t\t\t\tif (jsonData) {\n\t\t\t\t\treturn resolve(jsonData);\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tresolve(output);\n\t\t});\n\n\t\tchildProcess.on('error', err => {\n\t\t\tthis.populateResultViewer(RESULT_INFO.LEVEL.ERROR, category, additionalInfo, err);\n\t\t\tconst truncatedError = JSON.stringify(\n\t\t\t\tmaskSensitiveInformation(String(err), { '-sf.sessionId': '*****' })\n\t\t\t\t\t.split('\\n')\n\t\t\t\t\t.filter(msg => !msg.includes(COPADO_INFO_PREFIX))\n\t\t\t\t\t.join(' ')\n\t\t\t);\n\t\t\treject(new CommandExecutionError(truncatedError));\n\t\t});\n\t});\n}\n\nfunction evaluateResponse(response) {\n\tif (response?.status === 'error' && response?.message) {\n\t\tthis.handleDeploymentErrors(response);\n\t}\n\n\tif (response?.status === 'success' && response?.message === '0 Completed') {\n\t\tthis.asyncCopadoLogMessage('No Vlocity datapack deployed');\n\t}\n\treturn response;\n}\n\nfunction handleDeploymentErrors(response) {\n\tlet errorCount = 0,\n\t\tsuccessCount = 0,\n\t\twarningCount = 0,\n\t\treadyCount = 0;\n    response?.records.forEach((record) => {\n\t\tif (record?.VlocityDataPackStatus === 'Success') {\n\t\t\tthis.logger(`INFO: Deployment was successful for ${record?.VlocityDataPackDisplayLabel}`);\n\t\t\tsuccessCount++;\n\t\t} else if (record?.VlocityDataPackStatus === 'Error') {\n\t\t\tif (record.ErrorMessage && record?.ErrorMessage.includes('Activation Error >>')) {\n\t\t\t\tthis.populateResultViewer(\n\t\t\t\t\tRESULT_INFO.LEVEL.WARN,\n\t\t\t\t\tRESULT_INFO.CATEGORY.VBT_CLI,\n\t\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.VLOCITY_DEPLOYMENT,\n\t\t\t\t\trecord?.ErrorMessage\n\t\t\t\t);\n\t\t\t\tthis.logger(`WARNING: ${record?.ErrorMessage}`);\n\t\t\t\twarningCount++;\n\t\t\t\treturn;\n\t\t\t}\n\n            if(record.ErrorMessage) {\n\t\t\t\tthis.populateResultViewer(\n\t\t\t\t\tRESULT_INFO.LEVEL.ERROR,\n\t\t\t\t\tRESULT_INFO.CATEGORY.VBT_CLI,\n\t\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.VLOCITY_DEPLOYMENT,\n\t\t\t\t\trecord?.ErrorMessage\n\t\t\t\t);\n\t\t\t\tthis.logger(`ERROR: ${record?.ErrorMessage}`);\n\t\t\t}\n\t\t\terrorCount++;\n        } else if(record?.VlocityDataPackStatus === 'Ready') {\n\t\t\tthis.logger(`INFO: Deployment Status Ready for ${record?.VlocityDataPackDisplayLabel}`);\n\t\t\treadyCount++;\n\t\t}\n\t});\n\n\tif (warningCount > 0) {\n\t\tthis.asyncCopadoLogMessage(`copado -p 'Warnings during deployment'`);\n\t}\n\n\tif (successCount > 0 && (errorCount > 0 || readyCount > 0)) {\n\t\tthis.asyncCopadoLogMessage('Git merge aborted due to errors', RESULT_INFO.LEVEL.ERROR);\n\t\tthis.logger(`ERROR: Some datapacks were successfully deployed but the changes were not merged into the destination branch.`);\n\t}\n\n\tif (errorCount > 0 || (response?.status === 'error' && (response?.records?.length === 0 || readyCount > 0))) {\n\t\tconst errorMessage = response.message ? response.message : 'Error occurred while deploying Vlocity Datapacks.';\n\t\tthis.populateResultViewer(\n\t\t\tRESULT_INFO.LEVEL.ERROR,\n\t\t\tRESULT_INFO.CATEGORY.VBT_CLI,\n\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.VLOCITY_DEPLOYMENT,\n\t\t\t`Deployment for following DataPacks failed : ${errorMessage}`\n\t\t);\n\t\tthrow new CommandExecutionError(errorMessage);\n\t}\n}\n\nfunction getPath(filePath) {\n\treturn isTest ? `${__dirname}/__tests__/__mockDir__${filePath}` : filePath;\n}\n\nfunction getGitDepth(gitDepth) {\n\tgitDepth = parseInt(gitDepth);\n\treturn gitDepth >= 0 ? gitDepth : 100;\n}\n\nfunction fetchCheckoutBranch(branch, gitDepth, forceCreate) {\n    return `( copado-git-get -g \"git fetch origin ${branch} --depth ${gitDepth}\" && git checkout ${branch} )` + (forceCreate ? ` || git checkout -b ${branch}` : '');\n}\n\nfunction logger(text) {\n\tconsole.log(text);\n}\n\nfunction readFromPath(filePath) {\n\treturn JSON.parse(fs.readFileSync(filePath, 'utf-8'));\n}\n\nasync function uploadFile(fileName, name, parentId) {\n\tconst command = `copado --uploadfile ${fileName} ${name ? `--name '${name}'` : ''} ${parentId ? `--parentid '${parentId}'` : ''}`;\n\tthis.logger(command);\n\tawait this.executeCommand(command, RESULT_INFO.CATEGORY.COPADO_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.UPLOAD_FILES);\n}\n\nfunction isRollBackEnabled(isValidation, rollBackEnabled) {\n\treturn isValidation?.toLowerCase() !== 'true' && rollBackEnabled?.toLowerCase() === 'true';\n}\n\nasync function executeRollBackLogic(changes, rollBackBranchName, findAndReplaceRules, promotionFindAndReplaceRules) {\n\tlet result = [],\n\t\tfilePaths = [];\n\tif (isRollBack && changes?.length) {\n\t\tawait this.checkoutRollBackBranch(rollBackBranchName, targetBranch);\n\t\tthis.writeJobFile(JOB_FILE, changes);\n\t\tconst retrieveResult = await this.retrieveVlocityDataPacks();\n\t\tfs.writeFileSync(`${TEMP_DIRECTORY}/${ROLLBACK_RETRIEVE_RESULT}`, JSON.stringify(retrieveResult, null, 2));\n\t\tthis.uploadFileAtPath(`${TEMP_DIRECTORY}/${ROLLBACK_RETRIEVE_RESULT}`);\n\n\t\tfilePaths = this.getFilePaths(retrieveResult);\n\n\t\tif (filePaths.length && !hasOnlyDestructiveChanges(changes)) {\n\t\t\tawait this.varReplace(destinationEnv, ROLLBACK_RETRIEVAL_PATH, true);\n\t\t\tawait this.yamlFindAndReplace(changes, ROLLBACK_RETRIEVAL_PATH, findAndReplaceRules, rollBackBranchName);\n\t\t\tawait this.yamlFindAndReplace(changes, ROLLBACK_RETRIEVAL_PATH, promotionFindAndReplaceRules, rollBackBranchName, this.getPromotionName(promotionBranch));\n\t\t}\n\n\t\tretrieveResult?.records?.length &&\n            await this.copyFiles(`${ROLLBACK_RETRIEVAL_PATH}/${vlocityDirectory}/.`, `${TARGET_DIRECTORY}/${vlocityDirectory}/`);\n        const gitStatus = await this.executeCommand(`git status --porcelain=v1`, RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_STATUS);\n\n        const changedFiles = gitStatus.split('\\n').map((str) => str.trim().split(' ')?.[1]);\n\n        result = filePaths.filter((filePath) =>\n            changedFiles?.some((changedFile) => changedFile?.includes(filePath) || changedFile?.includes(path.dirname(filePath)))\n\t\t);\n\n\t\tawait this.commitChangesInRollbackBranch(result, filePaths, rollBackBranchName);\n\t}\n\n\treturn { filePaths, retrieveResult: result };\n}\n\nfunction hasOnlyDestructiveChanges(changes) {\n    return changes.filter((change) => change.a === 'delete').length === changes.length;\n}\n\nasync function commitChangesInRollbackBranch(changes, filepathsList, rollBackBranchName) {\n\tif (changes?.length) {\n\t\tthis.asyncCopadoLogMessage(`Committing backup to ${rollBackBranchName}`);\n\t\tawait this.gitCommit('Committing Vlocity files to rollback branch', rollBackBranchName, filepathsList, true);\n\t} else {\n\t\tthis.logger(`INFO: No changes in ${rollBackBranchName}`);\n\t}\n}\n\nfunction getRollBackBranchName(promotion) {\n\treturn 'rollback/' + promotion.split('/')[1];\n}\n\nfunction getPromotionName(promotion) {\n\treturn promotion?.split('/')[1];\n}\n\nasync function checkoutRollBackBranch(rollBackBranch, targetBranch) {\n\tlet checkoutRollbackBranch;\n\tconst rollbackBranchCreated = prevResult && JSON.parse(prevResult)?.rollbackBranchCreated;\n\tthis.asyncCopadoLogMessage(rollbackBranchCreated ? `Switching to branch ${rollBackBranch}` : `Creating ${rollBackBranch} from ${targetBranch}`);\n\n\tif (rollbackBranchCreated) {\n\t\tcheckoutRollbackBranch = `\n            git reset --hard || true\n            copado-git-get -g \"git fetch origin ${targetBranch}\" || exit 1\n            git checkout ${rollBackBranch}`;\n\t} else {\n\t\tcheckoutRollbackBranch = `\n            git reset --hard || true\n            copado-git-get -g \"git fetch origin ${targetBranch}\" || exit 1\n            git branch -D ${rollBackBranch} || true\n            git checkout -b ${rollBackBranch} origin/${targetBranch}`;\n\t}\n\n\tawait this.executeCommand(checkoutRollbackBranch, RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.ROLLBACK_BRANCH_CHECKOUT);\n}\n\nasync function retrieveVlocityDataPacks() {\n\tconst vlocityCmd = `\n        mkdir ${ROLLBACK_RETRIEVAL_PATH} || exit 1\n        cd ${ROLLBACK_RETRIEVAL_PATH} || exit 1\n        vlocity -sf.instanceUrl ${url} -sf.sessionId ${destinationSessionid} -job ${TARGET_DIRECTORY + '/' + JOB_FILE} packExport --json || true \n    `;\n\tthis.logger('Vlocity Command: ' + vlocityCmd);\n\tthis.logger('jobfile.yaml \\n' + fs.readFileSync(JOB_FILE, 'utf-8'));\n\n\tconst retrievedDataPacks = await this.executeCommand(vlocityCmd, RESULT_INFO.CATEGORY.VBT_CLI, '', true, true);\n\tthis.logger('Destination Org Retrieval status: ', JSON.stringify(retrievedDataPacks, null, 2));\n\treturn retrievedDataPacks;\n}\n\nasync function varReplace(environmentVariables, targetFolder, valueName) {\n\tif (environmentVariables && JSON.parse(environmentVariables)?.length) {\n\t\tthis.logger('START varReplace');\n\t\tlet command = `varreplace '${environmentVariables}' '${targetFolder}' ${valueName ? '--valuename=true' : ''}`;\n        await this.executeCommand(command, RESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE, RESULT_INFO.ADDITIONAL_INFORMATION.ENV_VARIABLE_REPLACEMENT);\n\t\tthis.logger('END varReplace');\n\t}\n}\n\nasync function yamlFindAndReplace(changes, targetFolder, findAndReplaceRules, branch , yamlDirName) {\n\tthis.logger('START Yaml Replace');\n\tif (changes?.length > 0 && findAndReplaceRules) {\n\t\tconst yamlDir = yamlDirName || 'Copado';\n\t\tconst additionalInfo = yamlDirName\n\t\t? RESULT_INFO.ADDITIONAL_INFORMATION.PROMOTION_FIND_AND_REPLACE\n\t\t: RESULT_INFO.ADDITIONAL_INFORMATION.GLOBAL_FIND_AND_REPLACE;\n\t\tlet command = `\n            copado --downloadfiles \"${findAndReplaceRules}\" --downloaddir ${TEMP_DIRECTORY}/ || exit 1\n            yamlreplace \"${TEMP_DIRECTORY}/${yamlDir}\" \"${targetFolder}\" -b \"${branch}\"\n        `;\n        await this.executeCommand(command, RESULT_INFO.CATEGORY.COPADO_METADATA_INTELLIGENCE, additionalInfo);\n\t}\n\tthis.logger('END Yaml Replace');\n}\n\nfunction getFilePaths(retrieveResult) {\n\tlet filePaths = [];\n    retrieveResult?.records?.forEach((record) => {\n\t\tif (record?.VlocityDataPackStatus === 'Success' && record?.VlocityDataPackKey) {\n\t\t\tfilePaths.push(convertVlocityKeyToFolderName(`${vlocityDirectory}/${record.VlocityDataPackKey}`));\n\t\t}\n\t});\n\treturn filePaths;\n}\n\nfunction asyncCopadoLogMessage(msg, logLevel) {\n\tif (msg) {\n\t\tthis.populateResultViewer(logLevel ? logLevel : RESULT_INFO.LEVEL.INFO, RESULT_INFO.CATEGORY.COPADO_INFO, '', msg);\n\t\tthis.executeCommand(`copado -p \"${msg}\"`);\n\t}\n}\n\nasync function executeCommandinChunks(fileList, chunkSize, cmd) {\n\tif (fileList.length > 0) {\n\t\tlet fileIndex = 0;\n\t\tdo {\n\t\t\tlet endIndex = fileIndex + parseInt(chunkSize) > fileList.length ? fileList.length : fileIndex + parseInt(chunkSize);\n\t\t\tlet fileChunk = fileList.slice(fileIndex, endIndex);\n\t\t\tawait this.executeCommand(\n                cmd.replace(/REPLACE_VALUE/g, fileChunk.map((file) => `'${file}'`).join(' ')),\n\t\t\t\tRESULT_INFO.CATEGORY.GIT,\n\t\t\t\tRESULT_INFO.ADDITIONAL_INFORMATION.GIT_ADD\n\t\t\t);\n\t\t\tfileIndex = endIndex;\n\t\t} while (fileIndex < fileList.length);\n\t}\n}\n\nasync function gitCommit(commitMessage, branchName, filePaths, allowCommitWithNoChanges) {\n\tconsole.log(`Committing ${commitMessage} in ${branchName}`);\n\tlet gitCommit = '';\n\tawait this.executeCommand('rm -f .git/index.lock', RESULT_INFO.CATEGORY.FILE_SYSTEM);\n\ttry {\n\t\tawait this.executeCommandinChunks(filePaths, 10, 'git add REPLACE_VALUE');\n\t} catch (error) {\n\t\tthis.logger('Re-trying staging using Git add . as chunking failed : ' + error);\n\t\tgitCommit = 'git add . || exit 1';\n\t}\n\tgitCommit = `\n\t\t${gitCommit} \n\t\tgit commit -m \"${commitMessage}\" ${allowCommitWithNoChanges ? ' || true' : ''}`;\n\tawait this.executeCommand(gitCommit, RESULT_INFO.CATEGORY.GIT, RESULT_INFO.ADDITIONAL_INFORMATION.GIT_COMMIT);\n}\n\nfunction createCopadoRollbackChangesFile(changeList, retrieveResult, exportedFilePaths) {\n    return new Promise((resolve) => {\n\t\tconst rollbackChanges = JSON.parse(JSON.stringify(changeList));\n        rollbackChanges.forEach((record) => {\n\t\t\tif (record.a?.toLowerCase() === ACTIONS.ADD) {\n\t\t\t\trecord.a = ROLLBACK_ACTION.DELETE_NOT_SUPPORTED;\n\t\t\t} else if (record.a?.toLowerCase() === ACTIONS.DELETE) {\n\t\t\t\trecord.a = ROLLBACK_ACTION.CREATE_NOT_SUPPORTED;\n\t\t\t} else if (record.a?.toLowerCase() === ACTIONS.RETRIEVE_ONLY) {\n\t\t\t\trecord.a = ROLLBACK_ACTION.UNCHANGED;\n\t\t\t}\n\t\t\trecord.s = true;\n\t\t});\n\n        exportedFilePaths?.forEach((path) => {\n\t\t\tconst updatedNode = rollbackChanges.find(\n                (change) => change.j && convertVlocityKeyToFolderName(JSON.parse(change.j)?.vk) === path.substring(path.indexOf('/') + 1)\n\t\t\t);\n\t\t\tif (updatedNode) {\n\t\t\t\tupdatedNode.a = ROLLBACK_ACTION.UPDATE;\n\t\t\t}\n\t\t});\n\n        retrieveResult?.forEach((result) => {\n\t\t\tconst updatedNode = rollbackChanges.find(\n                (change) => change.j && convertVlocityKeyToFolderName(JSON.parse(change.j)?.vk) === result.substring(result.indexOf('/') + 1)\n\t\t\t);\n\t\t\tif (updatedNode) {\n\t\t\t\tupdatedNode.a = ROLLBACK_ACTION.UPDATE;\n\t\t\t}\n\t\t});\n\n\t\tthis.asyncCopadoLogMessage('Uploading Rollback Changes File');\n\t\tfs.writeFileSync(VLOCITY_ROLLBACK_JSON, JSON.stringify(rollbackChanges));\n\t\tthis.uploadFile(VLOCITY_ROLLBACK_JSON, 'Copado Vlocity Rollback changes', promotionId);\n\t\tresolve();\n\t});\n}\n\nasync function copyFiles(source, target) {\n\tthis.logger(`cp -R ${source} ${target}`);\n\tawait this.executeCommand(\n\t\t`\n        cp -R ${source} ${target}\n        `,\n\t\tRESULT_INFO.CATEGORY.FILE_SYSTEM\n\t);\n}\n\nfunction convertVlocityKeyToFolderName(vk) {\n\tlet result;\n\tif (vk) {\n\t\tresult = vk\n\t\t\t.replace('\\\\', '-')\n\t\t\t.replace(/[^A-Za-z0-9/_\\-]+/g, '-')\n\t\t\t.replace(/[-]+/g, '-')\n\t\t\t.replace(/[-_]+_/g, '_')\n\t\t\t.replace(/[-]+\\/[-]+/g, '/')\n\t\t\t.replace(/^[-_\\\\/]+/, '')\n\t\t\t.replace(/[-_\\\\/]+$/, '');\n\t}\n\treturn result;\n}\n\nfunction populateResultViewer(level, category, additionalInfo, message) {\n\tconst refinedMessage = maskSensitiveInformation(message, { '-sf.sessionId': '*****' });\n\tif (refinedMessage) {\n\t\tresultViewerJson.push({\n\t\t\tLevel: level,\n\t\t\tCategory: category,\n\t\t\tMessage: refinedMessage,\n\t\t\tAdditionalInformation: additionalInfo\n\t\t});\n\t}\n}\n\nfunction uploadResultViewerJson(data, columns, header, headerIcon) {\n\tconst RESULT_VIEWER_JSON_PATH = `${TEMP_DIRECTORY}/ResultViewer.json`;\n\n\tconst fileContent = { data, columns, header, headerIcon };\n\tfs.writeFileSync(RESULT_VIEWER_JSON_PATH, JSON.stringify(fileContent, null, 2));\n\tthis.uploadFileAtPath(RESULT_VIEWER_JSON_PATH);\n}\n\nfunction uploadFileAtPath(filePath, parentId) {\n\tconst command = `copado --uploadfile ${filePath} ${parentId ? '--parentid ' + parentId : ''}`;\n\treturn this.executeCommand(command, RESULT_INFO.CATEGORY.COPADO_SERVICE, RESULT_INFO.ADDITIONAL_INFORMATION.UPLOAD_FILES);\n}\n\nasync function displayVersions() {\n    await this.executeCommand(`\n            echo \"Node version: \"\n            node -v\n            echo \"VBT version: \"\n            vlocity -v`, RESULT_INFO.CATEGORY.COPADO_INFO);\n}\n\n\nfunction saveMergeOrderOnPromotion(userStoryBranches, promotionId) {\n\tconst fileContent = {};\n\tfileContent.usMergeOrder = userStoryBranches && JSON.parse(userStoryBranches);\n\tfileContent.deploymentDate = new Date();\n\tfs.writeFile(PROMOTION_US_MERGE_ORDER, JSON.stringify(fileContent, null, 2), err => {\n\t\tif (err) {\n\t\t\tthis.logger(err);\n\t\t} else {\n\t\t\tthis.uploadFile(PROMOTION_US_MERGE_ORDER, null, promotionId).catch(err => {\n\t\t\t\tthis.logger('Error uploading US Merge order on the promotion : ', err);\n\t\t\t});\n\t\t}\n\t});\n}\n\nasync function configureSfCLI(dirPath) {\n\tlet configSet = dirPath ? `cd ${dirPath}` : '';\n\tconfigSet += `\n\tSF_ACCESS_TOKEN=${destinationSessionid} sf org login access-token --instance-url ${url} --set-default --no-prompt || exit 1`;\n\n\tawait this.executeCommand(configSet, RESULT_INFO.CATEGORY.SF_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.SFDX_CONFIG);\n}\n\nasync function getUserName(dirPath) {\n\tlet configSet = dirPath ? `cd ${dirPath}` : '';\n\tconfigSet += `\n    sf org display --json`;\n\n\tconst response = await this.executeCommand(configSet, RESULT_INFO.CATEGORY.SF_CLI, RESULT_INFO.ADDITIONAL_INFORMATION.SFDX_CONFIG, true, true);\n\treturn response?.result?.username;\n}\n\nfunction maskSensitiveInformation(data, sensitiveFlags) {\n\tconst maskingSequence = '*****';\n\n\tconst arrayOfData = data.split(' ');\n\tObject.keys(sensitiveFlags).forEach(subStr => {\n\t\tconst keyIndex = arrayOfData.indexOf(subStr);\n\t\tif (keyIndex > -1) {\n\t\t\tarrayOfData[keyIndex + 1] = maskingSequence;\n\t\t\tarrayOfData.splice(keyIndex + 2, sensitiveFlags[subStr].split(' ').length - 1);\n\t\t}\n\t});\n\treturn arrayOfData.join(' ');\n}\n\n// Clean Pull Request Main function\nasync function handleCleanPullRequestOperations() {\n\tif (!this.isCleanPullRequestEnabled()) {\n\t\treturn;\n\t}\n\n\tconst userStoryBranchesList = this.getUserStoryBranchesList();\n\tconst cleanPullRequestResults = await this.processCleanPullRequestForAllUserStories(userStoryBranchesList);\n\tconst errors = this.collectCleanPullRequestErrors(cleanPullRequestResults, userStoryBranchesList);\n\tthis.throwIfCleanPullRequestErrors(errors);\n}\n\n// Clean Pull Request Helper Functions\nfunction isCleanPullRequestEnabled() {\n\treturn cleanPullRequestEnabled && cleanPullRequestEnabled.toLowerCase() === 'true';\n}\n\nfunction getIsolationBranchName(featureBranch) {\n\treturn `isolation/${featureBranch}`;\n}\n\nasync function checkIsolationBranchExists(isolationBranchName) {\n\ttry {\n\t\tconst result = await this.executeCommand(\n\t\t\t`git ls-remote --heads origin ${isolationBranchName}`,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t`Check if isolation branch ${isolationBranchName} exists`\n\t\t);\n\n\t\t// git ls-remote returns empty string if branch doesn't exist\n\t\tconst branchExists = result && result.trim().length > 0;\n\t\treturn branchExists;\n\t} catch (error) {\n\t\treturn false;\n\t}\n}\n\nasync function deleteIsolationBranch(isolationBranchName) {\n\ttry {\n\t\t// Delete remote isolation branch\n\t\tawait this.executeCommand(\n\t\t\t`copado-git-get -g \"git push origin --delete ${isolationBranchName}\"`,\n\t\t\tRESULT_INFO.CATEGORY.GIT_SERVICE,\n\t\t\t`Delete remote isolation branch ${isolationBranchName}`\n\t\t);\n\t} catch (error) {\n\t\tthrow error;\n\t}\n}\n\nasync function handleCleanPullRequestForUserStory(userStoryBranch) {\n\tconst isolationBranchName = this.getIsolationBranchName(userStoryBranch);\n\n\tconst isolationBranchExists = await this.checkIsolationBranchExists(isolationBranchName);\n\n\tif (!isolationBranchExists) {\n\t\treturn;\n\t}\n\n\tawait this.deleteIsolationBranch(isolationBranchName);\n}\n\nfunction getUserStoryBranchesList() {\n\treturn JSON.parse(userStoryBranches);\n}\n\nasync function processCleanPullRequestForAllUserStories(userStoryBranchesList) {\n\tconst cleanPullRequestResults = await Promise.allSettled(\n\t\tuserStoryBranchesList.map(userStory => {\n\t\t\treturn this.handleCleanPullRequestForUserStory(userStory);\n\t\t})\n\t);\n\treturn cleanPullRequestResults;\n}\n\nfunction collectCleanPullRequestErrors(cleanPullRequestResults, userStoryBranchesList) {\n\tconst errors = [];\n\tcleanPullRequestResults.forEach((result, index) => {\n\t\tif (result.status === 'rejected') {\n\t\t\tconst userStory = userStoryBranchesList[index];\n\t\t\tconst errorMsg = `User Story ${userStory}: ${result.reason?.message || result.reason}`;\n\t\t\tthis.logger(`Error handling Clean Pull Request for ${userStory}: ${result.reason?.message || result.reason}`);\n\t\t\terrors.push(errorMsg);\n\t\t}\n\t});\n\treturn errors;\n}\n\nfunction throwIfCleanPullRequestErrors(errors) {\n\tif (errors.length > 0) {\n\t\tconst errorMessage = `Clean Pull Request operations failed for ${errors.length} user story(ies):\\n${errors.join('\\n')}`;\n\t\tthrow new Error(errorMessage);\n\t}\n}\n\nclass CommandExecutionError extends Error {\n\tconstructor(message) {\n\t\tsuper(message);\n\t\tthis.name = CUSTOM_ERROR.COMMAND_EXECUTION_ERROR;\n\t}\n}\n\nmodule.exports.execute = execute;\nmodule.exports.fetchPromotionBranch = fetchPromotionBranch;\nmodule.exports.configureGit = configureGit;\nmodule.exports.gitMergePromotionToTarget = gitMergePromotionToTarget;\nmodule.exports.getGitDepth = getGitDepth;\nmodule.exports.defaultJobParameters = defaultJobParameters;\nmodule.exports.writeJobFile = writeJobFile;\nmodule.exports.getVlocityChanges = getVlocityChanges;\nmodule.exports.validateVlocityData = validateVlocityData;\nmodule.exports.pushChangesToRemote = pushChangesToRemote;\nmodule.exports.cleanDeploymentFiles = cleanDeploymentFiles;\nmodule.exports.deployVlocity = deployVlocity;\nmodule.exports.commitGit = commitGit;\nmodule.exports.evaluateMergeStatus = evaluateMergeStatus;\nmodule.exports.fetchCheckoutBranch = fetchCheckoutBranch;\nmodule.exports.checkChangesWrtCategory = checkChangesWrtCategory;\nmodule.exports.executeCommand = executeCommand;\nmodule.exports.evaluateResponse = evaluateResponse;\nmodule.exports.getErrorCmdString = getErrorCmdString;\nmodule.exports.logger = logger;\nmodule.exports.readFromPath = readFromPath;\nmodule.exports.uploadFile = uploadFile;\nmodule.exports.updateJobFileFromSettings = updateJobFileFromSettings;\nmodule.exports.downloadFile = downloadFile;\nmodule.exports.handleDeploymentErrors = handleDeploymentErrors;\nmodule.exports.isRollBackEnabled = isRollBackEnabled;\nmodule.exports.executeRollBackLogic = executeRollBackLogic;\nmodule.exports.getRollBackBranchName = getRollBackBranchName;\nmodule.exports.checkoutRollBackBranch = checkoutRollBackBranch;\nmodule.exports.commitChangesInRollbackBranch = commitChangesInRollbackBranch;\nmodule.exports.retrieveVlocityDataPacks = retrieveVlocityDataPacks;\nmodule.exports.varReplace = varReplace;\nmodule.exports.yamlFindAndReplace = yamlFindAndReplace;\nmodule.exports.getFilePaths = getFilePaths;\nmodule.exports.asyncCopadoLogMessage = asyncCopadoLogMessage;\nmodule.exports.gitCommit = gitCommit;\nmodule.exports.executeCommandinChunks = executeCommandinChunks;\nmodule.exports.createCopadoRollbackChangesFile = createCopadoRollbackChangesFile;\nmodule.exports.copyFiles = copyFiles;\nmodule.exports.populateResultViewer = populateResultViewer;\nmodule.exports.uploadFileAtPath = uploadFileAtPath;\nmodule.exports.uploadResultViewerJson = uploadResultViewerJson;\nmodule.exports.displayVersions = displayVersions;\nmodule.exports.maskSensitiveInfo = maskSensitiveInfo;\nmodule.exports.saveMergeOrderOnPromotion = saveMergeOrderOnPromotion;\nmodule.exports.configureSfCLI = configureSfCLI;\nmodule.exports.getUserName = getUserName;\nmodule.exports.maskSensitiveInformation = maskSensitiveInformation;\nmodule.exports.handleCleanPullRequestOperations = handleCleanPullRequestOperations;\nmodule.exports.isCleanPullRequestEnabled = isCleanPullRequestEnabled;\nmodule.exports.getIsolationBranchName = getIsolationBranchName;\nmodule.exports.checkIsolationBranchExists = checkIsolationBranchExists;\nmodule.exports.deleteIsolationBranch = deleteIsolationBranch;\nmodule.exports.handleCleanPullRequestForUserStory = handleCleanPullRequestForUserStory;\nmodule.exports.getUserStoryBranchesList = getUserStoryBranchesList;\nmodule.exports.processCleanPullRequestForAllUserStories = processCleanPullRequestForAllUserStories;\nmodule.exports.collectCleanPullRequestErrors = collectCleanPullRequestErrors;\nmodule.exports.throwIfCleanPullRequestErrors = throwIfCleanPullRequestErrors;\nmodule.exports.getPromotionName = getPromotionName;\n\n!isTest && this.execute();",
